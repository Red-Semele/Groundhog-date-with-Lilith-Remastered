## review_credentials.rpy.example
## Copy this file to review_credentials.rpy and fill in your values.
## review_credentials.rpy is gitignored and should NEVER be committed.

init -10 python:
    _REVIEW_WEBHOOK_URL = "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN"
    _REVIEW_BOT_TOKEN   = "YOUR_BOT_TOKEN_HERE"
    _REVIEW_CHANNEL_ID  = ""  ## leave blank to auto-detect from webhook URL
