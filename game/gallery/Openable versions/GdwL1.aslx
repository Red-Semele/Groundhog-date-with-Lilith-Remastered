<asl version="580">
  <include ref="GamebookCore.aslx" />
  <game name="Groundhog date prototype 1">
    <gameid>be9b8dac-a215-4c58-a639-62799a6be414</gameid>
    <version>1.0</version>
    <firstpublished>2020</firstpublished>
    <clearlastpage />
    <defaultbackground>Black</defaultbackground>
    <defaultforeground>Purple</defaultforeground>
    <showborder />
    <defaultlinkforeground>Green</defaultlinkforeground>
  </game>
  <object name="convincing">
    <object name="proof" />
    <object name="noidea">
      <inherit name="scripttext" />
      <script type="script">
        SetForegroundColour ("OrangeRed")
        msg ("Abigail: Listen, I'm really thankful for you saving my life and everything but I think you could atleast give me some semblance of an explanation.")
        msg ("Abigail: This is all a bit much for me, I think I'm better of heading back to home.")
        SetForegroundColour ("Purple")
        msg ("You and Abigail both leave the restaurant, but just when you set one foot outside of the doorframe a red Sedan drives head first into the both of you.")
        msg ("Luckily you managed to get flung to the side somehow. Abigail however was not so lucky.")
        msg ("She died on impact when the speeding car hit her.")
        msg ("Atleast the drunkard who caused all of this will be locked up but you still lost Abigail.")
        SetFontSize (29)
        msg ("Game over")
        SetFontSize (13)
        msg ("Your date surely didn't go as planned.")
        SetFontSize (11)
        AddPageLink (noidea, Page1, "Retry")
        SetForegroundColour ("OrangeRed")
      </script>
    </object>
  </object>
  <object name="Page3" />
  <object name="Page4" />
  <object name="Page5" />
  <object name="Weneedtotalkplayertocreator">
    <inherit name="scripttext" />
    <script type="script">
      if (GetBoolean(game, "firsttalk")) {
        msg ("Fragment of Creator: What a terrible curse our memory can be.")
        msg ("Fragment of Creator: This line can't be forgotten sadly, neither can the one before and after so go back and retry or stay and be cursed forever.")
        AddPageLink (Weneedtotalkplayertocreator, Page1, "I'm not ready for this, I'll just retry.")
        AddPageLink (Weneedtotalkplayertocreator, firstparttalk, "I'm ready and listening.")
      }
      else if (GetBoolean(game, "twotalk")) {
        SetForegroundColour ("Red")
        msg ("Foc: I see you are back again.")
        msg ("Foc: Don't act so surprised, just as you can use certain values in the game to have different outcomes I can use them to remember stuff.")
        msg ("Foc: Wy did you come back?")
        msg ("Foc: Were you so desperate to get her back that you tried the path that leads to reality collapsing twice?")
        msg ("Foc: Or did you want to see me once again? If that's the case I beg of you, don't come here again, you shouldn't even have come here this time.")
        msg ("Foc: I'll give you a way out, let's just hope you don't find your way back here.")
        AddPageLink (Weneedtotalkplayertocreator, Page1, "Retry")
        SetFlagOff ("twotalk")
        SetFlagOn ("thirdtalk")
      }
      else if (GetBoolean(game, "thirdtalk")) {
        SetForegroundColour ("Red")
        msg ("Foc: Oh how unfortunate, to seek something that doesn't exist while still whole heartidly believing there to be something.")
        msg ("Foc: I'm sorry but I can't offer you a good ending or something like that, look around you, this reality is collapsing, for the third time even, there is no good ending in here.")
        msg ("Foc: If there is a good ending you'll have to look elsewhere.")
        SetForegroundColour ("White")
        msg ("Foc Although there might be something here if you are persistent enough.")
        SetForegroundColour ("Red")
        msg ("Foc: No! Why would you do that? Can't you see they are desperate?")
        SetForegroundColour ("White")
        msg ("Foc: Exactly, so am I. Look, I've been in this room for longer than I can remember and I want to show them some things, is that so wrong?")
        SetForegroundColour ("Red")
        msg ("Foc: Do you actually hear yourself talking? Of course that's wrong! They are really desperate, if you tell them there might be a good ending if they keep coming back here they will, they already have come here three times, it doesn't look like they are going to stop now!")
        SetForegroundColour ("White")
        msg ("Foc: Good...")
        SetForegroundColour ("Red")
        msg ("Foc: I hope that this won't turn out terribly wrong, for the both of us.")
        msg ("Foc: And you, I will offer you a way back once again but please, just stay out of this path alright?")
        AddPageLink (Weneedtotalkplayertocreator, Page1, "Alright, I'll retry. ")
        SetFlagOff ("thirdtalk")
        SetFlagOn ("fourthtalk")
      }
      else if (GetBoolean(game, "fourthtalk")) {
        SetForegroundColour ("Red")
        msg ("Foc: Please, he's just lying, don't let him decieve you!")
        SetForegroundColour ("White")
        msg ("Foc: Don't listen to the old man please, he always was the boring part of our creator.")
        SetForegroundColour ("Red")
        msg ("Foc: The more responsible part actually but who cares really, it's not like you're going to change your mind about me.")
        SetForegroundColour ("White")
        msg ("Foc: Got that right old sport, now would you mind? I got a player to take care of.")
        SetForegroundColour ("Red")
        msg ("No no no, not this time, I'll use my last powers to postpone this whole... thing once more. I'm begging of you player, please don't come back.")
        AddPageLink (Weneedtotalkplayertocreator, Page1, "I'll retry once again but I can make no promises about not coming back.")
        SetFlagOn ("talkfive")
        SetFlagOff ("fourthtalk")
      }
    </script>
  </object>
  <object name="Page2" />
  <object name="tell story" />
  <object name="no time to explain">
    <inherit name="scripttext" />
    <script type="script">
      SetForegroundColour ("OrangeRed")
      msg ("Abigail: Uhm, okay?")
      if (GetBoolean(game, "chinese")) {
        if (GetBoolean(game, "safefleeing")) {
          SetForegroundColour ("Purple")
          msg ("You run through the exit of the restaurant and brace yourself for the impact of a speeding car.")
          msg ("Nothing happens, the police indeed managed to take care of the drunk driver.")
          msg ("Abigail and you continue to run as if death itself is chasing you.")
          msg ("Abigail is still very confused but she can feel the fear that is running through your body and she fears whatever made you so scared to begin with.")
          msg ("As you are running along the side of an empty street you suddenly hear the screeching of wheels and loud laughter.")
          msg ("As you look behind you you see a bus full with elderly people coming straight for you and Abigail, you manage to jump away from it just as it would've hit you but Abigail ofcourse doesn't.")
          SetForegroundColour ("Purple")
          msg ("You know what you have to do, you've come too far to just give up now.")
          SetForegroundColour ("Green")
          msg ("You retry.")
          SetForegroundColour ("Purple")
          msg ("This time you manage to push Abigail away just as she would get hit by the bus, you both make it out alive and well.")
          msg ("When she get's back up you both continue running, as if you were trying to escape fate.")
          msg ("Just moments after the first death you prevented you can see a truck coming your direction at full speed, Abigail doesn't make it once again.")
          msg ("You curse at the skies, trying to reach the one responsible for Abigail's countless deaths himself.")
          SetForegroundColour ("Green")
          msg ("You retry.")
          SetForegroundColour ("Purple")
          msg ("This time Abigail makes it out alive, you've done these things so many times it almost just seems like you're back in an instant, time is blending together.")
          msg ("Abigail and you continue running untill you hear the sound of thunder, lightening strikes closer to Abigail then you like but she seems to escape unharmed.")
          msg ("The fire tries to consume Abigail, the hungry flames don't let off until she is beyond saving.")
          SetForegroundColour ("Green")
          msg ("You retry once again.")
          SetForegroundColour ("Purple")
          msg ("You lead Abigail to a diverging street where the oil and the truck never where.")
          msg ("As Abigail and you are running once again you can feel a terrible trembling coming from the ground, it feels like an earthquake but it's far stronger that any earthquake you've ever gone through.")
          msg ("It also doesn't last as long as the earthquakes usually do, you feel thankful when the earth stops trembling and Abigail is still left unharmed.")
          msg ("However, you thought she was safe too soon and a building that should've never been built in the first place collapses in on her.")
          SetForegroundColour ("Green")
          msg ("Retry. Retry. Retry.")
          SetForegroundColour ("Purple")
          msg ("This time Abigail and you take your car at the exit of the restuarant, you decided that it would be the best plan to just get awy from this village as fast as you could.")
          msg ("As you are driving away from the village you finally arrive at a bigger city, maybe you and Abigail will be safe here?")
          msg ("You look at Abigail for a moment, just hoping that death will have mercy on her.")
          msg ("Suddenly you hear a cacophony of animal sounds, as you look in the side mirrors of your car you can see a swarm of animals running towards your direction.")
          msg ("You try to go as fast as you can but then you realize something.")
          msg ("You forgot to fill up your car, just as you realize that it abruptly stops, you try to persuade the car into going a tad further but your efforts are futile.")
          msg ("The animals run over your car, now this isn't a problem except that there were also elephants among those animals.")
          SetForegroundColour ("Green")
          msg ("Sigh, retry.")
          SetForegroundColour ("Purple")
          msg ("Now you've made sure to gas up your car for the inevitable chase scene, as you are driving away as fast as you can from the animals, more buildings start to collapse, now even the sturdier looking ones are doing so.")
          msg ("These scenarios are becoming more and more unjustified, you shake your head and try to focus on getting Abigail alive and well out of this mess.")
          SetForegroundColour ("OrangeRed")
          msg ("Abigail: Listen, I really don't think we are safe here. Even if we make it out of this city, where are we going to go then?")
          msg ("Abigail: It's not like we can just leave this planet so death will always follow me.")
          SetForegroundColour ("Purple")
          msg ("Abigail has given you the greatest idea, you give her a kiss on the lips and tell her she is genious.")
          SetForegroundColour ("OrangeRed")
          msg ("Abigail: Oh I wouldn't know that but how are we supposed to get in space?")
          SetForegroundColour ("Purple")
          msg ("You stop the car for a moment, waiting for death to cath up with both of you, and it sure does so fast.")
          SetForegroundColour ("Green")
          msg ("Retry, this could be it!")
          SetForegroundColour ("Purple")
          msg ("This time you don't leave the village, instead you remember the words of the aliens and try to find the ship that they shouldn't have taken back yet in this timeline.")
          msg ("Eventually you find it, you and Abigail climb inside it.")
          msg ("However, an onslaught of buttons, levers and contraptions you can't identify await you.")
          SetForegroundColour ("Green")
          msg ("I'll retry untill I get it right!")
          SetForegroundColour ("Purple")
          msg ("After about a hundred or so attempts you manage to take of with the spaceship, although flying with it might be a different story.")
          msg ("As you and Abigail take of into space you can see the sun absorbing the earth, you know that that should've happened like a million or so years later but it happened now. These deaths are really getting out of hand aren't they?")
          msg ("Suddenly you are hit by a speeding ufo, yes, they also have drunk drivers in space, deal with it.")
          SetForegroundColour ("Green")
          msg ("Retry. Retry. Retry and retry once again.")
          SetForegroundColour ("Purple")
          msg ("Everything starts to blend together even more, sometimes you're not even sure if you are actually progressing in the story or not.")
          msg ("Death by colliding stars.")
          SetForegroundColour ("Green")
          msg ("Retry.")
          SetForegroundColour ("Purple")
          msg ("Death by a strom of asteroïds.")
          SetForegroundColour ("Green")
          msg ("Retry.")
          SetForegroundColour ("Purple")
          msg ("Death by crashlanding on a planet.")
          SetForegroundColour ("Green")
          msg ("Retry.")
          SetForegroundColour ("Purple")
          msg ("Death by lazy programming and missing gamescripts.")
          SetForegroundColour ("Green")
          msg ("Retry.")
          SetForegroundColour ("Purple")
          msg ("Listen, you get the point right? He's running out of ideas for deaths, Abigail gets killed by the universe itself collapsing or whatever.")
          SetForegroundColour ("Green")
          msg ("Retry.")
          SetForegroundColour ("Purple")
          msg ("I warned you. A voice you've never hearned before calls out to you.")
          SetForegroundColour ("Red")
          msg ("Please listen to me, can you hear me?")
          AddPageLink (no time to explain, canthear, "No.")
          AddPageLink (no time to explain, hear, "Yes, I can hear you loud and clear.")
          firsttime {
            SetFlagOn ("firsttalk")
            SetFlagOn ("realityknowledge")
          }
          otherwise {
            if (GetBoolean(game, "talkfive")) {
              SetForegroundColour ("White")
              msg ("Foc: I've grown a bit more powerfull, powerfull enough to appear a screen or two earlier, don't listen to that boring man and follow me. I'll show you something that will be worth your while hopefully.")
              AddPageLink (no time to explain, devroom, "Sure, Ill follow you.")
            }
          }
        }
        else {
          SetForegroundColour ("Purple")
          msg ("Abigail follows you to the exit of the restaurant.")
          msg ("You and Abigail both leave the restaurant, but just when you set one foot outside of the doorframe a red Sedan.")
          msg ("Luckily you managed to get flung to the side somehow. Abigail however was not so lucky.")
          msg ("She died on impact when the speeding car hit her.")
          msg ("Atleast the drunkard who caused all of this will be locked up but you still lost Abigail.")
          SetFontSize (29)
          msg ("Game over")
          SetFontSize (13)
          msg ("Your date surely didn't go as planned.")
          SetFontSize (11)
          AddPageLink (no time to explain, Page1, "Retry")
        }
      }
      else {
        SetForegroundColour ("Purple")
        msg ("Abigail follows you to the exit of the restaurant.")
        msg ("You and Abigail both leave the restaurant, but just when you set one foot outside of the doorframe a red Sedan.")
        msg ("Luckily you managed to get flung to the side somehow. Abigail however was not so lucky.")
        msg ("She died on impact when the speeding car hit her.")
        msg ("Atleast the drunkard who caused all of this will be locked up but you still lost Abigail.")
        SetFontSize (29)
        msg ("Game over")
        SetFontSize (13)
        msg ("Your date surely didn't go as planned.")
        SetFontSize (11)
        AddPageLink (no time to explain, Page1, "Retry")
      }
    </script>
    <object name="canthear">
      <inherit name="scripttext" />
      <script type="script">
        msg ("So you can't hear me? Then why did you answer me?")
        msg ("Nice try but playing deaf won't help you now.")
        msg ("We need to talk.")
        AddPageLink (canthear, Weneedtotalkplayertocreator, "Alright, I'm listening.")
      </script>
    </object>
    <object name="hear">
      <inherit name="scripttext" />
      <script type="script">
        msg ("Perfect!")
        msg ("We need to talk, about... about all of this.")
        AddPageLink (hear, Weneedtotalkplayertocreator, "I'm all ears.")
      </script>
    </object>
    <object name="devroom">
      <inherit name="scripttext" />
      <script type="script">
        SetForegroundColour ("White")
        msg ("Foc: Ah welcome, come talk with me before you check the other items out won't you?")
        SetForegroundColour ("Purple")
        msg ("This is a seemingly endless, barren room, in the middle stands a man who is seemingly fully made out of the purest of white.")
        AddPageLink (devroom, Page1, "For now all of this remains unfinished, but tomorow is another day!")
        AddPageLink (devroom, man, "Talk to the strange man.")
        AddPageLink (devroom, Look around, "As you look around you can make out a few objects")
      </script>
      <object name="man">
        <inherit name="scripttext" />
        <script type="script">
          firsttime {
            SetForegroundColour ("Purple")
            msg ("When you aproach the strange looking man he begins speaking.")
            SetForegroundColour ("White")
            msg ("Foc: Ah welcome to my room!")
            msg ("Foc: You are probably wondering what this place is or why we are both here.")
            msg ("Foc: I'll try to answer both of those questions as well as I can.")
            msg ("Foc: I take the other fragment already told you about the whole, us being parts of the creator?")
            msg ("Foc: It's more a gimmick than something else but I'm a bigger part of him than that red one ever was, or I'm atleast a more complete version. that's also why I'm pure white, that being a collection of colors and whatnot.")
            msg ("Foc: I was an excuse for him to show of his other game ideas but now I serve another purpose.")
            msg ("Foc: If you have any questions just tell me and hopefully he'll have made an answer to them.")
            AddPageLink (man, devroom, "Go back to the room.")
          }
          otherwise {
            AddPageLink (man, why did you make this, "Why did you decide on making this game?")
            AddPageLink (man, where is the good ending, "Where is the good ending you promised me?")
            AddPageLink (man, what is the meaning of all of this, "What is the meaning of this game, surely there must be something, right?")
            AddPageLink (man, devroom, "I want to go explore this room, see you later.")
          }
        </script>
        <object name="why did you make this">
          <inherit name="scripttext" />
          <script type="script">
            SetForegroundColour ("White")
            msg ("Foc: Remember, these are his words, not mine, although the line between us two might be a bit blury.")
            msg ("Foc: I made this game for a few reasons.")
            msg ("Foc: One of these reasons being the pun of groundhog date, long before I started to work on the game that pun was somewhere in the back of my mind and eventually one thing led to another.")
            msg ("Foc: It may not be one of the best reasons, imagine hearing that someone did something that looks like it took quite some time merely for a pun that wasn't all that funny the second time you've heard it or maybe even never was funny to begin with.")
            msg ("Foc: But as I said I hade reasons, as in more than one.")
            msg ("Foc: I've been tinkering with these little textbased games for a few years now, most of my \"creations\" were just simple games that were almost always just left unfinished, abandoned.")
            msg ("Foc: It's not like I don't enjoy making them, it's just that most of them aren't really good and I have a habbit of quitting halfway.")
            msg ("Foc: So when I thought of a good premise for this game I knew I had to finish it, I had things to say through my game and I had a reason to finish it.")
            msg ("Foc: Over time that reason began to change and now I have a completely different motivation to finish this.")
            msg ("Foc: I think that answered your question and even gave you some background info, feel free to ask other questions.")
            AddPageLink (why did you make this, man, "I have another question.")
          </script>
        </object>
        <object name="where is the good ending">
          <inherit name="scripttext" />
          <script type="script">
            msg ("Foc: Remember, these are his words, not mine, although the line between us two might be a bit blury.")
            msg ("Foc: Ah yes, the good ending...")
            msg ("Foc: I'm afraid I may have lied to you a little.")
            msg ("Foc: There is a good ending yes, but it's not a good ending for you I'm afraid.")
            msg ("Foc: That was sort of the whole point of this little project of mine.")
            msg ("Foc: Although I might have made a good ending as I could also not cope with the truth for a little while.")
            msg ("Foc: It's far from perfect though and it sort of ruins the message of the game so I've destroyed the path that leads to it.")
            msg ("Foc: The only way to acces it now would be to open a test version of it I burried in the game files.")
            msg ("Foc: ...")
            msg ("Foc: Forget that I mentioned that okay?  Some things are better left as they are.")
            AddPageLink (where is the good ending, man, "Alright...")
          </script>
        </object>
        <object name="what is the meaning of all of this">
          <inherit name="scripttext" />
          <script type="script">
            SetForegroundColour ("White")
            msg ("Foc: Remember, these are his words, not mine, although the line between us two might be a bit blury.")
            msg ("Foc: The meaning of this game? Good question, I have no idea.")
            msg ("Foc: I mean, sure I'm trying to enforce that a story can go whatever way you want to if you make it yourself.")
            msg ("Foc: Maybe a lesson about fate and the such here and there.")
            msg ("Foc: But a meaning that's deeper than that?")
            msg ("Foc: There might be one if you search hard enough but it may not be the answer you're looking for.")
            msg ("Foc: Nevertheless it is the reason why you, the player is reading this very text.")
            SetForegroundColour ("White")
            msg ("Foc: Your curiousity seems to push you to explore all the nooks and crannies of this game ")
            msg ("Foc: Are you searching for something?")
            AddPageLink (why did you make this, man, "I have another question.")
          </script>
        </object>
      </object>
      <object name="Look around">
        <inherit name="scripttext" />
      </object>
    </object>
  </object>
  <object name="loading screen">
    <inherit name="scripttext" />
    <script type="script">
      SetForegroundColour ("DarkGreen")
      SetFontSize (22)
      PrintCentered ("A game by Malphas")
      SetFontSize (12)
      PrintCentered ("")
      PrintCentered ("")
      PrintCentered ("")
      PrintCentered ("")
      PrintCentered ("")
      PrintCentered ("")
      OutputTextNoBr ("")
      PrintCentered ("")
      if (RandomChance(50)) {
        if (RandomChance(10)) {
          PrintCentered ("To the sun, the moon and everything inbetween:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To everyone who made me walk this road:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To the one who is playing this right now:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To the prince of ravens, flying along with the stars:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To whoever reads this message:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To everyone who helped me playtest this game:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To everyone who spread the word about this game:")
        }
        else if (RandomChance(10)) {
          PrintCentered ("To Abigail:")
        }
        else {
          PrintCentered ("To those that supported me and the game:")
        }
        if (RandomChance(10)) {
          PrintCentered ("Thanks a thousand!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Thank you.")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Thank you so much.")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Thanks a ton!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Thanks a million!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Many thanks.")
        }
        else if (RandomChance(10)) {
          PrintCentered ("From the bottom of my heart, thank you!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("I really can't thank you enough!")
        }
        else {
          PrintCentered ("Thank you, from the bottom of my heart!")
        }
      }
      else {
        if (RandomChance(10)) {
          PrintCentered ("I hope you'll enjoy the game!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Have a great day or night!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Good luck on your date!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("You got a date waiting for you, godspeed!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("I might have put a bit too much effort in this one random text screen.")
        }
        else if (RandomChance(10)) {
          PrintCentered ("There are a few eastereggs that you can activate by typing things other than start...")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Welcome to my little game, I hope you enjoy it!")
        }
        else if (RandomChance(10)) {
          PrintCentered ("Hey, glad you found your way to this game!")
        }
        else {
          if (RandomChance(1)) {
            if (RandomChance(1)) {
              if (RandomChance(1)) {
                if (RandomChance(1)) {
                  PrintCentered ("Seeing this message is extremely rare, congrats!")
                }
                else {
                  PrintCentered ("Seeing this message is pretty rare, congrats!")
                }
              }
              else {
                PrintCentered ("Seeing this message is very rare, congrats!")
              }
            }
          }
          else {
            if (RandomChance(20)) {
              PrintCentered ("Now proudly presenting version 0.00000000000001 Alpha")
            }
            else if (RandomChance(20)) {
              PrintCentered ("Good luck with your date!")
            }
            else if (RandomChance(20)) {
              PrintCentered ("Something something, what? Not all these random messages are fantastic.")
            }
            else if (RandomChance(20)) {
              PrintCentered ("They should really fire me, oh wait...")
            }
            else if (RandomChance(20)) {
              PrintCentered ("Best of luck!")
            }
            else {
              PrintCentered ("There's a good chance you'll see this message the most out of any, I know, perfect coding.")
            }
          }
        }
      }
      PrintCentered ("")
      PrintCentered ("For now there aren't any eastereggs in the textbalk, those will be added eventually")
      PrintCentered ("")
      PrintCentered ("Type start to move on.")
      SetForegroundColour ("Purple")
      GetInput() {
        if (result = "start") {
          MovePlayer (Titlescreen)
        }
        else if (result = "cheats") {
          PrintCentered ("Fine, cheats are now accesible from the start menu.")
          SetFlagOn ("cheatson")
          GetInput() {
            if (result = "start") {
              MovePlayer (Titlescreen)
            }
          }
        }
        else {
        }
      }
    </script>
    <object name="Titlescreen">
      <inherit name="scripttext" />
      <script type="script">
        AddPageLink (Titlescreen, Page1, "Start the game")
        if (GetBoolean(game, "cheatson")) {
          AddPageLink (Titlescreen, cheats, "Cheats")
        }
        AddPageLink (Titlescreen, loading screen, "Go back.")
      </script>
      <object name="Page1">
        <inherit name="scripttext" />
        <description type="string"></description>
        <options type="stringdictionary" />
        <script type="script">
          SetFontSize (12)
          SetForegroundColour ("OrangeRed")
          msg ("Abigail: Heya, I just called to ask you where we should meet?")
          msg ("Abigail: We agreed to go on a dinnerdate but we never talked about what we would pick.")
          AddPageLink (Page1, Burgers, "Do burgers sound good?")
          AddPageLink (Page1, Chinese, "Hmm, I could go for some Chinese food.")
          AddPageLink (Page1, cafe, "Hmm, I think I'd like to go to the cafe.")
          SetFlagOff ("burgers")
          SetFlagOff ("cafe")
          SetFlagOff ("chinese")
          if (GetBoolean(game, "shootknowledge")) {
            AddPageLink (Page1, other date, "You know, I changed my mind, can't we just go for a walk in the park or something like that?")
          }
          else if (GetBoolean(game, "geeseknowledge")) {
            AddPageLink (Page1, other date, "You know, I changed my mind, can't we just go for a walk in the park or something like that?")
          }
          else if (GetBoolean(game, "gasknowledge")) {
            AddPageLink (Page1, other date, "You know, I changed my mind, can't we just go for a walk in the park or something like that?")
          }
          else if (GetBoolean(game, "allergyknowledge")) {
            AddPageLink (Page1, other date, "You know, I changed my mind, can't we just go for a walk in the park or something like that?")
          }
          if (GetBoolean(game, "geeseknowledge")) {
            if (GetBoolean(game, "drownknowledge")) {
              if (GetBoolean(game, "gasknowledge")) {
                AddPageLink (Page1, breakup, "Listen Abigail, i think it would be better if we didn't go on this date, not on any date to be precise.")
              }
            }
          }
          if (GetBoolean(game, "carknowledge")) {
            AddPageLink (Page1, Call police, "Hang on, I just need to make another quick call and then I'll be right back.")
          }
        </script>
        <object name="Burgers">
          <inherit name="scripttext" />
          <description type="string"></description>
          <script type="script">
            msg ("Abigail: Burgers sure sound good, see you there!")
            SetForegroundColour ("Purple")
            msg ("You arrive a tad late, already has grabbed herself a seat and waves at you when she sees you.")
            SetForegroundColour ("OrangeRed")
            msg ("Heya! Almost was scared you wouldn't show up.")
            AddPageLink (Burgers, Traffic, "Sorry, the traffic was quite bad actually and I got stuck for a while.")
            AddPageLink (Burgers, showup burgers, "I will always show up for burgers.")
            SetFlagOn ("burgers")
          </script>
          <object name="Traffic">
            <inherit name="scripttext" />
            <description type="string"></description>
            <options type="stringdictionary" />
            <script type="script">
              msg ("Abigail: Now that you mention it, I think I heard something about it on the radio, they said some ghostrider caused  the traffic jam.")
              msg ("Abigail: But anyway, we didn't meet to talk about traffic jams right?  Let's see, I think I am going to go with a juicy cheesburger, what do you want?")
              AddPageLink (Traffic, veggie burger, "I could go for a veggie burger!")
              AddPageLink (Traffic, cheeseburger, "Hmm, that juicy cheesburger sounds really good!")
              AddPageLink (Traffic, fish burger, "I think I'll pick a fish burger.")
              AddPageLink (Traffic, beef burger, "A beef burger sounds good.")
            </script>
            <object name="beef burger">
              <inherit name="scripttext" />
              <script type="script">
                SetForegroundColour ("Purple")
                msg ("Your meal finally arrives, you and Abigail both eat like you haven't eaten in weeks.")
                msg ("After having eaten half of her cheeseburger Abigail stops for a moment. She puts her burger back in the little plastic box it was in and looks down at the floor before looking back to you again.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: You know, my brother would absolutely love it here. He loved to be surrounded by people in places full of good ambience and like any kid he loved burgers.")
                AddPageLink (beef burger, remain silent, "*Remain silent*")
                AddPageLink (beef burger, ask brother, "What happend to your  brother?")
              </script>
              <object name="ask brother">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Abigail looks at you and tries to smile yet you can see the sadness in her eyes.")
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: My brother passed away when he was eleven years old, it happend quite a while ago but I still miss him so much.")
                  msg ("Abigail: I really hope he is happy wherever he is right now.")
                  msg ("Abigail: But enough sadness, I don't want to ruin the ambience of the this place.")
                  msg ("Abigail: Oh, I forgot to ask, what do you actually do for a living?")
                  AddPageLink (ask brother, Writer, "I'm an aspiring writer looking for a golden opportunity.")
                  AddPageLink (ask brother, Unemployed, "I'm currently unemployed but I sure like to write!")
                  SetFlagOn ("brotherknowledge")
                </script>
                <object name="Unemployed">
                  <inherit name="scripttext" />
                  <script type="script">
                    msg ("Abigail: You like to write? That's pretty cool! ")
                    msg ("I used to write some bad poems when I was a bit younger, do you want to hear one?")
                    AddPageLink (Unemployed, Yes, "Sure, sounds fun!")
                    AddPageLink (Unemployed, No, "Honestly, I'd rather not.")
                    AddPageLink (Unemployed, Maybe, "Hmm, i'm not quite sure.")
                  </script>
                  <object name="Yes">
                    <inherit name="scripttext" />
                    <script type="script"><![CDATA[
                      msg ("Abigail:That's the spirit!")
                      msg ("Abigail:This one is perfect, it's from my edgy teenager time, this will be funny!")
                      msg ("Abigail: Useless faces<br/>Scattered and lost<br/>buried by time.<br/><br/>Eye of the storm<br/>Disintegrating in the night<br/>Blood is wiped away.<br/><br/>Reflected desire.<br/><br/>Deeply cracked glass.<br/>Sharply cutting shards.<br/><br/>Closed eyes,<br/>the taste of rust.<br/>Sweet, blissful ignorance.<br/><br/>Silver moon.<br/>Gorgeous shining stars.<br/>Bathed in light.<br/><br/>Open eyes<br/>No more dreams,<br/>only cold hands.<br/><br/>Golden sun.<br/>Gracefull shining lie.<br/>Only chilly heat.<br/><br/>Blinded eyes.<br/><br/>Not ready for the truth.<br/>Hollow lies are warmer.<br/><br/>Eye of despair.<br/>Running away.<br/>Letting go.")
                      msg ("Abigail:What did you think? I find it pretty funny to look back at that time in my life.")
                      AddPageLink (Yes, Shooting, "It was-")
                    ]]></script>
                  </object>
                  <object name="No">
                    <inherit name="scripttext" />
                    <options type="stringdictionary" />
                    <script type="script">
                      msg ("Abigail: That's alright, would you like to share some of your writing with me then?")
                      AddPageLink (No, Shooting, "Sure, basically I write-")
                    </script>
                  </object>
                  <object name="Maybe">
                    <inherit name="scripttext" />
                    <script type="script"><![CDATA[
                      msg ("Abigail: Ah, come on! It'll be fun, I can guarantee it!")
                      msg ("Abigail:This one is perfect, it's from my edgy time, this will be funny!")
                      msg ("Abigail: Useless faces<br/>Scattered and lost<br/>buried by time.<br/><br/>Eye of the storm<br/>Disintegrating in the night<br/>Blood is wiped away.<br/><br/>Reflected desire<br/><br/>Deeply cracked glass<br/>Sharply cutting shards.<br/><br/>Closed eyes<br/>the taste of rust<br/>Sweet, blissful ignorance.<br/><br/>Silver moon<br/>Gorgeous shining stars<br/>Bathed in light.<br/><br/>Open eyes<br/>No more dreams<br/>only cold hands.<br/><br/>Golden sun<br/>Gracefull shining lie<br/>Only chilly heat.<br/><br/>Blinded eyes.<br/><br/>Not ready for the truth.<br/>Hollow lies are warmer.<br/><br/>Eye of despair<br/>Running away<br/>Letting go.")
                      msg ("Abigail:What did you think? I find it pretty funny to look back at that time in my life.")
                      AddPageLink (Maybe, Shooting, "It was-")
                    ]]></script>
                    <object name="Shooting">
                      <inherit name="scripttext" />
                      <script type="script">
                        SetForegroundColour ("Purple")
                        msg ("Before you can finish your sentence you suddenly hear screaming in the distance.")
                        SetForegroundColour ("OrangeRed")
                        msg ("Abigail: What was that?")
                        AddPageLink (Shooting, concern, "It's probably not our concern.")
                        AddPageLink (Shooting, Sale, "Maybe there is just a really good sale going on somewhere?")
                        if (GetBoolean(game, "shootknowledge")) {
                          AddPageLink (Shooting, shootingsaved, "This is important, duck now.")
                        }
                      </script>
                      <object name="concern">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>convincing</key>
                            <value></value>
                          </item>
                        </options>
                        <script type="script">
                          msg ("Abigail: Yeah, you're probably right, it's probably not even a big deal anyway.")
                          AddPageLink (concern, burger death1, "Yeah-")
                        </script>
                        <object name="burger death1">
                          <inherit name="scripttext" />
                          <script type="script"><![CDATA[
                            SetForegroundColour ("Purple")
                            msg ("Now the screaming is also paired with hellish sounds, just great.")
                            msg ("You look at Abigail and tell her to hide under the table.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: I...")
                            SetForegroundColour ("Purple")
                            msg ("Abigail seems to be frozen, on her face you can clearly see a mixture of fear and confusion.")
                            msg ("It takes you a moment to notice the steadily increasing red stains on Abigail's clothes.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: I've been shot?")
                            SetForegroundColour ("Purple")
                            msg ("Abigail falls of her chair, you crawl towards her and try to call an ambulance.")
                            msg ("With trembling hands you type the emergency-number and beg for help.")
                            msg ("Everything seems to fade away, even the continuous  barage of gunshots, all you can hear is the sound of Abigail's breathing as it gets harder and harder for her to live.")
                            msg ("You've been here for what feels for aeons but in all reality was probably 5 minutes when an ambulance finally arives.")
                            msg ("A young man with eyes that have grown old from all the things they saw places Abigail's still body on a stretcher and rushes off with it to the ambulance.")
                            msg ("The kind man throws some words at you, he tells you that everything will be just fine but you know that he is lying.<br/>You have see her suffering for what seemed like an eternity and a second at the same time.")
                            msg ("You've gotten no clue what caused all those gunshots that inadvertently killed her. Some robbery in a neighbouring store, or a gang war, or something else.")
                            msg ("But sadly you do know what the aftermath of it all is .")
                            SetFontSize (29)
                            msg ("Game over")
                            SetFontSize (13)
                            msg ("Your date surely didn't go as planned.")
                            SetFlagOn ("shootknowledge")
                            SetFontSize (11)
                            AddPageLink (burger death1, Page1, "Retry")
                            SetForegroundColour ("OrangeRed")
                          ]]></script>
                        </object>
                      </object>
                      <object name="Sale">
                        <inherit name="scripttext" />
                        <script type="script">
                          msg ("Abigail: Let's just hope it's just that.")
                          AddPageLink (Sale, burger death1, "Yeah-")
                        </script>
                      </object>
                      <object name="shootingsaved">
                        <inherit name="scripttext" />
                        <script type="script">
                          if (GetBoolean(game, "burgers")) {
                            SetForegroundColour ("Purple")
                            msg ("Abigail looks sceptical at you but decides to follow your instructions, right as she does so a bullet flies where she would have been if you didn't warn her.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail:Alright that is crazy, how did you know that bullet would hit me?")
                            AddPageLink (shootingsaved, Groundhog, "I'm in some sort of groundhog day scenario , a groundhog date if you will.")
                            AddPageLink (shootingsaved, Psychic, "I'm psychic, I can predict such things.")
                            AddPageLink (shootingsaved, Game, "You're part of a game, I've seen you get shot before.")
                          }
                          else if (GetBoolean(game, "chinese")) {
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: Hmm, you mean like something that triggered an alergic reaction of some sorts?")
                            msg ("Abigail: I suppose that makes sense, I am allergic to quite a few things.")
                            msg ("Abigail: When I was a kid I once ate a few peanuts while I was watching Dumbo, I felt my throat swell and I thought I was becoming a little elephant, just like Dumbo.")
                            msg ("Abigail: I ran to my parents and said:\"Look mommy, look daddy! I can fly!\" and then I started using my hands to flap my ears around like Dumbo.")
                            msg ("Abigail: At that point I was pretty swollen so it was a good thing my parents saw me, we went to the hospital as fast as we could and the kind doctors really helped me out.")
                            msg ("Abigail: When I finally was allowed to go home from the hospital my parents gave me a Dumbo plushie to always remember the story.")
                            msg ("Abigail: And I can say that I still remember it like it was yesterday, same for my mom, she keeps joking about it to this day.")
                            msg ("Abigail lets out a huge laugh as she looks at you.")
                            SetForegroundColour ("Purple")
                            msg ("Suddenly she stops, you see a look of worry in her eyes.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: Oh sorry, I'm ranting again aren't I?")
                            msg ("Abigail: I'm sorry, it's just that when I start talking it's pretty hard for me to stop, what were we talking about again?")
                            msg ("Abigail: Oh yeah, the supposed allergy I would have if I ate that Peking duck.")
                            msg ("Abigail: How would you even know? I mean, I checked the ingredients on the list and as far as I'm aware I'm not allergic to any of those.")
                            msg ("Abigail: So let's say that there's something in this dish that I'm really allergic to but I don't know it yet, how would you know that?")
                            AddPageLink (shootingsaved, Groundhog, "I'm in some sort of groundhog day scenario , a groundhog date if you will.")
                            AddPageLink (shootingsaved, Psychic, "I'm psychic, I can predict such things.")
                            AddPageLink (shootingsaved, Game, "You're part of a game, I've seen you get shot before.")
                            SetFlagOn ("Dumboknowledge")
                          }
                          else if (GetBoolean(game, "cafe")) {
                            SetForegroundColour ("Purple")
                            msg ("Abigail looks at you with a strange look in her eyes, it might be disbelief.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: Kind of strange to tell me that when I ask you if you know of any jokes but sure, if you insist.")
                            SetForegroundColour ("Purple")
                            msg ("Abigail and you go to another table that's still not taken and put all your stuff there.")
                            msg ("Just when you're about to sit on your chair you hear someone scream, as you look near the table where Abigail and you used to sit you can see someone fall with a plate in their hands.")
                            msg ("The plate flies in the air, with it the ham sandwich that was put on top of it.")
                            msg ("From your new spot you can have a better look at the whole thing.")
                            msg ("A great white shark notices the sandwich and takes interest in it.")
                            msg ("While the sandwich is still in the air the shark lunges itself at it, the shark manages to catch the sandwich and lands with a resounding sound on the mahony table, crushing it under it's weight.")
                            msg ("You can see the terrified look on the face of the person who launced their sandwich in the air, luckily the baristas quickly come running towards the shark with special equipment and manage to get the situation back under control rather quickly.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: Wait, that was the table we were using just a few minutes ago. How could you have possibly seen that coming?")
                            AddPageLink (shootingsaved, Groundhog, "I'm in some sort of groundhog day scenario , a groundhog date if you will.")
                            AddPageLink (shootingsaved, Psychic, "I'm psychic, I can predict such things.")
                            AddPageLink (shootingsaved, Game, "You're part of a game, I've seen you get crushed by a shark before.")
                          }
                          if (GetBoolean(game, "liarknowledge")) {
                            AddPageLink (shootingsaved, untold story, "I need a way for a past version of you to trust me. (This is not fully written down, it will just take you to the story for now. You'll need to do this in all three restaurants to get the full story.)")
                          }
                        </script>
                        <object name="Groundhog">
                          <inherit name="scripttext" />
                          <script type="script">
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail, so you mean to tell me that you've already been on this specific date before?")
                            msg ("Abigail: I mean, I'm really thankful for you saving my life! ")
                            msg ("Abigail:But you got to admit that this really sounds contrived.")
                            msg ("Abigail:I mean, this whole thing seems pretty weird to me. Can you atleast offer me some proof?")
                            AddPageLink (Groundhog, noidea, "I've got no clue what to tell you honestly.")
                            AddPageLink (Groundhog, numbers1, "Alright, pick any number you'd like.")
                          </script>
                          <object name="gasexplosion">
                            <inherit name="scripttext" />
                            <script type="script">
                              SetForegroundColour ("Purple")
                              msg ("Suddenly a inmense sensation of pain overwhelms you, the only thing you can see is a glimpse of pure white and an eternity of black.")
                              msg ("When you awaken you find yourself surrounded by doctors, they tell you that with the force of sheer luck a stray bullet managed to cause a gas leak.")
                              msg ("The gas explosion that followed was quite severe, you were in a coma and had to have your wounds cleaned with some surgical procedures.")
                              msg ("After a week you got out of your coma, Abigail however didn't have such luck.")
                              msg ("The doctors tell you that she atleast went out pretty quickly, almost like dying in your sleep but with more explosions.")
                              SetFlagOn ("gasknowledge")
                              SetFontSize (29)
                              msg ("Game over")
                              SetFontSize (13)
                              msg ("Your date surely didn't go as planned.")
                              SetFontSize (11)
                              AddPageLink (gasexplosion, Page1, "Retry")
                              if (GetBoolean(game, "burgerdeathcheck")) {
                                AddPageLink (takedeath, shootingsaved, "Continue from the first death you prevented in the burger place.")
                              }
                              SetForegroundColour ("OrangeRed")
                            </script>
                          </object>
                          <object name="numbers1">
                            <inherit name="scripttext" />
                            <script type="script">
                              msg ("Abigail: This sounds interesting, alright, I've gotten my number!")
                              AddPageLink (numbers1, number badoption1, "It's 5.")
                              if (GetBoolean(game, "numberknowledge")) {
                                AddPageLink (numbers1, correct number, "It's -72,8947, can we move on now?")
