            <object name="untold story">
              <inherit name="scripttext" />
              <script type="script">
                RemovePageLink (untold story, death2res3)
                RemovePageLink (untold story, Geeseatack)
                RemovePageLink (untold story, gasexplosion)
                if (GetBoolean(game, "cafe")) {
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: Once upon a time there was a world, but the world doesn't concern this story.")
                  msg ("Abigail: For the story we need to look high in the inkfilled sea some like to call the night.")
                  msg ("Abigail: floating in that sea is the majestic moon herself who guides us through the night and turns gold to silver, confidence to elegance.")
                  msg ("")
                  msg ("Abigail: That's the end of this part of the story, like I said you are the only person I've ever told this to so I hope you'll make good use out of it.")
                  AddPageLink (untold story, death2res3, "I sure will! ")
                  SetFlagOn ("startknowledge")
                }
                else if (GetBoolean(game, "chinese")) {
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: The majestic moon is far from alone though, in the dark she is kept company by a thousand stars tha shine almost as bright as herself and one special raven with a silver crown.")
                  msg ("Abigail: The little raven was a prince, his parents ruled their raven-kingdom on a nice looking kind throne carved out from the wood of an oak.")
                  msg ("Abigail: The prince would one day inherit the throne but he still felt sad somehow. That was untill he noticed a silver light reflecting from his crown as he was between waking and dreams.")
                  msg ("")
                  AddPageLink (untold story, Geeseatack, "I sure will! ")
                  SetFlagOn ("middleknowledge")
                }
                else if (GetBoolean(game, "burgers")) {
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: The raven looked up and noticed the shining moon and from that day on he never left her side.")
                  msg ("Abigail: They talk for hours, about everything and nothing. When the night would end in one part of the world the raven would follow the moon to another.")
                  msg ("Abigail: To this day you can still clearly see them when they come visit you.")
                  msg ("Abigail: The end.")
                  msg ("")
                  AddPageLink (untold story, gasexplosion, "I sure will! ")
                  SetFlagOn ("endknowledge")
                }
              </script>
            </object>
            <object name="tell the untold story">
              <inherit name="scripttext" />
              <script type="script">
                SetForegroundColour ("Purple")
                msg ("You tell Abigail her untold story that now actually is told if you think about it.")
                msg ("Throughout the entire story Abigail stayed extremely silent.")
                msg ("When you are finished you can hear her soft sobbing through the speaker of your phone.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: Sorry, I am a bit overwhelmed, just give me a quick minute to calm myself down.")
                SetForegroundColour ("Purple")
                msg ("After five minutes you begin to hear commotion on the other side of the phone call again.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: That story, I've never told it to anyone, I haven't even written that down, I just kept repeating it over and over in my mind.")
                msg ("Abigail: I wrote it for my brother but he never came home since then. You see, a truck and...")
                SetForegroundColour ("Purple")
                msg ("Abigail begins to sob again, this time louder.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: I'm sorry, I can't say it, eve after all those years I just can't.")
                msg ("Abigail: Anyway, how did you even know that story, like I said earlier, I haven't shared it with anyone else and never written it down, it exist solely in my mind and I guess yours aswell now.")
                SetForegroundColour ("Purple")
                msg ("You tell Abigail about the many dates you've had together and the groundhog-esque scenario you are trapped in.")
                msg ("About a few of the different deaths she's suffered but try to not make your descriptions too gruesome.")
                msg ("About all the experiences the both of you shared, some better than others.")
                msg ("About the restaurants you've been to together.")
                msg ("That you tried to warn her to not go to one of those restaurants but that she didn't trust you.")
                msg ("That a version of her from the future, or maybe a parallel timeline that diverted in a different dirrection, helped you and told you the story, broken down in three parts, one for each restaurant.")
                msg ("Abigail coughs for a second.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: Hold on, this is a bit much, can we meet somewhere?")
                msg ("Abigail: I got the perfect place in mind, it's a forest near the village where all three of those restaurants you just mentioned are, as a kid i called it Kakariko forrest as a refference to a game I liked to play.")
                msg ("Abigail: If I die on you again just mention Kakariko forrest, that should pique past me's interest.")
                SetFlagOn ("kakknowledge")
                msg ("Here Abigail dies once more, I still got to implement the death into the game.")
                AddPageLink (tell the untold story, Page1, "Retry")
              </script>
            </object>
            <object name="Kakarikowoods">
              <inherit name="scripttext" />
              <description type="string"></description>
              <script type="script"><![CDATA[
                SetForegroundColour ("Purple")
                msg ("Abigail gasps for a second.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: You mean the Kakariko woods? The same as I am thinking of right now?<br/>")
                msg ("Abigail: You know what, let's both go to Kakariko woods, if we are at the same spot then I'll know for sure.")
                msg ("Abigail: While you're at it, try taking some food you got laying around your house with you, we can make a picknick date out of it!")
                SetForegroundColour ("Purple")
                msg ("Abigail giggles.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: See you there! Or so I hope.")
                SetForegroundColour ("Purple")
                msg ("Abigail hangs up the phone and you immediatly start seeking every nook and cranny of your house for something that would make for good food on a picknick.")
                msg ("When you're done you drive to the Kakariko woods, hoping that things will be different there.")
                msg ("The woods are located on top of a hill, from where you are now standing you can see most of the village where all your past dates took place.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: Oh hey, I see you already found a place with a good view, nice work!")
                SetForegroundColour ("Purple")
                msg ("Abigail gives you a playful pat on the back as she places her picknick blanket down on the ground.")
                msg ("Abigail and you start placing down all the food on the blanket, when you're both finished you sit down on it.")
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: You know, this is really a beautiful view of the village we've got from here...")
                msg ("Abigail: But how did you know about this place? I always gave it that name when I was a kid but I never told anyone.")
                msg ("Abigail: What's all of this about?")
                AddPageLink (Kakarikowoods, kakgroundhog, "I'm in some sort of groundhog day scenario , a groundhog date if you will.")
                AddPageLink (Kakarikowoods, kakpsychic, "I'm psychic, I can predict things like kakariko woods.")
                AddPageLink (Kakarikowoods, kakgame, "You're part of a game, I've been on many dates with you in other playthroughs of this game.")
                SetFlagOn ("kakariko")
              ]]></script>
              <object name="kakpsychic">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Abigail watches you with a sceptic look in her eyes.")
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: You know, when you told me that story over the phone I might have believed you but now I somehow can tell you're not telling the truth if that makes sense.")
                  msg ("Abigail: So what is this all really about?")
                  AddPageLink (kakpsychic, kakgroundhog, "I'm in some sort of groundhog day scenario , a groundhog date if you will.")
                  AddPageLink (kakpsychic, kakpsychic, "I'm psychic, I can predict things like the kakariko woods.")
                  AddPageLink (kakpsychic, kakgame, "You're part of a game, I've been on many dates with you in other playthroughs of this game.")
                </script>
              </object>
              <object name="kakgame">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Abigail shifts her position for a moment and gives you an honest smile.")
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: That actually makes quite a bit of sense, It wouldn't be too impossible to make a game and let every character in it believe that they are real, in fact that's most games isn't it?")
                  msg ("Abigail: Most characters never break forth walls, nowadays it seems to be more and more popular but most game designers try to not make the experience shatter your immersion too much.")
                  msg ("Abigail: So, are you the one who is playing this game?")
                  AddPageLink (kakgame, itsme, "Yup, I am the one who is playing it.")
                  AddPageLink (kakgame, whoisplayiing, "I'm playing this game, although someone else might be playing with my character in another game.")
                  AddPageLink (kakgame, talkthroughcharacter, "I am, however I can't say whatever I want, I can only speak with you through these clickable links that have a preview of what I'm going to say. So in a sense I guess I'm not really playing this game, not the me you know anyway.")
                </script>
                <object name="itsme">
                  <inherit name="scripttext" />
                  <script type="script">
                    SetForegroundColour ("OrangeRed")
                    msg ("Abigail: It's pretty strange to be told that you're in a game but I'm glad you are the player, you seem more than capable enough to do what you need to do.")
                    SetForegroundColour ("Purple")
                    msg ("Abigail pauses for a moment and then continues.")
                    SetForegroundColour ("OrangeRed")
                    msg ("Abigail: Now that I think about it, what is it you've got to do in this game?")
                    AddPageLink (itsme, Me no know, "I actually have no idea.")
                  </script>
                  <object name="Me no know">
                    <inherit name="scripttext" />
                    <script type="script">
                      SetForegroundColour ("OrangeRed")
                      msg ("Abigail: That's fine, we can figure your goal out together.")
                      SetForegroundColour ("Purple")
                      msg ("Abigail scratches her chin and continues.")
                      SetForegroundColour ("OrangeRed")
                      msg ("Abigail: Let's see, first of, how does this game look to you?")
                      AddPageLink (Me no know, clickable thinks, "I just see text on the screen, your text is a different color from the narator's. I also get a few clickable links to selct what I want to say.")
                    </script>
                    <object name="clickable thinks">
                      <inherit name="scripttext" />
                      <script type="script">
                        SetForegroundColour ("OrangeRed")
                        msg ("Abigail: Ah I see, so you can't see the absolutely stunning view from our picknickspot?")
                        AddPageLink (clickable thinks, yup, "Yup, the best thing I can get is a description of it if the game feels like giving me one.")
                      </script>
                      <object name="yup">
                        <inherit name="scripttext" />
                        <script type="script">
                          SetForegroundColour ("OrangeRed")
                          msg ("Abigail: Hmm, let's try looking at the scenery, maybe the game will give you a description then.")
                          AddPageLink (yup, scenery forrest, "Sure, I'm looking forward to watch it together!")
                        </script>
                        <object name="scenery forrest">
                          <inherit name="scripttext" />
                          <script type="script">
                            SetForegroundColour ("Purple")
                            msg ("From the spot you picked on the hill you have a gorgeous view of the village where most of your dates with Abigail took place.")
                            msg ("It's pretty calm in the village, here and there you might catch a rare glimpse of a car or a pedestrian but other than that the streets are completly empty.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: This view is absolutely fantastic isn't it?")
                            msg ("Abigail: When my parents used to take walks with me and my brother in this forrest I knew that I just had to keep coming back here.")
                            msg ("Abigail: And I did! Many times actually. I like to come here whenever I have some spare time or when I really need to get some time away from things.")
                            msg ("Abigail: The sundown here is absolutely beautiful, maybe we'll be able to share that moment today.")
                            msg ("Abigail: Yeah, I'd like that.")
                            SetForegroundColour ("Purple")
                            msg ("As Abigail and you enjoy eachother's company for a while while looking off into the distance suddenly you hear police sirens.")
                            msg ("The police sirens are coming from near the mall, where the burger restaurant is located.")
                            msg ("The same restaurant where Abigail got shot...")
                            msg ("You point at the mall and tell Abigail about the events that took place there.")
                            msg ("Abigail gasps for a moment.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: Sorry, I know that you relived many scenarios like the one you just mentioned and that I have no memory of those scenarios but it will still take some getting used to the idea.")
                            SetForegroundColour ("Purple")
                            msg ("Suddenly you can see a red Sedan, racing at full speed and smashing against the entrance of the mall.")
                            msg ("The burger restaurant explodes, taking a sizeable chunk of the mall with it. However the Sudan escapes without a scratch.")
                            msg ("You both watch the Sedan as it continues to drive closer and closer to the cafe.")
                            msg ("When the car reaches the cafe it rams a garbage container that falls over, drives up on a ramp and crashes into the weak walls, coming back the other way and driving away like nothing happened.")
                            if (not GetBoolean(game, "policechinese")) {
                              msg ("In it's final act of destruction the car speeds into the doors of the chinese restaurant.")
                              msg ("The car backs away just as a swarm of geese break the doors of the restaurant wide open.")
                              msg ("The geese leave the restaurant with almost everyone in the restaurant kidnapped by them.")
                              msg ("When the geese eventually dissapear the village begins to turn calm once more, the whole ordeal seems like it finally ended.")
                            }
                            else if (GetBoolean(game, "policechinese")) {
                              msg ("You can see a swarm of geese heading straigth for the chinese restaurant.")
                              msg ("They break the doors wide open.")
                              msg ("The geese leave the restaurant with almost everyone in the restaurant kidnapped by them.")
                              msg ("When the geese eventually dissapear the village begins to turn calm once more, the whole ordeal seems like it finally ended.")
                            }
                            SetForegroundColour ("OrangeRed")
                            msg ("Abigail: Has it... Has it ended?")
                            AddPageLink (scenery forrest, over, "Yes, it's finally all over.")
                            SetFlagOn ("carknowledge")
                            if (GetBoolean(game, "kakdeath1knowledge")) {
                              AddPageLink (scenery forrest, kakdeath1warn, "This will warn Abigail she is about to die again, I still need to put the unique death in.")
                            }
                          </script>
                          <object name="over">
                            <inherit name="scripttext" />
                            <script type="script">
                              SetForegroundColour ("OrangeRed")
                              msg ("Abigail: That... That was quite the show wasn't it?")
                              msg ("Abigail: You've been through all that to have a succesful date with me?")
                              msg ("Abigail: You are really dedicated, I'll give you that!")
                              SetForegroundColour ("Purple")
                              msg ("Abigail gives you a cute little smile.")
                              msg ("The stars are absolutely marvelous, as you and Abigail gaze upon the skies you catch a glimpse of a falling star.")
                              SetForegroundColour ("OrangeRed")
                              msg ("Abigail: Oh, did you see that falling star? Let's make a wish!")
                              SetForegroundColour ("Purple")
                              msg ("Abigail closes her eyes, a soft smile appears on her face.")
                              msg ("A moment later she looks at you again, she places her hand on yours.")
                              SetForegroundColour ("OrangeRed")
                              msg ("Abigail: What did you wish for?")
                              AddPageLink (over, all I could wish for is here, "I didn't make a wish, everything I could ever need is right here, in this moment here with you.")
                              AddPageLink (over, I can no say, "I can't tell you my wish right? Isn't that how falling star wishes work?")
                              AddPageLink (over, I wished that, "I wished that...")
                              if (GetBoolean(game, "rockknowledge")) {
                                AddPageLink (over, kakdeath1warn, "Actually, you might want to sit somewhere else for a moment.")
                              }
                            </script>
                            <object name="all I could wish for is here">
                              <inherit name="scripttext" />
                              <script type="script">
                                SetForegroundColour ("Purple")
                                msg ("Abigail chuckles and looks you in your eyes.")
                                SetForegroundColour ("OrangeRed")
                                msg ("Wow, you sure know what to say don't you?")
                                msg ("If I'm being honest I'm also really enjoying this moment, it feels like I could sit here for an century and still be as happy as I am right now.")
                                SetForegroundColour ("Purple")
                                msg ("Abigail diverts her look from your eyes from a moment and continues watching the star-filled night.")
                                msg ("A gasp of amazement escapes her mouth.")
                                SetForegroundColour ("OrangeRed")
                                msg ("Abigail: You really need to see this, it's absolutely stunning!")
                                SetForegroundColour ("Purple")
                                msg ("The sky now is completly filled with falling stars, you've never seen so many falling stars in your entire life, let alone all together.")
                                msg ("However, one point seems to be getting bigger and bigger, it doesn't seem to be a star as it's not sending out any light.")
                                msg ("You and Abigail watch in absolute terror as the thing only starts to get closer, becoming larger, in an alarming rate.")
                                msg ("Before you can move away a meteorite smashes Abigail like a newspaper would smash a fly.")
                                SetFontSize (29)
                                msg ("Game over")
                                SetFontSize (13)
                                msg ("Your date surely didn't go as planned.")
                                SetFlagOn ("rockknowledge")
                                SetFontSize (11)
                                AddPageLink (all I could wish for is here, Page1, "Retry")
