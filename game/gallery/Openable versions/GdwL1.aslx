                            <object name="correct number">
                              <inherit name="scripttext" />
                              <script type="script">
                                SetForegroundColour ("Purple")
                                msg ("Abigail looks at you in utter shock and disbelief.")
                                SetForegroundColour ("OrangeRed")
                                msg ("Abigal: How...")
                                msg ("Abigail: How did you know that?")
                                msg ("Abigail: I mean you told me how but it's still pretty hard to get my brain to accept it.")
                                msg ("Abigail: I feel like when I'm going to admit I believe you there is going to come an entire camera crew out of nowhere and I'll be made fun of in some bad tv show. But let's say I am starting to believe you a little bit so we won't have the camera crew barge in on us.")
                                msg ("Abigail: So what is this all about?")
