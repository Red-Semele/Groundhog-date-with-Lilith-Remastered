                              </script>
                              <object name="help">
                                <inherit name="scripttext" />
                                <script type="script">
                                  msg ("Abigail: And I couldn't be more thankful for that, without you I would be dead. We've defeated death itself, take that death.")
                                  SetForegroundColour ("Purple")
                                  msg ("Abigail stands up and does a silly dance while looking up at the sky.")
                                  AddPageLink (help, takedeath, "Take that death!")
                                  AddPageLink (help, wedidit, "We did it!")
                                  AddPageLink (help, dontanger, "Don't jump the shark, that's just asking for trouble!")
                                  if (GetBoolean(game, "burgers")) {
                                    if (GetBoolean(game, "gasknowledge")) {
                                      AddPageLink (help, stilldying, "Actually you are still dying, this time to a gas explosion.")
                                    }
                                  }
                                  else if (GetBoolean(game, "chinese")) {
                                    if (GetBoolean(game, "geeseknowledge")) {
                                      AddPageLink (help, stilldying, "Actually you are still dying, this time to a swarm of geese.")
                                    }
                                  }
                                  else if (GetBoolean(game, "cafe")) {
                                    if (GetBoolean(game, "drownknowledge")) {
                                      AddPageLink (help, stilldying, "Actually you are still dying, this time it'll be drowning.")
                                    }
                                  }
                                </script>
                                <object name="takedeath">
                                  <inherit name="scripttext" />
                                  <script type="script"><![CDATA[
                                    SetForegroundColour ("Purple")
                                    msg ("Take that death! You and Abigail both do a silly dance while taunting death itself, maybe that isn't such a good idea?")
                                    if (GetBoolean(game, "burgers")) {
                                      SetForegroundColour ("OrangeRed")
                                      msg ("Abigail: Don't be ridicilous, we've won!")
                                      SetForegroundColour ("Purple")
                                      msg ("Suddenly a inmense sensation of pain overwhelms you, the only thing you can see is a glimpse of pure white and an eternity of black.")
                                      msg ("When you awaken you find yourself surrounded by doctors, they tell you that with the force of sheer luck a stray bullet managed to cause a gas leak.")
                                      msg ("The gas explosion that followed was quite severe, you were in a coma and had to have your wounds cleaned with some surgical procedures.")
                                      msg ("After a week you got out of your coma, Abigail however didn't have such luck.")
                                      msg ("The doctors tell you that she atleast went out pretty quickly, almost like dying in your sleep but with more explosions.")
                                      SetFlagOn ("gasknowledge")
                                      SetFontSize (29)
                                      msg ("Game over")
                                      SetFontSize (13)
                                      msg ("Your date surely didn't go as planned.")
                                    }
                                    else if (GetBoolean(game, "chinese")) {
                                      SetForegroundColour ("Purple")
                                      msg ("Suddenly you are interrupted in the midle of your sentence, you hear the faint sound of quacking.")
                                      msg ("The sound of the quacking steadily grows louder and louder untill it's all you can hear.")
                                      msg ("A true quackophony if you will.")
                                      msg ("Abigail looks over your shoulder with a frightend look in her eyes.")
                                      msg ("When you turn around you see a wave of angry geese breaking through the doors of the once cozy Chinese restaurant, the staff is running around in sheer panic.")
                                      msg ("Before you can make another sound everything turns to white, the white of pesky geese feathers.")
                                      msg ("The pain you are experiencing is too much and you fall unconscious.")
                                      msg ("When you wake up again all the cutomers and staff have dissapeared, including Abigail.")
                                      msg ("The room is completly filled to the brim with geese feathers, you begin to sneeze just thinking about that.")
                                      msg ("While you are sneezing you notice that someone put a sticky note on your hand.")
                                      msg ("It reads a as following: \"We took everyone and you won't be seeing them back, let this be a lesson on why you should not eat or serve geese or ducks as those are also part of our family. <br/>- Sincerely, the geese\"")
                                      SetFontSize (29)
                                      msg ("Game over")
                                      SetFontSize (13)
                                      msg ("Your date surely didn't go as planned.")
                                      SetFlagOn ("geeseknowledge")
                                      SetFontSize (11)
                                      SetForegroundColour ("OrangeRed")
                                    }
                                    else if (GetBoolean(game, "cafe")) {
                                      SetForegroundColour ("Purple")
                                      msg ("Suddenly you hear the sound of glass shattering acompagnied with loud cursing.")
                                      msg ("A red sudan crashes through the ceiling itself, a seemingly endless stream of water follows him.")
                                      msg ("The customers all run towards the door as fast as they can.")
                                      msg ("They push as hard as they can yet the door does not seem to budge.")
                                      msg ("It doesn't take too long before the water has filled the entire room, you soon begin losing consciousness.")
                                      msg ("When you awaken all the water around you is gone and the door is open, a young woman walks towards you when she sees that you've regained consciousness.")
                                      msg ("Apparently she and her partner were walking around when they heard the comotion in the restaurant, a really heavy container was blocking the only way in so they had to call the fire department.")
                                      msg ("Eventually they managed to move the container and free everyone from drowning to dead.")
                                      msg ("Or atleast almost everyone, some people died.  You guessed it, Abigail did as well.")
                                      SetFontSize (29)
                                      msg ("Game over")
                                      SetFontSize (13)
                                      msg ("Your date surely didn't go as planned.")
                                      SetFlagOn ("drownknowledge")
                                      SetFontSize (11)
                                      SetForegroundColour ("OrangeRed")
                                    }
                                    AddPageLink (takedeath, Page1, "Retry")
                                  ]]></script>
                                </object>
