                <object name="talkthroughcharacter">
                  <inherit name="scripttext" />
                  <script type="script">
                    AddPageLink (talkthroughcharacter, kakgame, "This path is still under construction. This link will take you back.")
                    SetForegroundColour ("Purple")
                    msg ("Abigail scratches her head as if she is trying to comprehend what you are saying.")
                    SetForegroundColour ("OrangeRed")
                    msg ("Abigail: So, what you are saying is that you can't fully express your true self, the self that is now playing this game?")
                    msg ("Abigail: Do you want to change that by having a good talk with me? I can't promiss that you'll be able to truly express yourself but it might help.")
                    AddPageLink (kakgame, itsme, "Yup, I am the one who is playing it.")
                    AddPageLink (kakgame, whoisplayiing, "I'm playing this game, although someone else might be playing with my character in another game.")
                    AddPageLink (kakgame, talkthroughcharacter, "I am, however I can't say whatever I want, I can only speak with you through these clickable links that have a preview of what I'm going to say. So in a sense I guess I'm not really playing this game, not the me you know anyway.")
                  </script>
                  <object name="Idliketotalk" />
                </object>
              </object>
              <object name="kakgroundhog">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Abigail watches you with a sceptic look in her eyes.")
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: You know, when you told me that story over the phone I might have believed you but now I somehow can tell you're not telling the truth if that makes sense.")
                  msg ("Abigail: So what is this all really about?")
                  AddPageLink (kakgroundhog, kakgroundhog, "I'm in some sort of groundhog day scenario , a groundhog date if you will.")
                  AddPageLink (kakgroundhog, kakpsychic, "I'm psychic, I can predict things like the kakariko woods.")
                  AddPageLink (kakgroundhog, kakgame, "You're part of a game, I've been on many dates with you in other playthroughs of this game.")
                </script>
              </object>
            </object>
          </object>
        </object>
        <object name="myhouse">
          <inherit name="scripttext" />
        </object>
        <object name="breakup">
          <inherit name="scripttext" />
          <script type="script">
            SetForegroundColour ("OrangeRed")
            msg ("Abigail: Oh okay, I'm sorry to hear that, let's still keep in touch anyway!")
            SetForegroundColour ("Purple")
            msg ("You agree with Abigail and still regulary text with her and sometimes even meet up with eachother.")
            msg ("However after a while the texts on both your and her side begin to be less and less frequent and you begin to only meet once in a month.")
            msg ("Once in a month changes to once in every season to once every year untill the meetings stops completely.")
            msg ("After a few years that you've forgotten about Abigail you decide to check her facebook page out.")
            msg ("She doesn't have that much pictures on her facebook account but the ones she has on there are beautifully shot.")
            msg ("On a few pictures she stands next a blonde man while they both have the widest smiles you have ever seen.")
            msg ("Apparently the man is called Ron, he is a semi-profesional photographer and his pictures surely show for it.")
            msg ("Abigail and Ron got two kids that look like they had not a thing to worry about.")
            msg ("Looking at the pictures you can't help but feel tears coming up, you tried your best to move on but apparently that didn't work all too well.")
            msg ("You know that this was probably the best thing to do, to keep Abigail safe and sound.")
            msg ("But something deep inside you keeps wondering if there wasn't a way where you two could be together while Abigail would be safe.")
            msg ("There must be a way right?")
            SetFontSize (29)
            msg ("Game over")
            SetFontSize (13)
            msg ("Your date surely didn't go as planned.")
            SetFlagOn ("Ronknowledge")
            SetFontSize (11)
            AddPageLink (breakup, Page1, "Retry")
          </script>
        </object>
        <object name="cafe">
          <inherit name="scripttext" />
          <script type="script">
            SetForegroundColour ("OrangeRed")
            msg ("Abigail: That sounds good to me! I'll meet you there.")
            SetForegroundColour ("Purple")
            msg ("You arrive a tad too early and find no space to park so you decide to park a few streets later and walk to the cafe.")
            msg ("The walls are made out of glass and function as aquariums that seem to go higher than you can see.")
            msg ("There are some holes in the special shaped aqaurium to allow for easy feeding of the fish and also makes the aquarium feel more alive, with colorful fish sometimes poking their head out of the aquarium as if they want to watch the cutomers, maybe you are the one in the glass cage and you just don't know it.")
            msg ("When you get there Abbigail is already sitting at a nice looking mahony table.")
            msg ("When she notices you she waves at you enthusiastically with a wide grin on her face.")
            SetForegroundColour ("OrangeRed")
            msg ("Abigail: Heya, glad you could make it! ")
            msg ("Abigail: This place has a really nice atmospere, those mahony tables and the aquariums are real eyecatchers don't you think?")
            msg ("Abigail: Anyway, let's go order our food and then we can talk some more.")
            SetForegroundColour ("Purple")
            msg ("You and Abigail walk towards the barista, as he glances up from his phone he greets you with a shy smile.")
            msg ("He looks quite young, if you'd have to guess you would say he is somewhere between 17 and 18 years old.")
            msg ("You get lost in the thoughts of how life was when you where still 17 untill Abigail gives you a playful nudge.")
            msg ("The barista looks at you and Abigail and asks:\"What can I get for you?\"")
            SetForegroundColour ("OrangeRed")
            msg ("Abigail: Hmm, I think I'm going for for the ham and cheese sandwich and a cafe cubano.")
            msg ("Abigail: What are you choosing? ")
            AddPageLink (cafe, sanwich of the day, "I am taking the sandwich of the day and an espresso.")
            AddPageLink (cafe, frap, "I'll take the beef sandwich and a frappuchino.")
            SetFlagOn ("cafe")
          </script>
          <object name="sanwich of the day">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("The barista smiles and says coming right up!")
              msg ("You and Abigail walk back to your table and take a seat.")
              SetForegroundColour ("OrangeRed")
              msg ("Abigail: So, in the mean time we can catch up a bit!")
              msg ("Abigail: I just came up with a good question to ask you!")
              msg ("Abigail: If you were only allowed to take three things with you on a desserted island, what would you bring along?")
              AddPageLink (sanwich of the day, pil, "I would take my computer, my phone and a pilates ring.")
              AddPageLink (sanwich of the day, swiss, "I would take a tent, a rope and a swiss pocket knife.")
            </script>
            <object name="pil">
              <inherit name="scripttext" />
              <script type="script">
                msg ("Abigail: Ah I see, with those things you'll be able to keep yourself from going insane by boredom, good thinking!")
                AddPageLink (pil, thnaks, "Thanks!")
              </script>
              <object name="thnaks">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Abigail chuckles and gives you a small smile.")
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail: Hey, I had to give it to you!")
                  msg ("Abigail: So, do you know any good jokes by any chance?")
                  AddPageLink (thnaks, noidont, "No, not really.")
                  if (GetBoolean(game, "sharkknowledge")) {
                    AddPageLink (thnaks, shootingsaved, "Hmm, this is not a joke, but I think it might be better if we go sit somewhere else for a while.")
                  }
                </script>
                <object name="noidont">
                  <inherit name="scripttext" />
                  <script type="script">
                    msg ("Abigail: Oh, that's a shame.")
                    msg ("Abigail: Hmm, maybe I could start out then, could give you some good ideas!")
                    msg ("Abigail: So a priest, a monk and a rabbit enter a bar.")
                    msg ("Abigail: Says the rabbit :\"Whoops, did you slip your tongue there Abigail?\"")
                    AddPageLink (noidont, I no understand, "Hmm, I'm not quite sure I'm getting the joke here.")
                    AddPageLink (noidont, fantastic, "Wow, that was a really good one!")
                    AddPageLink (noidont, no funny, "That was not really all that funny.")
                  </script>
                  <object name="I no understand">
                    <inherit name="scripttext" />
                    <script type="script">
                      msg ("Abigail: Oh, the point of the joke is that the other two who entered the bar where religious fiures, the monk and the priest.")
                      msg ("Abigail: So the rabbit doesn't quite fit in, it's because he was actually a rabbi instead. So I mispronounced that hence the \"did you slip your tongue?\" .")
                      msg ("Abgail: Now that joke isn't exactly funny anymore is it? It tends to be that way when you explain a joke so I'm sorry if I ruined it for you.")
                      AddPageLink (I no understand, thirdrestfirstdeath, "No need to apoligise, I'm the one who didn't understand. Also, reflecting on your joke it is still pretty funny.")
                    </script>
                  </object>
                  <object name="fantastic">
                    <inherit name="scripttext" />
                    <script type="script">
                      msg ("Abigail: I'm glad you liked it!")
                      msg ("Abigail: So, have you come up with a good joke while I was telling you mine?")
                      AddPageLink (fantastic, noreally, "Not really, I'm not that good with jokes.")
                    </script>
                    <object name="noreally">
                      <inherit name="scripttext" />
                      <script type="script">
                        msg ("Abigail: Oh, that's fine with me, do you have anything else to say then?")
                        AddPageLink (noreally, thirdrestfirstdeath, "Sure! We could talk about so many things, like for example...")
                      </script>
                    </object>
                  </object>
                  <object name="no funny">
                    <inherit name="scripttext" />
                    <script type="script">
                      msg ("Abigail: Well, I'm not sure what to say to that. ")
                      AddPageLink (no funny, thirdrestfirstdeath, "Oh I'm sorry, I didn't mean to offend you or anything like that.")
                    </script>
                  </object>
                </object>
                <object name="whydidthechickencrosstheroad" />
                <object name="knockknock" />
              </object>
            </object>
            <object name="swiss">
              <inherit name="scripttext" />
              <script type="script">
                SetForegroundColour ("OrangeRed")
                msg ("Abigail: Ah I see, that makes a lot of sense! With those things you could ensure your survival, good thinking!")
                AddPageLink (swiss, thnaks, "Thanks!")
              </script>
            </object>
          </object>
          <object name="frap">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("The barista smiles and says coming right up!")
              msg ("You and Abigail walk back to your table and take a seat.")
              SetForegroundColour ("OrangeRed")
              msg ("Abigail: So, in the mean time we can catch up a bit!")
              msg ("Abigail: I just came up with a good question to ask you!")
              msg ("Abigail: If you were only allowed to take three things with you on a desserted island, what would you bring along?")
              AddPageLink (frap, pil, "I would take my computer, my phone and a pilates ring.")
              AddPageLink (frap, swiss, "I would take a tent, a rope and a swiss pocket knife.")
            </script>
          </object>
          <object name="thirdrestfirstdeath">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("Suddenly you hear someone scream, you can turn your head just quick enough to see someone fall with a plate in their hands.")
              msg ("The plate flies in the air, with it the ham sandwich that was put on top of it.")
              msg ("You are apparently not the only one who has noticed, as you can see a gigantic grey-ish creature jumping out from the water and lunging at the sandwich.")
              msg ("It takes you a second or two to realise that the creature is in fact a shark, do they keep sharks in the cafe?")
              msg ("You can barely get out of it's reach as it lands on the table, you get a brief glimpse of it's sheer gigantic proportions.")
              msg ("Abigail gets to look at the size of the great white shark a little bit closer as it completly crushes her with it's weight.")
              SetFontSize (29)
              msg ("Game over")
              SetFontSize (13)
              msg ("Your date surely didn't go as planned.")
              SetFlagOn ("sharkknowledge")
              SetFontSize (11)
              AddPageLink (thirdrestfirstdeath, Page1, "Retry")
              SetForegroundColour ("OrangeRed")
            </script>
          </object>
          <object name="death2res3">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("Suddenly you hear the sound of glass shattering acompagnied with loud cursing.")
              msg ("A red sudan crashes through the ceiling itself, a seemingly endless stream of water follows him.")
              msg ("The customers all run towards the door as fast as they can.")
              msg ("They push as hard as they can yet the door does not seem to budge.")
              msg ("It doesn't take too long before the water has filled the entire room, you soon begin losing consciousness.")
              msg ("When you awaken all the water around you is gone and the door is open, a young woman walks towards you when she sees that you've regained consciousness.")
              msg ("Apparently she and her partner were walking around when they heard the comotion in the restaurant, a really heavy container was blocking the only way in so they had to call the fire department.")
              msg ("Eventually they managed to move the container and free everyone from drowning to dead.")
              msg ("Or atleast almost everyone, some people died.  You guessed it, Abigail did as well.")
              SetFontSize (29)
              msg ("Game over")
              SetFontSize (13)
              msg ("Your date surely didn't go as planned.")
              SetFlagOn ("drownknowledge")
              SetFontSize (11)
              AddPageLink (death2res3, Page1, "Retry")
              SetForegroundColour ("OrangeRed")
            </script>
          </object>
        </object>
