                            <object name="breakdownreality">
                              <inherit name="scripttext" />
                              <script type="script">
                                SetForegroundColour ("Green")
                                msg ("I tried everything I could think of Abigail.")
                                msg ("I've fled form death with you, even going as far as flying away from the earth with a spaceship only for reality itself to collapse.")
                                if (GetBoolean(game, "Ronknowledge")) {
                                  msg ("I might have been selfish, in one timeline you end up with a guy called Ron and you two just have a great time together.")
                                  msg ("But that wasn't enough for me, I want to go on this date and have you come out of it alive and well.")
                                }
                                msg ("I just want to share a nice, enjoyable date with you.")
                                SetForegroundColour ("Purple")
                                msg ("Abigail points at the village, the sun is setting once again.")
                                SetForegroundColour ("OrangeRed")
                                msg ("Abigail: With such a marvelous view I would surely call this a nice, enjoyable date.")
                                SetForegroundColour ("Purple")
                                msg ("Abigail cuddles up to you.")
                                SetForegroundColour ("OrangeRed")
                                msg ("Abigail: Thanks for going on this date with me! I'm having a really good time so far!")
                                msg ("Abigail: You know, I've been thinking...")
                                msg ("Abigail: If I'm going to die soon then what's stopping you from quitting this game? OR would I just lose consciousnes, like I'm dying?")
                                msg ("Abigail: I'm not sure if there's a way to tell. What do you think?")
                                AddPageLink (breakdownreality, you will live on, "I believe that you would still live on.")
                                SetFlagOn ("Credits")
                              </script>
                              <object name="you will live on">
                                <inherit name="scripttext" />
                                <script type="script"><![CDATA[
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Abigail: That's rather reassuring.")
                                  msg ("Abigail: Since we're in a video game there's only so much dialogue I can tell you and only as many places we can go to as are programmed into it.")
                                  msg ("Abigail: But if you could break the boundaries through whatever creative outlet you have then there would essentially be thousands upon thousands of stories about us that you could give life. ")
                                  msg ("Abigail: The best part would be that you decide how they play out.")
                                  SetForegroundColour ("Purple")
                                  msg ("Abigail pauses for a moment and then continues.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Abigail:We tend to create these new worlds all the time, sometimes even without realising it.<br/>Abigail: When you are thinking about what the next season of your favourite show will be about then you're technically creating an entire new world where the show's characters go through your story.<br/>Abigail: And who's to say wich version is the superior one? Afterall, they're both telling a story, personally I think that's absolutely beautiful.<br/>Abigail: So let's try to do just that!")
                                  SetForegroundColour ("Purple")
                                  msg ("Abigail hugs you for a long period of time, you feel her warmth as it reaches your cold body.")
                                  msg ("After a while she stops embracing you and looks at you with a soft smile on her lips.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Abigail: So... has it already happened? Are you now making our story?")
                                  AddPageLink (you will live on, I no make yet, "No, we're still in the game.")
                                  AddPageLink (you will live on, I am making, "Yes, I'm now in full control of it.")
                                ]]></script>
                                <object name="I am making">
                                  <inherit name="scripttext" />
                                  <script type="script">
                                    SetForegroundColour ("Purple")
                                    msg ("Abigail gives you a warm embrace and jumps up in the air after she stops hugging you.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: Perfect! So now we can just do whatever we want without having to fear being killed right?")
                                    AddPageLink (I am making, absolutely, "Absolutely!")
                                  </script>
                                  <object name="absolutely">
                                    <inherit name="scripttext" />
                                    <script type="script">
                                      SetForegroundColour ("Purple")
                                      msg ("Just as you said that something kills Abigail since you lied to here and were actually still in the game that has a habbit of killing her of. (I still need to come up with a death for this one.)")
                                      SetFontSize (29)
                                      msg ("Game over")
                                      SetFontSize (13)
                                      msg ("Your date surely didn't go as planned.")
                                      SetFlagOn ("tellnoliesknowledge")
                                      SetFontSize (11)
                                      AddPageLink (absolutely, Page1, "Retry")
                                      SetForegroundColour ("OrangeRed")
                                      msg ("You unlocked the credits.")
                                    </script>
                                  </object>
                                </object>
                                <object name="I no make yet">
                                  <inherit name="scripttext" />
                                  <script type="script">
                                    SetForegroundColour ("Purple")
                                    msg ("Abigail looks at you with a puzzled look on her face.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: Oh, why haven't you started yet? Just picture us in your mind and tell the story you'd like to live through.")
                                    AddPageLink (I no make yet, I want to see where this leads, "I just want to see what happens when I choose this path.")
                                  </script>
