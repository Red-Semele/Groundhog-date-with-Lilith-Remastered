                              <object name="rightstory">
                                <inherit name="scripttext" />
                                <script type="script">
                                  SetForegroundColour ("Purple")
                                  msg ("Abigail gasps, you can see the pure confusion in her eyes.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Abigail: Hang on, how did you know wich story I was thinking of?")
                                  msg ("Abigail: I mean, I guess you told me you were in a game but how would you have known? ")
                                  AddPageLink (rightstory, retry saves, "I'm basically retying certain scenarios and learning things that I need to then move on.")
                                  RemovePageLink (rightstory, no time to explain)
                                  RemovePageLink (rightstory, no time to explain)
                                  RemovePageLink (rightstory, no time to explain)
                                  if (GetBoolean(game, "geeseknowledge")) {
                                    if (GetBoolean(game, "chinese")) {
                                      AddPageLink (rightstory, no time to explain, "I have no time to explain, we need to get out of here, follow me.")
                                    }
                                  }
                                  else if (GetBoolean(game, "gasknowledge")) {
                                    if (GetBoolean(game, "burgers")) {
                                      AddPageLink (rightstory, no time to explain, "I have no time to explain, we need to get out of here, follow me.")
                                    }
                                  }
                                  else if (GetBoolean(game, "drownknowledge")) {
                                    if (GetBoolean(game, "cafe")) {
                                      AddPageLink (rightstory, no time to explain, "I have no time to explain, we need to get out of here, follow me.")
                                    }
                                  }
                                </script>
                                <object name="retry saves">
                                  <inherit name="scripttext" />
                                  <script type="script">
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: That would be nice wouldn't it? To just be able to retry all the things that bother us and then just solve all the problems on that front.")
                                    msg ("Abigail: Sometimes I just want to put time to a halt to live a week in a second's worth of time.")
                                    msg ("Abigail: To just be able to capture one moment and live it for as long as I would want, that seems liek a wonderfull thought doesn't it?")
                                    SetForegroundColour ("Purple")
                                    msg ("You nod at Abigail and she gives you a cute smile.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: I knew you'd get it! ")
                                    msg ("Abigail: I think that we all have that desire, to just take a rest from the endless stream of things that life brings us.")
                                    msg ("Abigail: And in a way, you get to do just that.")
                                    msg ("Abigail: Capturing certain moments and reliving them endlessly, you really have been graced with a beautiful gift if you'd ask me.")
                                    msg ("Abigail: Even if the moments you get to relive are just part of a game, don't take it for granted.")
                                    msg ("Abigail: In the end everything is just as real as you make it.")
                                    msg ("Abigail: I hope that made some sense and sorry if I'm rambling.")
                                    AddPageLink (retry saves, rambling, "You're not rambling and you're making perfect sense.")
                                  </script>
                                  <object name="rambling">
                                    <inherit name="scripttext" />
                                    <script type="script"><![CDATA[
                                      if (GetBoolean(game, "burgers")) {
                                        msg ("Suddenly a inmense sensation of pain overwhelms you, the only thing you can see is a glimpse of pure white and an eternity of black.")
                                        msg ("When you awaken you find yourself surrounded by doctors, they tell you that with the force of sheer luck a stray bullet managed to cause a gas leak.")
                                        msg ("The gas explosion that followed was quite severe, you were in a coma and had to have your wounds cleaned with some surgical procedures.")
                                        msg ("After a week you got out of your coma, Abigail however didn't have such luck.")
                                        msg ("The doctors tell you that she atleast went out pretty quickly, almost like dying in your sleep but with more explosions.")
                                        SetFlagOn ("gasknowledge")
                                        SetFontSize (29)
                                        msg ("Game over")
                                        SetFontSize (13)
                                        msg ("Your date surely didn't go as planned.")
                                        SetFontSize (11)
                                        AddPageLink (rambling, Page1, "Retry")
                                        SetForegroundColour ("OrangeRed")
                                      }
                                      else if (GetBoolean(game, "cafe")) {
                                        SetForegroundColour ("Purple")
                                        msg ("Suddenly you hear someone scream, you can turn your head just quick enough to see someone fall with a plate in their hands.")
                                        msg ("The plate flies in the air, with it the ham sandwich that was put on top of it.")
                                        msg ("You are apparently not the only one who has noticed, as you can see a gigantic grey-ish creature jumping out from the water and lunging at the sandwich.")
                                        msg ("It takes you a second or two to realise that the creature is in fact a shark, do they keep sharks in the cafe?")
                                        msg ("You can barely get out of it's reach as it lands on the table, you get a brief glimpse of it's sheer gigantic proportions.")
                                        msg ("Abigail gets to look at the size of the great white shark a little bit closer as it completly crushes her with it's weight.")
                                        SetFontSize (29)
                                        msg ("Game over")
                                        SetFontSize (13)
                                        msg ("Your date surely didn't go as planned.")
                                        SetFlagOn ("sharkknowledge")
                                        SetFontSize (11)
                                        AddPageLink (rambling, Page1, "Retry")
                                        SetForegroundColour ("OrangeRed")
                                      }
                                      else if (GetBoolean(game, "chinese")) {
                                        SetForegroundColour ("Purple")
                                        msg ("Suddenly you are interrupted in the midle of your sentence, you hear the faint sound of quacking.")
                                        msg ("The sound of the quacking steadily grows louder and louder untill it's all you can hear.")
                                        msg ("A true quackophony if you will.")
                                        msg ("Abigail looks over your shoulder with a frightend look in her eyes.")
                                        msg ("When you turn around you see a wave of angry geese breaking through the doors of the once cozy Chinese restaurant, the staff is running around in sheer panic.")
                                        msg ("Before you can make another sound everything turns to white, the white of pesky geese feathers.")
                                        msg ("The pain you are experiencing is too much and you fall unconscious.")
                                        msg ("When you wake up again all the cutomers and staff have dissapeared, including Abigail.")
                                        msg ("The room is completly filled to the brim with geese feathers, you begin to sneeze just thinking about that.")
                                        msg ("While you are sneezing you notice that someone put a sticky note on your hand.")
                                        msg ("It reads a as following: \"We took everyone and you won't be seeing them back, let this be a lesson on why you should not eat or serve geese or ducks as those are also part of our family. <br/>- Sincerely, the geese\"")
                                        SetFontSize (29)
                                        msg ("Game over")
                                        SetFontSize (13)
                                        msg ("Your date surely didn't go as planned.")
                                        SetFlagOn ("geeseknowledge")
                                        SetFontSize (11)
                                        AddPageLink (rambling, Page1, "Retry")
                                        SetForegroundColour ("OrangeRed")
                                      }
                                    ]]></script>
                                  </object>
                                </object>
