                        <object name="Game">
                          <inherit name="scripttext" />
                          <script type="script">
                            msg ("Abigail: Wait what? So you are saying we are in some sort of game right now?")
                            msg ("Abigail: I mean that could certainly be a possibility, I'm not sure if we'll ever know for sure if we're in a game or not.")
                            msg ("Abigail: I find what your saying to be rather interesting but do you have any proof as to your whole \"we're in a videogame\" story?")
                            AddPageLink (Game, think of story, "Alright, think of a story, anything will do.")
                          </script>
                          <object name="think of story">
                            <inherit name="scripttext" />
                            <script type="script">
                              SetForegroundColour ("OrangeRed")
                              msg ("Abigail: Alright, I can see where this is going, you're going to try and guess what I'm thinking of right?")
                              AddPageLink (think of story, yesguess, "Yup, you're absolutely right!")
                              AddPageLink (think of story, nope, "No, you need to tell me the story now.")
                            </script>
                            <object name="yesguess">
                              <inherit name="scripttext" />
                              <script type="script">
                                SetForegroundColour ("OrangeRed")
                                msg ("Abigail: Well best of luck, i got a pretty hard story for you to guess.")
                                SetForegroundColour ("Purple")
                                msg ("Abigail giggles for a moment and then looks at you with a sceptic look in her eyes.")
                                AddPageLink (yesguess, wrongstory, "Your story is about a girl that goes out to buy milk and gets trapped in some alternate universe that is a reflection of her mind.")
                                AddPageLink (yesguess, wrongstory1, "Your story is about about a man who has to live through an apocalypse that has been caused by strange crystals.")
                                AddPageLink (yesguess, word badoption2, "Your story is about someone who has to date parts of himself to come to terms with his bad fragments.")
                                AddPageLink (yesguess, wrongstory3, "Actually I have no clue what the story you have in mind could be.")
                                if (GetBoolean(game, "storyknowledge")) {
                                  AddPageLink (yesguess, rightstory, "Your story is about a man who meets the love of his life in a dream and spends his entire life with her only to wake up the day after he went to bed.")
                                }
                              </script>
                              <object name="wrongstory">
                                <inherit name="scripttext" />
                                <script type="script">
                                  msg ("Abigail: That was the wrong story! I knew you wouldn't guess the story would be about a guy who meets a girl in his dreams and spends his whole life with her, only to wake up a day later than he went to bed.")
