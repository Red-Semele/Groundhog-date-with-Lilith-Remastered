                          <object name="kakdeath1warn">
                            <inherit name="scripttext" />
                            <script type="script">
                              SetForegroundColour ("Purple")
                              msg ("As Abigail moves to the other side of the blanket, to your left, a meteorite crashes down just where she was sitting before.")
                              msg ("Abigail jumps up from pure shock before taking a deep breath and recollecting herself.")
                              SetForegroundColour ("OrangeRed")
                              msg ("Abigail: Sorry, I can't get used to all this death stuff, even when I know it's coming.")
                              AddPageLink (kakdeath1warn, Page1, "This is all there's to do here for now, this link will take you back to the start screen, there will be a puzzle there aswell, one with calling the police.")
                              if (GetBoolean(game, "realityknowledge")) {
                                AddPageLink (kakdeath1warn, breakdownreality, "I tried everything Abigail, I even took you to space but it didn't work out, no matter wich path I choose you still end up dying.")
