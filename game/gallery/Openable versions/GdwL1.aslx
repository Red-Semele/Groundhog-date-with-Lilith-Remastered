                              <object name="breakloop">
                                <inherit name="scripttext" />
                                <options type="stringdictionary" />
                                <script type="script">
                                  msg ("Abigail: So you mean to tell me that your groundhog day scenario is linked to me dying and that is what is causing the loop?")
                                  msg ("Abigail: I mean, don't get me wrong, I'm flattered that whoever made you keep looping untill I was safe did but what happens when we make it out of here alive?")
                                  msg ("Abigail: If me dying resets the day untill you saved me would it also happen when I'm dying of old age or would that loop of you only work for one day?")
                                  AddPageLink (breakloop, Ihavenoidea, "I have no idea to be honest, we've never made it that far.")
                                  AddPageLink (breakloop, Only for this day, "No, it seems like it will only be for today, or I hope so atleast.")
                                </script>
                                <object name="Ihavenoidea">
                                  <inherit name="scripttext" />
                                  <script type="script"><![CDATA[
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: I really hope that wouldn't be the case, I don't want to die too early ofcourse, but when I have lived a long life and my time has come I'd be more than happy to go.")
                                    SetForegroundColour ("Purple")
                                    msg ("Abigail looks at you as to make sure you're processing all of this, you give her a silent nod and she continues.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: I mean, imagine what a nightmare it must be for the both of us.")
                                    msg ("Abigail:You would be cursed with always having to save an old lady that could litterally die any moment, always just buying her a few extra hours.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: And I would be cursed with never getting to pass away, I would be the oldest person that was ever alive and just be a living heap of flesh and wrinkles after a year of 200. No matter how much I would pray for the sweet release of death it would never come, or atleast I would never be aware that it came as you would just rewind and try to fix it.")
                                    SetForegroundColour ("Purple")
                                    msg ("Abigail shudders.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Abigail: Let's just hope that this loop will end for the both of us before we get at that point.")
                                    SetForegroundColour ("Purple")
                                    msg ("Shaken by the images of a living heap of flesh and wrinkles you can only agree with her.")
                                    if (GetBoolean(game, "burgers")) {
                                      msg ("Suddenly a inmense sensation of pain overwhelms you, the only thing you can see is a glimpse of pure white and an eternity of black.")
                                      msg ("When you awaken you find yourself surrounded by doctors, they tell you that with the force of sheer luck a stray bullet managed to cause a gas leak.")
                                      msg ("The gas explosion that followed was quite severe, you were in a coma and had to have your wounds cleaned with some surgical procedures.")
                                      msg ("After a week you got out of your coma, Abigail however didn't have such luck.")
                                      msg ("The doctors tell you that she atleast went out pretty quickly, almost like dying in your sleep but with more explosions.")
                                      SetFlagOn ("gasknowledge")
                                      SetFontSize (29)
                                      msg ("Game over")
                                      SetFontSize (13)
                                      msg ("Your date surely didn't go as planned.")
                                      SetFontSize (11)
                                      AddPageLink (Ihavenoidea, Page1, "Retry")
                                      SetForegroundColour ("OrangeRed")
                                    }
                                    else if (GetBoolean(game, "cafe")) {
                                      SetForegroundColour ("Purple")
                                      msg ("Suddenly you hear someone scream, you can turn your head just quick enough to see someone fall with a plate in their hands.")
                                      msg ("The plate flies in the air, with it the ham sandwich that was put on top of it.")
                                      msg ("You are apparently not the only one who has noticed, as you can see a gigantic grey-ish creature jumping out from the water and lunging at the sandwich.")
                                      msg ("It takes you a second or two to realise that the creature is in fact a shark, do they keep sharks in the cafe?")
                                      msg ("You can barely get out of it's reach as it lands on the table, you get a brief glimpse of it's sheer gigantic proportions.")
                                      msg ("Abigail gets to look at the size of the great white shark a little bit closer as it completly crushes her with it's weight.")
                                      SetFontSize (29)
                                      msg ("Game over")
                                      SetFontSize (13)
                                      msg ("Your date surely didn't go as planned.")
                                      SetFlagOn ("sharkknowledge")
                                      SetFontSize (11)
                                      AddPageLink (Ihavenoidea, Page1, "Retry")
                                      SetForegroundColour ("OrangeRed")
                                    }
                                    else if (GetBoolean(game, "chinese")) {
                                      SetForegroundColour ("Purple")
                                      msg ("Suddenly you are interrupted in the midle of your sentence, you hear the faint sound of quacking.")
                                      msg ("The sound of the quacking steadily grows louder and louder untill it's all you can hear.")
                                      msg ("A true quackophony if you will.")
                                      msg ("Abigail looks over your shoulder with a frightend look in her eyes.")
