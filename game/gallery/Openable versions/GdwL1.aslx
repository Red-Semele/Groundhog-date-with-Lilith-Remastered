            <inherit name="scripttext" />
            <script type="script">
              msg ("Abgail: Hmm what are you saying? Why are you so concerned with us going to a restaurant, it's not like it's going to kill us silly.")
              AddPageLink (import, it will, "Actually it will, or it will kill you atleast.")
              AddPageLink (import, I was just messing with you, "Sorry, I was just messing with you.")
              if (GetBoolean(game, "Dumboknowledge")) {
                AddPageLink (import, Iknowaboutyourallergy, "I know about that one time when you thought you were Dumbo while suffering an allergic reaction.")
              }
              if (GetBoolean(game, "brotherknowledge")) {
