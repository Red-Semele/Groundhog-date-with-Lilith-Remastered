              if (GetBoolean(game, "startknowledge")) {
                if (GetBoolean(game, "middleknowledge")) {
                  if (GetBoolean(game, "endknowledge")) {
                    AddPageLink (import, tell the untold story, "I know about your untold story.")
                  }
                }
              }
              if (GetBoolean(game, "kakknowledge")) {
                AddPageLink (import, Kakarikowoods, "No time to explain, meet me at the Kakariko woods.")
              }
