        <object name="Riddle evalution page">
          <inherit name="scripttext" />
          <script type="script"><![CDATA[
            if (GetInt(game, "R1W") = 0) {
              if (GetInt(game, "R2W") = 0) {
                if (GetInt(game, "R3W") = 0) {
                  SetForegroundColour ("OrangeRed")
                  msg ("Wow, you got them all right, color me impressed!")
                  if (not GetBoolean(game, "R1knowledge")) {
                    if (not GetBoolean(game, "R2knowledge")) {
                      if (not GetBoolean(game, "R3knowledge")) {
                        if (not GetBoolean(game, "NMdetect")) {
                          SetFlagOn ("Mdetect")
                        }
                      }
                    }
                  }
                }
              }
            }
            else if (GetInt(game, "RW") = 1) {
              SetForegroundColour ("OrangeRed")
              msg ("Only one riddle wrong, not shabby at all!")
              SetFlagOn ("NMdetect")
            }
            else if (GetInt(game, "RW") <= 3) {
              SetForegroundColour ("OrangeRed")
              msg ("You did pretty great, you gave it your best shot!")
              SetFlagOn ("NMdetect")
            }
            else if (GetInt(game, "RW") <= 6) {
              SetForegroundColour ("OrangeRed")
              msg ("You are pretty determined, I like that!")
              SetFlagOn ("NMdetect")
            }
            else if (GetInt(game, "RW") > 6) {
              SetForegroundColour ("OrangeRed")
              msg ("Oh, did I make my riddles too hard?")
              SetFlagOn ("NMdetect")
            }
            SetCounter ("R1W", 0)
            SetCounter ("R2W", 0)
            SetCounter ("R3W", 0)
            SetCounter ("RW", 0)
            wait {
              MovePlayer (Chinese Abby memories)
            }
          ]]></script>
        </object>
      </object>
      <object name="Chinese restaurant">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          SetForegroundColour ("OrangeRed")
          msg ("That sounds like a plan!")
          msg ("I'll see you there.")
          SetForegroundColour ("Purple")
          msg ("You head to the Chinese restaurant, when you arive there Lilith is already seated. She happily waves at you.")
          wait {
            SetForegroundColour ("Purple")
            msg ("It's not too busy right now but the amount of people certainly isn't anything to scoff at.")
            msg ("You walk towards the table where Lilith is sitting and greet her with a cheerful smile.")
            wait {
              SetForegroundColour ("OrangeRed")
              msg ("Heya {player.alias}! <br/>Glad to see you here.")
              SetForegroundColour ("Purple")
              msg ("She gives you an honest smile.")
              wait {
                MovePlayer (Chinese restaurant choices)
              }
            }
          }
        ]]></script>
        <object name="Chinese restaurant choices">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Chinese restaurant would no want to miss this</key>
              <value>Glad to be here aswell!</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
          <object name="Chinese restaurant would no want to miss this">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("OrangeRed")
              msg ("Oh you flatterer!")
              wait {
                SetForegroundColour ("Purple")
                msg ("Lilith pauses for a moment, seemingly lost in a thought.")
                wait {
                  SetForegroundColour ("OrangeRed")
                  msg ("Or are you glad to be here for the restaurant itself?")
                  MovePlayer (Would no want to miss this choice)
                }
              }
            </script>
            <object name="Would no want to miss this choice">
              <inherit name="scripttext" />
              <options type="stringdictionary">
                <item>
                  <key>Chin_for restaurant</key>
                  <value>Mostly for the restaurant, I really like it here.</value>
                </item>
                <item>
                  <key>Chin_for you</key>
                  <value>For you of course silly!</value>
                </item>
              </options>
              <script type="script">
                SetForegroundColour ("DarkGreen")
              </script>
              <object name="Chin_for restaurant">
                <inherit name="scripttext" />
                <script type="script"><![CDATA[
                  SetForegroundColour ("OrangeRed")
                  msg ("Oh, I mean I like this place aswell I suppose...")
                  SetForegroundColour ("Purple")
                  msg ("She seems slightly dissapointed with your answer.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("Anyway, I think I'd starve if I don't eat soon so let's continue our little chat while we wait on our food.<br/>What would you like to order?")
                    wait {
                      MovePlayer (Chinese menu choice)
                    }
                  }
                ]]></script>
              </object>
              <object name="Chin_for you">
                <inherit name="scripttext" />
                <script type="script"><![CDATA[
                  SetForegroundColour ("Purple")
                  msg ("Lilith lets out a sigh of relief and chuckles slightly.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("Sorry, that was just a thought that popped up in my head.")
                    SetForegroundColour ("Purple")
                    msg ("She looks like she could sink through the floor out of embarrassment so you decide it's best to forget what she has said.")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("Anyway, I think I'd starve if I don't eat soon so let's continue our little chat while we wait on our food.<br/>What would you like to order?")
                      wait {
                        MovePlayer (Chinese menu choice)
                      }
                    }
                  }
                ]]></script>
              </object>
            </object>
          </object>
          <object name="Chinese menu choice">
            <inherit name="scripttext" />
            <options type="stringdictionary">
              <item>
                <key>Peking duck</key>
                <value>I'm going for the peking duck.</value>
              </item>
              <item>
                <key>orange chicken</key>
                <value>I think I'll pick the orange chicken.</value>
              </item>
            </options>
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("You open the menu and two tems catch your eye.")
              SetForegroundColour ("DarkGreen")
            </script>
            <object name="Peking duck">
              <inherit name="scripttext" />
              <options type="stringdictionary">
                <item>
                  <key>Waitress chinese res</key>
                  <value>Great minds think alike.</value>
                </item>
              </options>
              <script type="script"><![CDATA[
                SetForegroundColour ("OrangeRed")
                msg ("That's a good choice! <br/>So good in fact that I was thinking about picking the same thing.")
                SetForegroundColour ("DarkGreen")
                if (GetBoolean(game, "allergyknowledge")) {
                  AddPageLink (orange chicken choice, Warning her about food, "Actually there is something in that peking duck that you are really allergic to, deathly even.")
                }
              ]]></script>
            </object>
            <object name="orange chicken">
              <inherit name="scripttext" />
              <script type="script"><![CDATA[
                SetForegroundColour ("OrangeRed")
                msg ("That's a good choice! <br/>I've had my fair share of orange chicken already throughout my life, so I think I'm going for something else.")
                wait {
                  SetForegroundColour ("Purple")
                  msg ("Lilith scratches her chin softly.")
                  SetForegroundColour ("OrangeRed")
                  msg ("I think I'm going to pick the peking duck, beats another portion of orange chicken.")
                  wait {
                    SetForegroundColour ("Purple")
                    msg ("She lets out a small chuckle.<br/>")
                    MovePlayer (orange chicken choice)
                  }
                }
              ]]></script>
              <object name="orange chicken choice">
                <inherit name="scripttext" />
                <options type="stringdictionary">
                  <item>
                    <key>Waitress chinese res</key>
                    <value>Sounds good to me!</value>
                  </item>
                </options>
                <script type="script">
                  SetForegroundColour ("DarkGreen")
                  if (GetBoolean(game, "allergyknowledge")) {
                    AddPageLink (orange chicken choice, Warning her about food, "Actually there is something in that peking duck that you are really allergic to, deathly even.")
                  }
                </script>
              </object>
            </object>
            <object name="Waitress chinese res">
              <inherit name="scripttext" />
              <script type="script"><![CDATA[
                SetForegroundColour ("Purple")
                msg ("<br/>Suddenly a waitress stands right before your table, slightly startling you.<br/>Lilith tries her best not to burst out with laughter but a few muffled laughs get through.<br/><br/>After writing down both of your choices she wanders of towards the kitchen.")
                wait {
                  MovePlayer (Chinese restaurant_riddles)
                }
              ]]></script>
            </object>
          </object>
        </object>
        <object name="Warning her about food">
          <inherit name="scripttext" />
          <script type="script">
            msg ("I suppose that makes sense, I am allergic to quite a few things.")
            msg ("When I was a kid I once ate a few peanuts while I was watching Dumbo, I felt my throat swell and I thought I was becoming a little elephant, just like Dumbo.")
            msg ("I ran to my parents and said:\"Look mommy, look daddy! I can fly!\" and then I started using my hands to flap my ears around like Dumbo.")
            msg ("At that point I was pretty swollen so it was a good thing my parents saw me, we went to the hospital as fast as we could and the kind doctors really helped me out.")
            msg ("When I finally was allowed to go home from the hospital my parents gave me a Dumbo plushie to always remember the story.")
            msg ("And I can say that I still remember it like it was yesterday,  the same counts  for my mom, she keeps joking about it to this day.")
            msg ("Lilith  lets out a huge laugh as she looks at you.")
            SetForegroundColour ("Purple")
            msg ("Suddenly she stops, you see a look of worry in her eyes.")
            SetForegroundColour ("OrangeRed")
            msg ("Oh sorry, I'm ranting again aren't I?")
            msg ("I'm sorry, it's just that when I start talking it's pretty hard for me to stop, what were we talking about again?")
            msg ("Oh yeah, the supposed allergy I would have if I ate that Peking duck.")
            msg ("How would you even know? I mean, I checked the ingredients on the list and as far as I'm aware I'm not allergic to any of those.")
            msg ("So let's say that there's something in this dish that I'm really allergic to but I don't know it yet, how would you know that?")
          </script>
        </object>
      </object>
      <object name="Burger_brother">
        <inherit name="scripttext" />
        <options type="stringdictionary" />
        <script type="script"><![CDATA[
          SetForegroundColour ("OrangeRed")
          msg ("Thank you for bringing me here {player.alias}.<br/>It has been too long since I've been here, to tell you the truth I actually was avoiding this place.<br/>But now the happy memories come flooding back to me.")
          wait {
            SetForegroundColour ("Purple")
            msg ("Lilith pauses for a moment, she seems unsure whether to continue or not.")
            wait {
              SetForegroundColour ("OrangeRed")
              TextFX_Typewriter ("You know, my brother really used to love this place before...", 200)
              wait {
                SetForegroundColour ("Purple")
                msg ("Lilith freezes before she can continue the sentence.")
                MovePlayer (Burger_brother_options)
              }
            }
          }
        ]]></script>
        <object name="Burger_brother_options">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Burger_brother what is a name</key>
              <value>What was his name?</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
          <object name="Burger_brother what is a name">
            <inherit name="scripttext" />
            <options type="stringdictionary">
              <item>
                <key>Burger_joke for smile</key>
                <value>*Alleviate tension with a joke.*</value>
              </item>
            </options>
            <script type="script">
              SetFlagOn ("Askedbrother")
              SetForegroundColour ("Purple")
              msg ("Lilith tries to compose herself as well as she can but from the look in her eyes you can tell this is all a bit much for her.")
              SetCounter ("brotherask", 0)
            </script>
            <object name="Burger_joke for smile">
              <inherit name="scripttext" />
              <options type="stringdictionary">
                <item>
                  <key>Burger_Granite joke</key>
                  <value>You know, I've dated rocks before but they always tend to take things for granite.</value>
                </item>
                <item>
                  <key>Burger_pointless joke</key>
                  <value>The triangle thought about dating circles but ultimately it seemed to pointless.</value>
                </item>
                <item>
                  <key>Burger_click joke</key>
                  <value>The computer mouse wanted to date someone who clicked with them.</value>
                </item>
              </options>
              <script type="script">
                SetForegroundColour ("DarkGreen")
                if (GetBoolean(game, "jokeknowledge")) {
                  AddPageLink (Burger_joke for smile, Burger_Abigail joke, "So a priest, a monk and a rabbit enter a bar.  Says the rabbit :\"Whoops, did you slip your tongue there {player.alias}?\"")
                }
              </script>
              <object name="Burger_Granite joke">
                <inherit name="scripttext" />
                <script type="script">
                  MovePlayer (Burger_joke response)
                </script>
                <object name="Burger_joke response">
                  <inherit name="scripttext" />
                  <script type="script"><![CDATA[
                    SetForegroundColour ("Purple")
                    msg ("A slight smile forms on Lilith's face. <br/>She doesn't seem to find your joke that funny but from the gratitude in her eyes you can tell she is thankful for your effort.<br/>She seems to have become slightly more composed.")
                    SetForegroundColour ("OrangeRed")
                    TextFX_Typewriter ("Thank you.", 150)
                    wait {
                      ClearScreen
                      SetForegroundColour ("Purple")
                      msg ("Lilith continues as if nothing happened.")
                      MovePlayer (Burger what do you do for a living)
                    }
                  ]]></script>
                  <object name="Burger what do you do for a living">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>Burger_aspiring writer</key>
                        <value>I'm an aspiring writer looking for a golden opportunity.</value>
                      </item>
                      <item>
                        <key>Burger_unemployed</key>
                        <value>I'm currently unemployed but I sure like to write!</value>
                      </item>
                    </options>
                    <script type="script">
                      SetForegroundColour ("OrangeRed")
                      msg ("So, what do you do for a living?")
                      SetForegroundColour ("DarkGreen")
                    </script>
                    <object name="Burger_aspiring writer">
                      <inherit name="scripttext" />
                      <options type="stringdictionary" />
                      <script type="script"><![CDATA[
                        SetForegroundColour ("OrangeRed")
                        msg ("That's pretty cool, you probably still have a whole journey to make to get from aspiring writer to a professional one.")
                        SetForegroundColour ("Purple")
                        msg ("Lilith pauses for a moment, she seems to be hesitant about continuing.")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("I also like to write something here and there in my free time, I'm not really wanting to become a writer, it's just something to put my emotions into. ")
                          wait {
                            msg ("I'd assume that's also a reason why you write, otherwise you probably wouldn't be dreaming of becoming a writer, right?")
                            wait {
                              msg ("Well, try to never forget why you started writing in the first place, alright? <br/>And then maybe you'll find an opportunity, maybe you won't, but in the end you'll always have your passion for writing.")
                              wait {
                                MovePlayer (Burger_aspiring_choice)
                              }
                            }
                          }
                        }
                      ]]></script>
                      <object name="Burger_aspiring_choice">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>Burger let Lilith show you her writing</key>
                            <value>Would you like to show me something you've written?</value>
                          </item>
                          <item>
                            <key>Burger_thanks for the tip Lilith I will use it well</key>
                            <value>Thanks for the tip, I'll try to keep it in mind.</value>
                          </item>
                        </options>
                        <script type="script">
                          SetForegroundColour ("DarkGreen")
                        </script>
                        <object name="Burger_thanks for the tip Lilith I will use it well">
                          <inherit name="scripttext" />
                          <options type="stringdictionary">
                            <item>
                              <key>Burger_aspiring_choice</key>
                              <value>Go back.</value>
                            </item>
                          </options>
                          <script type="script"><![CDATA[
                            SetForegroundColour ("LightGreen")
                            msg ("This path will take some thinking and work so it's not yet done.")
                            SetForegroundColour ("Purple")
                            msg ("Lilith gives you a big smile.")
                            SetForegroundColour ("OrangeRed")
                            msg ("You're more than welcome!<br/>This tip applies to all sort of things, not only writing.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("<br/>I would have loved to have been given the same advice when I needed to hear it the most.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("You see, I actually used to play the trombone.<br/>I loved playing music on that thing, you could say it was my passion.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("But after nine years of music lessons I caught myself just playing music for the sake of getting it done.")
                                  wait {
                                    SetForegroundColour ("OrangeRed")
                                    msg ("<br/>I quit that year.<br/>Now I barely play the trombone anymore.")
                                    wait {
                                      MovePlayer (Burger_tip choices)
                                    }
                                  }
                                }
                              }
                            }
                          ]]></script>
                          <object name="Burger_tip choices">
                            <inherit name="scripttext" />
                            <options type="stringdictionary">
                              <item>
                                <key>Burger_I am sorry you stopped</key>
                                <value>Oh, I'm sorry that you lost a hobby.</value>
                              </item>
                            </options>
                            <script type="script">
                              SetForegroundColour ("DarkGreen")
                            </script>
                            <object name="Burger_I am sorry you stopped">
                              <inherit name="scripttext" />
                              <script type="script"><![CDATA[
                                SetForegroundColour ("Purple")
                                msg ("Lilith laughs.")
                                SetForegroundColour ("OrangeRed")
                                msg ("No worries, I really like music and I will always treasure my memories with the trombone.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("<br/>But if I kept playing it I think I would slowly grow to resent it, sometimes it's just better to end things on a good note.")
                                  SetForegroundColour ("Purple")
                                  msg ("Lilith lets out a small giggle.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("That pun wasn't intended, I swear!")
                                  wait {
                                    MovePlayer (Burger shooting)
                                  }
                                }
                              ]]></script>
                            </object>
                          </object>
                        </object>
                        <object name="Burger let Lilith show you her writing">
                          <inherit name="scripttext" />
                          <script type="script"><![CDATA[
                            ClearScreen
                            SetForegroundColour ("Purple")
                            msg ("A wide smile grows on Lilith's face.")
                            SetForegroundColour ("OrangeRed")
                            msg ("You want to read something of me?")
                            msg ("I'd love that!")
                            SetForegroundColour ("Purple")
                            msg ("She eagerly digs in her handbag, retrieving a small notebook with a picture of a pug on it.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("I think you'll like this one!")
                              SetForegroundColour ("Purple")
                              msg ("She pushes the notebook, now flipped open, towards you.<br/>Suddenly you are reminded of the burger sauce that is all over your fingers.")
                              wait {
                                MovePlayer (Burger finger choice)
                              }
                            }
                          ]]></script>
                          <object name="Burger finger choice">
                            <inherit name="scripttext" />
                            <options type="stringdictionary">
                              <item>
                                <key>Burger_clean fingers before touching paper</key>
                                <value>Clean your fingers with a napkin.</value>
                              </item>
                              <item>
                                <key>Burger_no clean fingers</key>
                                <value>Don't clean your fingers.</value>
                              </item>
                            </options>
                            <script type="script">
                              SetForegroundColour ("DarkGreen")
                            </script>
                            <object name="Burger_no clean fingers">
                              <inherit name="scripttext" />
                              <script type="script"><![CDATA[
                                SetForegroundColour ("Purple")
                                msg ("Lilith frowns when she sees your dirty fingers.<br/>Nontheless you take the notebook out of her hand and begin to read.<br/>You can read the entire thing in her voice somehow.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Oh Moon<br/>here we are again, or rather, here I am again.")
                                  wait {
                                    msg ("<br/>Staring at my, our green horizon that never seems to cross with your silver.<br/>And yet every now and then it looks like you're waiting for me there, due to a trick of the light.")
                                    wait {
                                      msg ("<br/>Then I hear Orpheus' sweet sounds rise once more from the gap between Life and Death.<br/>But Orpheus' tune is quickly twisted into something else.")
                                      wait {
                                        msg ("<br/>And then I'll be here and you’ll be there once again.<br/>I don't know whether to cry or laugh when I look at my, our, green horizon.")
                                        wait {
                                          msg ("<br/>All I know is that we better not listen to the dwindling of Orpheus' tune.<br/>Has something that has not been seen or heard really happened?")
                                          wait {
                                            SetForegroundColour ("Purple")
                                            msg ("<br/><br/><br/>When you get done reading your eyes linger on the now dirtied notebook a bit longer before returning it to Lilith.")
                                            SetForegroundColour ("OrangeRed")
                                            msg ("So, what did you think of it?")
                                            SetForegroundColour ("Purple")
                                            msg ("She seems irritated by your actions but is asking out of politeness.")
                                            wait {
                                              IncreaseCounter ("brotherask")
                                              MovePlayer (Burger_writing rating)
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              ]]></script>
                            </object>
                            <object name="Burger_clean fingers before touching paper">
                              <inherit name="scripttext" />
                              <script type="script"><![CDATA[
                                SetForegroundColour ("Purple")
                                msg ("Lilith seems thankful that you cleaned your fingers.<br/>You take the notebook out of her hand and begin to read.<br/>You can read the entire thing in her voice somehow.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Oh Moon<br/>here we are again, or rather, here I am again.")
                                  wait {
                                    msg ("<br/>Staring at my, our green horizon that never seems to cross with your silver.<br/>And yet every now and then it looks like you're waiting for me there, due to a trick of the light.")
                                    wait {
                                      msg ("<br/>Then I hear Orpheus' sweet sounds rise once more from the gap between Life and Death.<br/>But Orpheus' tune is quickly twisted into something else.")
                                      wait {
                                        msg ("<br/>And then I'll be here and you’ll be there once again.<br/>I don't know whether to cry or laugh when I look at my, our, green horizon.")
                                        wait {
                                          msg ("<br/>All I know is that we better not listen to the dwindling of Orpheus' tune.<br/>Has something that has not been seen or heard really happened?")
                                          wait {
                                            SetForegroundColour ("Purple")
                                            msg ("<br/><br/><br/>When you get done reading your eyes linger on the notebook a bit longer before returning it to Lilith.")
                                            SetForegroundColour ("OrangeRed")
                                            msg ("So, what did you think of it?")
                                            SetForegroundColour ("Purple")
                                            msg ("She seems eager to find out what your thoughts are on her writing.")
                                            wait {
                                              MovePlayer (Burger_writing rating)
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              ]]></script>
                              <object name="Burger_writing rating">
                                <inherit name="scripttext" />
                                <options type="stringdictionary">
                                  <item>
                                    <key>Burger_writing impressed</key>
                                    <value>Wow, you really impressed me. That was fantastic!</value>
                                  </item>
                                  <item>
                                    <key>Burger_writing terrible</key>
                                    <value>That was really terrible.</value>
                                  </item>
                                </options>
                                <script type="script">
                                  SetForegroundColour ("DarkGreen")
                                </script>
                                <object name="Burger_writing impressed">
                                  <inherit name="scripttext" />
                                  <script type="script">
                                    SetForegroundColour ("Purple")
                                    msg ("A wide smile appears on Lilith's face.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Thanks! I'm glad you like it so much.")
                                    wait {
                                      MovePlayer (Brothertalk_of silence)
                                    }
                                  </script>
                                  <object name="Brothertalk_of silence">
                                    <inherit name="scripttext" />
                                    <script type="script"><![CDATA[
                                      ClearScreen
                                      if (GetBoolean(game, "Askedbrother")) {
                                        if (GetInt(game, "brotherask") = 0) {
                                          SetForegroundColour ("Purple")
                                          msg ("Lilith pauses for a moment.")
                                          wait {
                                            SetForegroundColour ("OrangeRed")
                                            msg ("You asked what my brother's name was, right?<br/>I don't know why but I feel like I can trust you enough to tell you about him.<br/><br/>I might tear up, it's been a long time since I've told his story to anyone.<br/>")
                                            SetForegroundColour ("OrangeRed")
                                            msg ("His... his name was James.")
                                            wait {
                                              SetForegroundColour ("OrangeRed")
                                              msg ("He was the best brother I could have asked for.<br/>He was five years older than me but we always played together.<br/>We used to be the best of friends, playing hide and seek, video games, making our own stories to act out, you name it.")
                                              wait {
                                                SetForegroundColour ("OrangeRed")
                                                msg ("<br/>He was always there for me, he supported me however he could and appreciated me.")
                                                SetForegroundColour ("Purple")
                                                msg ("When she talks about her brother you can see one of the biggest smiles you've ever seen growing on her face.")
                                                wait {
                                                  SetForegroundColour ("OrangeRed")
                                                  TextFX_Typewriter ("But that's when it happened...", 175)
                                                  wait {
                                                    SetForegroundColour ("Purple")
                                                    msg ("Lilith pauses for a moment as she gasps for air, you can see tears dripping off her face.")
                                                    wait {
                                                      SetForegroundColour ("OrangeRed")
                                                      msg ("<br/>He was only seventeen when he got hit by a speeding car.<br/>He didn't die immediately, they say he must have layed there for an hour before...")
                                                      wait {
                                                        SetForegroundColour ("OrangeRed")
                                                        msg ("<br/>My... father... couldn't accept James dying and left us.<br/>That day two people were stolen from me by a car.")
                                                        wait {
                                                          SetForegroundColour ("OrangeRed")
                                                          msg ("<br/>Mom really tried her best to fill the void left by them but the pressence of their absence has always haunted us since that horrible day.")
                                                          wait {
                                                            if (GetBoolean(game, "Abigailjoke")) {
                                                              SetForegroundColour ("OrangeRed")
                                                              msg ("My sister, Abigail,the one from the joke you just told,  is 5 years younger than me so she doesn't really remember much of what happened.")
                                                              wait {
                                                                TextFX_Typewriter ("Sometimes I envy her.", 140)
                                                              }
                                                            }
                                                            else {
                                                              SetForegroundColour ("OrangeRed")
                                                              msg ("My sister, Abigail, is 5 years younger than me so she doesn't really remember much of what happened.")
                                                              wait {
                                                                TextFX_Typewriter ("Sometimes I envy her.", 140)
                                                                wait {
                                                                  SetForegroundColour ("Purple")
                                                                  msg ("<br/><br/><br/>She lets out a sigh of relief.")
                                                                  SetForegroundColour ("OrangeRed")
                                                                  msg ("As much as it hurts me to talk about James it feels good to finally let it all out once again.<br/>Thank you for listening to me ramble on {player.alias}.")
                                                                  wait {
                                                                    MovePlayer (Burger shooting)
                                                                  }
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                        else {
                                          SetForegroundColour ("Purple")
                                          msg ("Lilith and you eat the rest of your burger and fries in pure silence.")
                                          msg ("She seems to look at her watch every minute or so, frowning each time.")
                                          wait {
                                            MovePlayer (Burger shooting)
                                          }
                                        }
                                      }
                                      else {
                                        msg ("Alternative dialog. (impossible to reach for now)")
                                      }
                                      SetCounter ("brotherask", 0)
                                    ]]></script>
                                    <object name="Burger shooting">
                                      <inherit name="scripttext" />
                                      <options type="stringdictionary">
                                        <item>
                                          <key>concern</key>
                                          <value>It's probably not our concern.</value>
                                        </item>
                                        <item>
                                          <key>sale</key>
                                          <value>Maybe there is just a really good sale going on somewhere?</value>
                                        </item>
                                      </options>
                                      <script type="script">
                                        SetForegroundColour ("Purple")
                                        msg ("Suddenly you hear screaming from a few shops further.")
                                        SetForegroundColour ("OrangeRed")
                                        msg ("What was that?")
                                        if (GetBoolean(game, "shootknowledge")) {
                                          AddPageLink (Burger shooting, Burger_Death 1 prevented, "This is important, duck now.")
                                        }
                                        SetForegroundColour ("DarkGreen")
                                      </script>
                                      <object name="concern">
                                        <inherit name="scripttext" />
                                        <script type="script">
                                          SetForegroundColour ("OrangeRed")
                                          msg ("You're probably right, it's probably not even a big deal anyway.")
                                          AddPageLink (concern, Burger_Death 1, "Yeah-")
                                        </script>
                                      </object>
                                      <object name="sale">
                                        <inherit name="scripttext" />
                                        <script type="script">
                                          msg ("Let's hope it's just that.")
                                          AddPageLink (sale, Burger_Death 1, "Yeah-")
                                        </script>
                                      </object>
                                    </object>
                                  </object>
                                </object>
                                <object name="Burger_writing terrible">
                                  <inherit name="scripttext" />
                                  <script type="script"><![CDATA[
                                    IncreaseCounter ("brotherask")
                                    SetForegroundColour ("Purple")
                                    msg ("Lilith begins to frown slightly.<br/>She looks hurt by your words.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("Oh... <br/>No need to be a douche about it.")
                                    wait {
                                      MovePlayer (Brothertalk_of silence)
                                    }
                                  ]]></script>
                                </object>
                              </object>
                            </object>
                          </object>
                        </object>
                      </object>
                    </object>
                    <object name="Burger_unemployed">
                      <inherit name="scripttext" />
                      <script type="script">
                        SetForegroundColour ("OrangeRed")
                        msg ("Oh, do you like to write? That's pretty cool!")
                        SetForegroundColour ("Purple")
                        msg ("Lilith seems to be quite enthusiastic, her eyes have a certain shimmer to them that wasn't there just a moment ago.")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("I also like to write something from time to time, it's one of my hobby's actually.")
                          MovePlayer (Burger_unemployed_choice)
                        }
                      </script>
                    </object>
                  </object>
                </object>
              </object>
              <object name="Burger_pointless joke">
                <inherit name="scripttext" />
                <script type="script">
                  MovePlayer (Burger_joke response)
                </script>
              </object>
              <object name="Burger_click joke">
                <inherit name="scripttext" />
                <script type="script">
                  MovePlayer (Burger_joke response)
                </script>
              </object>
              <object name="Burger_Abigail joke">
                <inherit name="scripttext" />
                <script type="script"><![CDATA[
                  SetForegroundColour ("Purple")
                  msg ("Lilith bursts out in laughter.")
                  SetForegroundColour ("OrangeRed")
                  msg ("I really love that joke, my sister Abigail told me it once and I kept laughing and laughing for hat seemed like an eternity.<br/>Just thinking about it again, it fills me with a warm feeling, like a blanket you wrap around yourself in the coldest of winters.")
                  wait {
                    msg ("<br/>Thank you for cracking me up {player.alias}!")
                    SetForegroundColour ("Purple")
                    msg ("Lilith flashes you a cute smile, she seems pretty much completely composed once again.")
                    MovePlayer (Burger what do you do for a living)
                  }
                ]]></script>
              </object>
            </object>
          </object>
        </object>
        <object name="Burger_unemployed_choice">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Burger let Lilith show you her writing</key>
              <value>Would you like to show me something you've written?</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
        </object>
      </object>
      <object name="Burger_Death 1">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          SetForegroundColour ("Purple")
          msg ("Now the screaming is also paired with hellish sounds, just great.")
          msg ("You look at Lilith and tell her to hide under the table.")
          SetForegroundColour ("OrangeRed")
          msg ("I...")
          SetForegroundColour ("Purple")
          msg ("Lilith seems to be frozen, on her face you can clearly see a mixture of fear and confusion.")
          msg ("It takes you a moment to notice the steadily increasing red stains on Lilith's clothes.")
          SetForegroundColour ("OrangeRed")
          msg ("I've been shot?")
          SetForegroundColour ("Purple")
          msg ("She falls of her chair, you crawl towards her and try to call an ambulance.")
          msg ("With trembling hands you type the emergency-number and beg for help.")
          msg ("Everything seems to fade away, even the continuous  barage of gunshots, all you can hear is the sound of Lilith's breathing as it gets harder and harder for her to live.")
          msg ("You've been here for what feels for aeons but in all reality was probably 5 minutes when an ambulance finally arives.")
          msg ("A young man with eyes that have grown old from all the things they saw places Liliths still body on a stretcher and rushes off with it to the ambulance.")
          msg ("The kind man throws some words at you, he tells you that everything will be just fine but you both know that he is lying.<br/>You have see her suffering for what seemed like an eternity and a second at the same time.")
          msg ("You've gotten no clue what caused all those gunshots that inadvertently killed her. Some robbery in a neighbouring store, or a gang war, or something else.")
          msg ("But sadly you do know what the aftermath of it all is .")
          SetFontSize (29)
          msg ("Game over")
          SetFontSize (13)
          msg ("Your date surely didn't go as planned.")
          SetFlagOn ("shootknowledge")
          SetFontSize (12)
          AddPageLink (Burger_Death 1, Gamestart, "Retry")
          SetForegroundColour ("OrangeRed")
        ]]></script>
        <object name="Burger_Death 1 prevented">
          <inherit name="scripttext" />
          <options type="stringdictionary" />
          <script type="script">
            SetForegroundColour ("Purple")
            msg ("Lilith gives you a sceptical look but decides to follow your instructions, right as she does so a bullet flies where she would have been if you didn't warn her.")
            SetForegroundColour ("OrangeRed")
            msg ("Alright that is crazy, how did you know that bullet would hit me?")
            wait {
              MovePlayer (Burger_death_one_prevented_explaining)
            }
          </script>
          <object name="Burger_death_one_prevented_explaining">
            <inherit name="scripttext" />
            <options type="stringdictionary">
              <item>
                <key>Cafe_Groundhog</key>
                <value>I'm basically living in some sort of groundhog day scenario.</value>
              </item>
            </options>
            <script type="script">
              SetForegroundColour ("DarkGreen")
            </script>
            <object name="Burger_Groundhog" />
            <object name="Burger_escape fate">
              <inherit name="scripttext" />
              <options type="stringdictionary">
                <item>
                  <key>Burger_Groundhog_it has to do with me</key>
                  <value>I think it has to do with me, everytime we are together you seem to end up dying.</value>
                </item>
                <item>
                  <key>Burger_Groundhog_fate seems to want it</key>
                  <value>It seems like fate wants it for some reason.</value>
                </item>
              </options>
              <script type="script"><![CDATA[
                SetForegroundColour ("OrangeRed")
                msg ("So I keep dying? Interesting...<br/>Before that stray bullet I never really got in close contact with death.")
                SetForegroundColour ("Purple")
                msg ("Lilith scratches her head.")
                SetForegroundColour ("OrangeRed")
                msg ("So, why do you think I keep dying all of the sudden?")
                SetForegroundColour ("DarkGreen")
              ]]></script>
              <object name="Burger_Groundhog_it has to do with me">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Lilith bursts out laughing.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("Sorry, it's still a bit much to take in right now.")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("So, our dates always end up killing me, right?")
                      msg ("Have you ever considerd not dating me?")
                      wait {
                        MovePlayer (Burger_Groundhog it has to do with me answers)
                      }
                    }
                  }
                </script>
                <object name="Burger_Groundhog it has to do with me answers">
                  <inherit name="scripttext" />
                  <options type="stringdictionary">
                    <item>
                      <key>Burger_groundhog_but i love you</key>
                      <value>But I love spending time with you, I'd hate to have to throw all of that away.</value>
                    </item>
                    <item>
                      <key>Burger_groundhog I did no</key>
                      <value>I haven't tried that yet actually.</value>
                    </item>
                  </options>
                  <script type="script">
                    if (GetBoolean(game, "failedwarning")) {
                      AddPageLink (Burger_Groundhog it has to do with me answers, Burger_I tried to actually, "Actually I tried to warn you about your death, tried to break up with you, tried just not showing up but it all ended with you dying either way.")
                    }
                    SetForegroundColour ("DarkGreen")
                  </script>
                  <object name="Burger_I tried to actually" />
                  <object name="Burger_groundhog_but i love you">
                    <inherit name="scripttext" />
                    <script type="script"><![CDATA[
                      SetForegroundColour ("OrangeRed")
                      msg ("Well, I also like spending time with you...")
                      wait {
                        msg ("It would be a shame if we had to sacrifice it all.")
                        msg ("Besides, wheter you would or not do that, I would never know about it or this conversation.")
                        SetForegroundColour ("Purple")
                        msg ("Lilith lets out a little laugh.")
                        SetForegroundColour ("OrangeRed")
                        msg ("Funny how those things work right?")
                        wait {
                          SetForegroundColour ("Purple")
                          msg ("Lilith scratches her head.")
                          SetForegroundColour ("OrangeRed")
                          msg ("But if all else really fails we might have to consider not seeing eachother again.")
                          SetForegroundColour ("Purple")
                          msg ("She lets out a big sigh.")
                          wait {
                            SetForegroundColour ("OrangeRed")
                            msg ("However, I have a feeling that there must be another way to solve our little problem, I'm practically sure of it!<br/>If all else fails we'll just have to confront the Moirai themselves!")
                            SetForegroundColour ("Purple")
                            msg ("She seems to be taking all of this pretty well for a woman who just heard that she dies repeatedly.")
                            wait {
                              MovePlayer (Burger_death two gasexplosion)
                            }
                          }
                        }
                      }
                    ]]></script>
                  </object>
                  <object name="Burger_groundhog I did no">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>Burger_That means we will no know eachother</key>
                        <value>That means we won't know eachother like this, if the loop breaks I will not have been on this date with you. </value>
                      </item>
                    </options>
                    <script type="script">
                      SetForegroundColour ("OrangeRed")
                      msg ("Well, maybe that's worth looking into then even though it's probably quite a long shot.")
                      SetForegroundColour ("DarkGreen")
                    </script>
                    <object name="Burger_That means we will no know eachother">
                      <inherit name="scripttext" />
                      <script type="script"><![CDATA[
                        SetForegroundColour ("Purple")
                        msg ("Lilith rubs her chin for a moment.")
                        SetForegroundColour ("OrangeRed")
                        msg ("Hmm, I suppose you are right...")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("Once you manage to break the loop by not showing up or something like that I wouldn't want to have something to do with you in the first place.")
                          wait {
                            SetForegroundColour ("OrangeRed")
                            msg ("Besides, even then I doubt you would be able to convince me about this whole groundhog day thingy.<br/>You wouldn't be able to relive that moment anymore so your tricks would quite literally be useless ")
                            SetForegroundColour ("Purple")
                            msg ("Lilith looks saddened for a moment before she tries to give you a wide smile, you can tell it's quite forced.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("You know, I got a feeling that won't be the case so you can always give it a shot if you want.")
                              SetForegroundColour ("Purple")
                              msg ("She grows slilent for a moment.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("But just in case something does end up happening and causes you to never be able to see me again.")
                                wait {
                                  TextFX_Typewriter ("I want you to know that I really liked our time together...", 133)
                                  wait {
                                    MovePlayer (Burger_death two gasexplosion)
                                  }
                                }
                              }
                            }
                          }
                        }
                      ]]></script>
                    </object>
                  </object>
                </object>
              </object>
              <object name="Burger_Groundhog_fate seems to want it">
                <inherit name="scripttext" />
                <options type="stringdictionary">
                  <item>
                    <key>Burger_escape fate</key>
                    <value>Go back.</value>
                  </item>
                </options>
                <script type="script">
                  SetForegroundColour ("LightGreen")
                  msg ("This branch still needs work so it's not ready.")
                </script>
              </object>
            </object>
            <object name="Burger_death two gasexplosion">
              <inherit name="scripttext" />
              <script type="script">
                SetForegroundColour ("Purple")
                msg ("Suddenly a inmense sensation of pain overwhelms you, the only thing you can see is a glimpse of pure white and an eternity of black.")
                msg ("When you awaken you find yourself surrounded by doctors, they tell you that with the force of sheer luck the stray bullet that would've hit Lilith managed to cause a gas leak.")
                msg ("The gas explosion that followed was quite severe, you were in a coma and had to have your wounds cleaned with some surgical procedures.")
                msg ("After a week you got out of your coma, Lilith however didn't have such luck.")
                msg ("The doctors tell you that she atleast went out pretty quickly, almost like dying in your sleep but with more explosions.")
                SetFlagOn ("gasknowledge")
                SetFontSize (29)
                msg ("Game over")
                SetFontSize (13)
                msg ("Your date surely didn't go as planned.")
                SetFontSize (12)
              </script>
            </object>
          </object>
        </object>
      </object>
      <object name="Burger ordering scene">
        <inherit name="scripttext" />
        <script type="script">
          SetForegroundColour ("LightGreen")
          msg ("Add a scene describing you getting the burgers ordered with Lilith. ")
          SetForegroundColour ("OrangeRed")
          MovePlayer (Burger_brother)
        </script>
      </object>
      <object name="Burger selection menu">
        <inherit name="scripttext" />
        <options type="stringdictionary">
          <item>
            <key>Burger_burger choice</key>
            <value>I could go for a veggie burger!</value>
          </item>
          <item>
            <key>Burger_burger choice1</key>
            <value>Hmm, that juicy cheeseburger sounds really good!</value>
          </item>
          <item>
            <key>Burger_burger choice2</key>
            <value>I think I'll pick the fish burger.</value>
          </item>
          <item>
            <key>Burger_burger choice3</key>
            <value>A beef burger sounds good.</value>
          </item>
        </options>
        <script type="script">
          SetForegroundColour ("DarkGreen")
        </script>
        <object name="Burger_burger choice">
          <inherit name="scripttext" />
          <script type="script">
            MovePlayer (Burger ordering scene)
          </script>
        </object>
        <object name="Burger_burger choice1">
          <inherit name="scripttext" />
          <script type="script">
            MovePlayer (Burger ordering scene)
          </script>
        </object>
        <object name="Burger_burger choice2">
          <inherit name="scripttext" />
          <script type="script">
            MovePlayer (Burger ordering scene)
          </script>
        </object>
        <object name="Burger_burger choice3">
          <inherit name="scripttext" />
          <script type="script">
            MovePlayer (Burger ordering scene)
          </script>
        </object>
      </object>
      <object name="Burger restaurant">
        <inherit name="scripttext" />
        <options type="stringdictionary">
          <item>
            <key>Burger_I will always come for burgers</key>
            <value>I can't say no to burgers!</value>
          </item>
          <item>
            <key>Burger_traffic was bad</key>
            <value>Sorry, the traffic was pretty bad.</value>
          </item>
          <item>
            <key>Burger_do no want to miss this for the world</key>
            <value>Sorry, wouldn't want to miss this for the world.</value>
          </item>
        </options>
        <script type="script">
          SetFlagOn ("Burger")
          SetForegroundColour ("OrangeRed")
          msg ("Burgers sure sound good, see you there!")
          SetForegroundColour ("Purple")
          msg ("You arrive a tad late, Lilith already has grabbed herself a seat and waves at you when she sees you.")
          SetForegroundColour ("OrangeRed")
          msg ("Heya! Almost was scared you wouldn't show up.")
          SetFlagOn ("burger")
          firsttime {
            SetCounter ("burger", 0)
          }
          otherwise {
            IncreaseCounter ("burger")
          }
        </script>
        <object name="Burger_I will always come for burgers">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Burger_This is the first time</key>
              <value>This is actually the first time I've eaten here.</value>
            </item>
            <item>
              <key>Burger_I have been here before</key>
              <value>I have been here before already.</value>
            </item>
          </options>
          <script type="script"><![CDATA[
            SetForegroundColour ("Purple")
            msg ("Lilith chuckles.")
            SetForegroundColour ("OrangeRed")
            msg ("Ah, another burger fan!")
            msg ("We are at the right place I'd say, the burgers here are delicious.")
            msg ("Did you already know that or is this the first time you've eaten here?")
            if (GetInt(game, "burger") = 0) {
              RemovePageLink (Burger_I will always come for burgers, Burgers_About x times exactly)
            }
            else if (GetInt(game, "burger") = 1) {
              AddPageLink (Burger_I will always come for burgers, Burgers_About x times exactly, "I've been here only once.")
            }
            else if (GetInt(game, "burger") > 1) {
              AddPageLink (Burger_I will always come for burgers, Burgers_About x times exactly, "I've been here exactly {counter:burger} times.")
            }
          ]]></script>
          <object name="Burger_This is the first time">
            <inherit name="scripttext" />
            <script type="script"><![CDATA[
              SetForegroundColour ("OrangeRed")
              msg ("Oh, I'm sure you'll love it here then!<br/>Like I've said before, they have really amazing bugers here.")
              SetForegroundColour ("Purple")
              msg ("Lilith pauses for a moment.")
              wait {
                SetForegroundColour ("OrangeRed")
                msg ("So, which burger do you want to pick? I think I'll go for the juicy cheeseburger myself.")
                MovePlayer (Burger selection menu)
              }
            ]]></script>
          </object>
          <object name="Burger_I have been here before">
            <inherit name="scripttext" />
            <script type="script"><![CDATA[
              SetForegroundColour ("OrangeRed")
              if (HasSeenPage(Burger_I have been here before)) {
                SetForegroundColour ("OrangeRed")
                msg ("Somehow, from the look in your eyes, I can see you actually have been here before.<br/>You look at this place as if you've already seen it before if that makes sense.")
                SetForegroundColour ("Purple")
                msg ("Lilith lets out a small giggle.")
                wait {
                  SetForegroundColour ("OrangeRed")
                  msg ("Sorry if that came out as weird, I'm just enthusiastic about this place.")
                  msg ("But anyway, what do you want to eat? I think I'll pick the juicy cheeseburger, the cheese is delicously melted!")
                  MovePlayer (Burger selection menu)
                }
              }
              else {
                SetForegroundColour ("OrangeRed")
                msg ("That's pretty cool!")
                SetForegroundColour ("Purple")
                msg ("Almost shouting those words, she seems really passionate about burgers for some reason.")
                SetForegroundColour ("OrangeRed")
                wait {
                  msg ("Sorry if that came out a bit too strong, I just really like this place.")
                  msg ("But anyway, what do you want to eat? I think I'll pick the juicy cheeseburger, the cheese is delicously melted!")
                  MovePlayer (Burger selection menu)
                }
              }
            ]]></script>
          </object>
          <object name="Burgers_About x times exactly">
            <inherit name="scripttext" />
            <script type="script"><![CDATA[
              if (GetInt(game, "burger") = 0) {
                SetForegroundColour ("OrangeRed")
                msg ("So... it's your first time with other words?<br/>I'm sure you'll love it here then!<br/>Like I've said before, they have really amazing bugers here.")
                SetForegroundColour ("Purple")
                msg ("Lilith pauses for a moment.")
                wait {
                  SetForegroundColour ("OrangeRed")
                  msg ("So, which burger do you want to pick? I think I'll go for the juicy cheeseburger myself.")
                  MovePlayer (Burger selection menu)
                }
              }
              else if (GetInt(game, "burger") > 3) {
                if (GetInt(game, "burger") > 6) {
                  if (GetInt(game, "burger") > 9) {
                    if (GetInt(game, "burger") > 12) {
                      if (GetInt(game, "burger") > 22) {
                        SetForegroundColour ("OrangeRed")
                        msg ("Wow!  Almost feel like I should let you choose my burger with all that burger knowledge you must have.")
                        SetForegroundColour ("Purple")
                        msg ("Lilith lets out a joyful laugh.")
                        SetForegroundColour ("OrangeRed")
                        msg ("Almost though, not completely.")
                      }
                      else {
                        SetForegroundColour ("OrangeRed")
                        msg ("Wow... is it weird to be impressed by that?")
                        SetForegroundColour ("Purple")
                        msg ("Lilith lets out a small laugh.")
                        SetForegroundColour ("OrangeRed")
                        msg ("Probably but still, I'm quite impressed by the effort you made.")
                      }
                    }
                    else {
                      SetForegroundColour ("OrangeRed")
                      msg ("Wow, you've been here a lot of times!<br/>... Come to think of it, you might have visited this place more than I have.")
                      SetForegroundColour ("Purple")
                      msg ("Lilith lets out a small giggle.")
                    }
                  }
                  else {
                    SetForegroundColour ("OrangeRed")
                    msg ("Wow, you've been here quite a few times already!<br/>You must really like it here then, I knew we were on the same wavelength.")
                  }
                }
                else {
                  SetForegroundColour ("OrangeRed")
                  msg ("Ah, you've been here a few times already.<br/>Then you surely now how good the burgers are here.")
                }
              }
              else {
                if (GetInt(game, "burger") = 1) {
                  SetForegroundColour ("OrangeRed")
                  msg ("Ah, I hope you liked your previous meal here!")
                }
                else {
                  SetForegroundColour ("OrangeRed")
                  msg ("Ah, I hope you liked your previous meals here!")
                }
              }
              wait {
                SetForegroundColour ("OrangeRed")
                msg ("So, which burger do you want to pick? I think I'll go for the juicy cheeseburger myself.")
                MovePlayer (Burger selection menu)
              }
            ]]></script>
          </object>
        </object>
        <object name="Burger_traffic was bad">
          <inherit name="scripttext" />
          <script type="script">
            SetForegroundColour ("OrangeRed")
            msg ("Now that you mention it, I think I heard something about it on the radio, they said some ghostrider caused  the traffic jam.")
            wait {
              msg ("Anyway, what do you want to order of the menu?  I think I am going to go with a juicy cheesburger.")
              MovePlayer (Burger selection menu)
            }
          </script>
        </object>
        <object name="Burger_do no want to miss this for the world">
          <inherit name="scripttext" />
          <script type="script"><![CDATA[
            SetForegroundColour ("OrangeRed")
            msg ("Awwe, I'm flattered you are so happy to see me.<br/>Or is it the burgers you don't want to miss?")
            SetForegroundColour ("Purple")
            msg ("Lilith chuckles slightly.")
            wait {
              SetForegroundColour ("OrangeRed")
              msg ("Sorry, I'm just messing with you.")
              wait {
                msg ("So, what do you want to order of the menu?  I think I am going to go with a juicy cheesburger.")
                MovePlayer (Burger selection menu)
              }
            }
          ]]></script>
        </object>
      </object>
      <object name="Cafe_Death_two">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          ClearScreen
          SetForegroundColour ("Purple")
          msg ("Suddenly you begin to hear the sound of shattering glass.<br/>As you turn to look at the source of the sound you can see that the aquarium next to where Lilith was sitting has shattered.<br/>The water is gushing out rapidly and it does not seem to be planning to stop.<br/>It seems as if somehow the marlin must have made a crack form.<br/>You think about the pure shenanigans that were needed to even make this exact thing happen but you are soon interrupted by the water flowing past your shoes with some fish coming along for the ride.<br/>")
          SetForegroundColour ("OrangeRed")
          msg ("Quick {player.alias}, we need to do something!")
          if (GetBoolean(game, "drownknowledge")) {
            SetForegroundColour ("Purple")
            msg ("You try to open the main exit of the restaurant but it doesn't seem to be giving in, almost as if something is blocking it.")
            SetForegroundColour ("OrangeRed")
            msg ("Quick! Maybe we can still go to the first floor, we need to go higher!")
            SetForegroundColour ("Purple")
            msg ("Pretty much without any other option you two decide to make a rush for the first floor of the restaurant. <br/>When you turn around the corner you see that the stairs are blocked of by an extremely large closet made out of lignum vitae, you can not carry that, all you can do is admire the craftmanship.<br/>You give Lilith a firm hug and tell her that there's nothing else you two can do except for waiting.<br/>And so the both of you wait, in eachothers arms, for certain death.<br/>And it comes as expected.")
          }
          else {
            SetForegroundColour ("Purple")
            msg ("You give Lilith a firm hug and tell her that there's nothing else you two can do except for waiting.<br/>")
            if (GetBoolean(game, "Lilithlike")) {
              SetForegroundColour ("OrangeRed")
              msg ("If I have to go now I atleast get some comfort out of the fact that you are here for me.")
              if (GetBoolean(game, "groundhog")) {
                msg ("add different ending greet depending on wich excuse you gave.")
              }
              else {
                msg ("Goodbye {player.alias}, thank you for everything.")
              }
            }
            else {
              SetForegroundColour ("Purple")
              msg ("And so the both of you wait, in eachothers arms, for certain death.<br/>And it comes as expected.")
            }
          }
          SetFontSize (29)
          msg ("Game over")
          SetFontSize (13)
          msg ("Your date surely didn't go as planned.")
          SetFlagOn ("drownknowledge")
          SetFontSize (12)
          AddPageLink (Cafe_Death_two, Gamestart, "Retry")
          SetForegroundColour ("Purple")
          IncreaseCounter ("Lildeaths")
          IncreaseCounter ("drowndeaths")
        ]]></script>
      </object>
      <object name="Cafe_death_one_prevented">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          SetForegroundColour ("Purple")
          msg ("Lilith gives you a questioning look, as if she's trying to estimate if you are joking or not.")
          wait {
            msg ("Eventually she decides to not take any chances. <br/>She stands up and moves to your side of the table.")
            wait {
              SetForegroundColour ("OrangeRed")
              msg ("So...")
              wait {
                msg ("What is this all about {player.alias}?")
                wait {
                  SetForegroundColour ("Purple")
                  msg ("Before you can answer her question you hear someone scream again, that's the sign.<br/>You turn your head just quick enough to see someone fall with a plate in their hands.")
                  msg ("The plate flies in the air, with it the ham sandwich that was put on top of it.")
                  msg ("You are not the only one who has noticed, as you can see a beautiful blue marlin jump from an opening in the aquarium.")
                  msg ("The marlin has a long and pointy bill, it pierces the sandwich in a feat of pure dexterity. ")
                  msg ("It's current trajectory leads it to pierce through the chair where Lilith was sitting just mere moments ago.")
                  msg ("The staff quickly rush towards your table to take the marlin away and to see if it hasn't been hurt, they offer Lilith and you a short apology before disappearing.")
                  wait {
                    ClearScreen
                    SetForegroundColour ("OrangeRed")
                    msg ("...")
                    SetForegroundColour ("Purple")
                    msg ("Lilith looks as if she has seen a ghost, if you hadn't intervened she may have seen her own.")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("Alright, I'm trying my best to remain calm but how did you know that exact scenario would happen?")
                      MovePlayer (Cafe_death_one_prevented_explaining)
                    }
                  }
                }
              }
            }
          }
        ]]></script>
        <object name="Cafe_death_one_prevented_explaining">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Cafe_Groundhog</key>
              <value>I'm basically living in some sort of groundhog day scenario.</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
        </object>
      </object>
      <object name="gallery">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          ClearScreen
          SetForegroundColour ("Purple")
          msg ("Ah, the gallery. A place where hopes and dreams come to live and die.<br/>This place is stocked with all sorts of things so have fun exploring!")
        ]]></script>
      </object>
      <object name="Aquarium cafe">
        <inherit name="scripttext" />
        <sound type="string"></sound>
        <continuesound />
        <script type="script"><![CDATA[
          SetFlagOn ("Cafe")
          if (not GetBoolean(game, "Cafe_taste")) {
            SetForegroundColour ("OrangeRed")
            msg ("That sounds good to me! I'll meet you there!<br/>")
          }
          else {
            SetForegroundColour ("OrangeRed")
            msg ("Oh my, you surely know how to get me excited! I'll meet you there!<br/>")
          }
          wait {
            ClearScreen
            wait {
              SetForegroundColour ("Purple")
              msg ("You arrive a tad too early and find no space to park so you decide to park a few streets later and walk to the cafe.")
              wait {
                msg ("The walls are made out of glass and function as aquariums that seem to stretch on even beyond the ceiling.")
                wait {
                  msg ("There are some holes in the specially shaped aquarium to allow for easy feeding of the fish and it also makes the aquarium feel more alive, with colorful fish sometimes poking their head out of the aquarium as if they want to watch the customers, maybe you are the one in the glass cage and you just don't know it.<br/>")
                  wait {
                    msg ("It's probably them though, atleast they seem to be enjoying themselves.")
                    wait {
                      msg ("When you get there Lilith is already sitting at a nice looking mahogany table.")
                      wait {
                        msg ("When she notices you she waves at you enthusiastically with a wide grin on her face.")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("Heya, glad you could make it! ")
                          wait {
                            msg ("This place has a really nice atmosphere, those mahogany tables and the aquariums are real eye catchers don't you think?")
                            wait {
                              msg ("Anyway, let's go order our food and then we can talk some more.")
                              SetForegroundColour ("Purple")
                              wait {
                                msg ("You and Lilith walk towards the barista, as he glances up from his phone he greets you with a shy smile.<br/>He looks quite young, if you'd have to guess you would say he is somewhere between 17 and 18 years old.<br/>You get lost in the thoughts of how life was when you still were 17 until Lilith gives you a playful nudge.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("The barista looks at the both of you and asks: \"What can I get for you?\" ")
                                  wait {
                                    SetForegroundColour ("OrangeRed")
                                    msg (" Hmm, I think I'm going for the ham and cheese sandwich and a cafe cubano.<br/> What are you choosing? ")
                                    MovePlayer (Aquarium food choice)
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]]></script>
        <object name="Aquarium food choice">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Cafe_same food</key>
              <value>I'll have the same as you.</value>
            </item>
            <item>
              <key>Cafe_daysandwichespresso</key>
              <value>I'll have the sandwich of the day and an espresso.</value>
            </item>
            <item>
              <key>Cafe_frap</key>
              <value>I'll have the beef sandwich and a frappuchino.</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
          <object name="Cafe_same food">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("The barista smiles and says: \"Coming right up!\"")
              msg ("Lilith and you walk back to your table and take a seat.")
              SetFlagOn ("Cafe_same food")
              wait {
                ClearScreen
                MovePlayer (Cafe_waiting on food)
              }
            </script>
          </object>
          <object name="Cafe_frap">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("The barista smiles and says: \"Coming right up!\"")
              msg ("Lilith and you walk back to your table and take a seat.")
              SetFlagOn ("Cafe_frap")
              wait {
                ClearScreen
                MovePlayer (Cafe_waiting on food)
              }
            </script>
          </object>
          <object name="Cafe_daysandwichespresso">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("The barista smiles and says: \"Coming right up!\"")
              msg ("Lilith and you walk back to your table and take a seat.")
              SetFlagOn ("Cafe_daysandwich")
              wait {
                ClearScreen
                MovePlayer (Cafe_waiting on food)
              }
            </script>
          </object>
          <object name="Cafe_waiting on food">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("Lilith looks around in pure awe, a bright smile forms on her face.")
              SetForegroundColour ("OrangeRed")
              wait {
                msg ("So, what do you think of this place now that you've seen it for the first time?")
                MovePlayer (rate_the_cafe)
              }
            </script>
            <object name="rate_the_cafe">
              <inherit name="scripttext" />
              <options type="stringdictionary">
                <item>
                  <key>Cafe_great</key>
                  <value>It's fantastic! Look at all those fish!</value>
                </item>
                <item>
                  <key>Cafe_bad</key>
                  <value>This cafe really sucks.</value>
                </item>
                <item>
                  <key>Cafe_okayish</key>
                  <value>I can see why you like it but it's not really my thing.</value>
                </item>
              </options>
              <script type="script">
                SetForegroundColour ("DarkGreen")
                if (GetBoolean(game, "swordknowledge")) {
                  AddPageLink (rate_the_cafe, Cafe_not first time i see, "Actually it's not the first time I've seen this place.")
                }
              </script>
              <object name="Cafe_great">
                <inherit name="scripttext" />
                <script type="script"><![CDATA[
                  SetForegroundColour ("Purple")
                  msg ("Lilith let's out a small giggle.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg (" I knew you would love it as much as me when I saw your smile.<br/>I've never seen so many colors at the same time, thank you for taking me here {player.alias}!<br/>Just the fish on their own made this one of the best dates I ever had, it can only get better from here.")
                    MovePlayer (Cafe_great_choices)
                  }
                  SetFlagOn ("Cafe_taste")
                ]]></script>
                <object name="Cafe_great_choices">
                  <inherit name="scripttext" />
                  <options type="stringdictionary">
                    <item>
                      <key>Bad_love_experiences</key>
                      <value>Sorry to ask you this, but did you have bad experiences in love?</value>
                    </item>
                    <item>
                      <key>You are welcome cafe</key>
                      <value>You are very welcome, thank you for making me come here in the first place.</value>
                    </item>
                  </options>
                  <script type="script">
                    SetForegroundColour ("Green")
                  </script>
                  <object name="Bad_love_experiences">
                    <inherit name="scripttext" />
                    <options type="stringdictionary" />
                    <script type="script"><![CDATA[
                      SetForegroundColour ("OrangeRed")
                      msg ("Well...")
                      wait {
                        msg ("I wouldn't say I had really bad experiences with love. It's just that I tend to grow connected with people before they even had the chance to grow fond of me.<br/>I also do not need to be with someone every single moment, both as a friend or lover, once I'm connected I start to sort of withdraw a little bit.<br/>")
                        wait {
                          msg ("In the beginning I thought that I was weird for acting that way, I started trying to make sure that I didn't distance myself from anyone so I wouldn't hurt them.<br/>Of course this only made things worse, soon I began having almost no confidence in myself and messed up quite a few relationships and friendships.<br/>")
                          wait {
                            msg ("It took me a while before I managed to find the courage in myself to try and fix my problems.<br/>It didn't happen instantly, even now I sometimes come of as too distant, but little by little I managed to tell myself that there is nothing wrong with not needing an overdose of affection every second.<br/>")
                            wait {
                              msg ("So, did I have bad experiences in love? <br/>Maybe, but they were all quite necessary as without them I wouldn't be here with you today, I wouldn't even be if that makes sense.<br/>Sorry for blabbering on by the way, I'm quite talkative when you get me going.")
                              SetForegroundColour ("DarkGreen")
                              MovePlayer (Cafe_I like to listen)
                            }
                          }
                        }
                      }
                    ]]></script>
                    <object name="Cafe_I no mind you talk">
                      <inherit name="scripttext" />
                      <script type="script"><![CDATA[
                        ClearScreen
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("Oh you flatterer! ")
                          wait {
                            SetForegroundColour ("Purple")
                            msg ("Lilith looks at you and gives you a big grin, you can clearly see she's blushing.<br/>Suddenly the grin begins to make place for a slight frown.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("Is it normal for me to be that happy because someone told me they don't mind me speaking?")
                              msg ("...")
                              wait {
                                msg ("I... kind of struggle with self-confidence.")
                                msg ("Sometimes I think other people find it a burden to talk to me or be around me at all.")
                                MovePlayer (Cafe_comfort)
                              }
                            }
                          }
                        }
                      ]]></script>
                      <object name="Cafe_comfort">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>Cafe_I really like you</key>
                            <value>Well, I really enjoy our time together!</value>
                          </item>
                        </options>
                        <script type="script">
                          SetForegroundColour ("DarkGreen")
                          if (GetBoolean(game, "swordknowledge")) {
                            AddPageLink (Cafe_comfort, Cafe_death_one_prevented, "Quick, come stand next to me!")
                          }
                        </script>
                        <object name="Cafe_I really like you">
                          <inherit name="scripttext" />
                          <script type="script">
                            SetForegroundColour ("OrangeRed")
                            msg ("Thank you {player.alias}, it really helps to hear someone say that from time to time.")
                            SetForegroundColour ("Purple")
                            msg ("Lilith gives give a thankfull smile.")
                            wait {
                              MovePlayer (Cafe_Death_one)
                            }
                          </script>
                        </object>
                      </object>
                    </object>
                    <object name="Cafe_I like to listen">
                      <options type="stringdictionary">
                        <item>
                          <key>Cafe_I no mind you talk</key>
                          <value>No need to apologise for talking, I like listening to you.</value>
                        </item>
                      </options>
                    </object>
                  </object>
                  <object name="You are welcome cafe">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>I want to hear your joke</key>
                        <value>Sure, I'd like that!</value>
                      </item>
                    </options>
                    <script type="script">
                      SetForegroundColour ("OrangeRed")
                      msg ("Well, in that case I'll retaliate with a \"You are very welcome.\" aswell!")
                      SetForegroundColour ("Purple")
                      msg ("Lilith let's out a small giggle.")
                      SetForegroundColour ("OrangeRed")
                      msg ("Do you want to hear a joke?")
                      SetForegroundColour ("DarkGreen")
                    </script>
                    <object name="I want to hear your joke">
                      <inherit name="scripttext" />
                      <options type="stringdictionary">
                        <item>
                          <key>Not getting joke</key>
                          <value>Hmm, I'm not sure I'm getting the joke.</value>
                        </item>
                        <item>
                          <key>Funny joke</key>
                          <value>Wow, that was a really good one!</value>
                        </item>
                        <item>
                          <key>Bad joke</key>
                          <value>That was not funny at all.</value>
                        </item>
                      </options>
                      <script type="script"><![CDATA[
                        SetForegroundColour ("OrangeRed")
                        msg ("So a priest, a monk and a rabbit enter a bar.<br/>Says the rabbit :\"Whoops, did you slip your tongue there Lilith?\"")
                        SetForegroundColour ("DarkGreen")
                        SetFlagOn ("jokeknowledge")
                      ]]></script>
                      <object name="Funny joke">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>Cafe_Death_one</key>
                            <value>She sounds nice!</value>
                          </item>
                        </options>
                        <script type="script"><![CDATA[
                          SetForegroundColour ("Purple")
                          msg ("Lilith explodes in laughter.")
                          wait {
                            SetForegroundColour ("OrangeRed")
                            msg ("Exactly! The first time Abigail, my sister, told me that joke I spent an entire hour laughing.<br/>But then again, she always makes me laugh so much that I just might pass out one time.")
                            wait {
                              msg ("I'm kidding, I'm kidding! About the passing out part that is, she really is funny though.")
                              MovePlayer (Funny joke answers)
                            }
                          }
                        ]]></script>
                        <object name="Funny joke answers">
                          <inherit name="scripttext" />
                          <options type="stringdictionary">
                            <item>
                              <key>Cafe_Death_two</key>
                              <value>She sounds nice!</value>
                            </item>
                          </options>
                          <script type="script">
                            SetForegroundColour ("DarkGreen")
                            if (GetBoolean(game, "swordknowledge")) {
                              AddPageLink (Funny joke answers, Cafe_death_one_prevented, "Quick, come stand next to me!")
                            }
                          </script>
                        </object>
                      </object>
                      <object name="Bad joke">
                        <inherit name="scripttext" />
                        <script type="script">
                          SetForegroundColour ("Purple")
                          msg ("Lilith looks saddened by your remark.")
                          SetForegroundColour ("OrangeRed")
                          msg ("Really? ...")
                          wait {
                            msg ("I thought it was funny when Abigail told me...")
                            MovePlayer (Bad joke part 2)
                          }
                        </script>
                        <object name="Bad joke part 2">
                          <inherit name="scripttext" />
                          <options type="stringdictionary">
                            <item>
                              <key>Cafe_Death_one</key>
                              <value>Well...</value>
                            </item>
                          </options>
                          <script type="script">
                            SetForegroundColour ("DarkGreen")
                          </script>
                        </object>
                      </object>
                      <object name="Not getting joke">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>Cafe_Death_one</key>
                            <value>No need to apoligize, I made you explain it. Besides, it's still pretty funny now that I understand the joke.</value>
                          </item>
                        </options>
                        <script type="script"><![CDATA[
                          SetForegroundColour ("OrangeRed")
                          msg ("Oh, the point of the joke is that the other two who entered the bar where religious fiures, the monk and the priest.<br/>So the rabbit doesn't quite fit in, it's because he was actually a rabbi instead. So I mispronounced that hence the \"did you slip your tongue?\" .<br/>Now that joke isn't exactly funny anymore is it? It tends to be that way when you explain a joke so I'm sorry if I ruined it for you.")
                          if (GetBoolean(game, "swordknowledge")) {
                            AddPageLink (Not getting joke, Cafe_death_one_prevented, "Quick, come stand next to me!")
                          }
                        ]]></script>
                      </object>
                    </object>
                  </object>
                </object>
              </object>
              <object name="Cafe_bad">
                <inherit name="scripttext" />
                <script type="script">
                  SetForegroundColour ("Purple")
                  msg ("Lilith frowns at your reaction.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("...")
                    msg ("There's no need to drag this place down just because you don't like it.")
                  }
                </script>
              </object>
              <object name="Cafe_okayish">
                <inherit name="scripttext" />
                <script type="script"><![CDATA[
                  SetForegroundColour ("Purple")
                  msg ("Lilith flashes you an understanding smile.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("Ah, sorry to hear that, but I am really loving this place if that's worth something.<br/>Maybe we can go to a place you like next time?<br/>I've never seen so many colors at the same time, thank you for taking me here {player.alias}.<br/>So far this is one of the best dates I ever had!")
                    MovePlayer (Cafe_great_choices)
                  }
                  SetFlagOn ("Cafe_taste")
                ]]></script>
              </object>
              <object name="Cafe_not first time i see">
                <inherit name="scripttext" />
                <options type="stringdictionary">
                  <item>
                    <key>Cafe_back on track</key>
                    <value>Oh, you probably just misheard me.</value>
                  </item>
                </options>
                <script type="script">
                  ClearScreen
                  SetForegroundColour ("OrangeRed")
                  msg ("Oh... I thought you said that you had only heard about this place.")
                  SetForegroundColour ("Purple")
                  msg ("Lilith pauses, seemingly not knowing what to say.")
                  SetForegroundColour ("Green")
                </script>
                <object name="Cafe_back on track">
                  <inherit name="scripttext" />
                  <script type="script">
                    SetForegroundColour ("Purple")
                    msg ("Lilith lets out a polite chuckle.")
                    SetForegroundColour ("OrangeRed")
                    msg ("Oh, my bad then!")
                    wait {
                      MovePlayer (Cafe_back on track joke)
                    }
                  </script>
                  <object name="Cafe_back on track joke">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>I want to hear your joke</key>
                        <value>Sure!</value>
                      </item>
                    </options>
                    <script type="script">
                      SetForegroundColour ("OrangeRed")
                      msg ("So...")
                      SetForegroundColour ("Purple")
                      msg ("Lilith pauses for what must've been a brief moment.")
                      SetForegroundColour ("OrangeRed")
                      msg ("Do you want to hear a joke?")
                    </script>
                  </object>
                </object>
              </object>
            </object>
          </object>
        </object>
        <object name="Cafe_Groundhog">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Cafe_noproof</key>
              <value>Hmm, I can't think of any good way to give you proof.</value>
            </item>
            <item>
              <key>Cafe_proof_sentence</key>
              <value>Alright, think of a random number.</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("OrangeRed")
            msg ("So you mean to tell me that you've already been on this specific date before?")
            msg ("I mean, I'm really thankful for you warning me, that would probably haven't ended too well for me.")
            msg ("But you got to admit that this really sounds contrived.")
            msg ("I mean, this whole thing seems pretty weird to me. Can you atleast offer me some proof?")
          </script>
          <object name="Cafe_proof_sentence">
            <inherit name="scripttext" />
            <script type="script">
              AddPageLink (Cafe_proof_sentence, number badoption 2, "It's 20.")
              AddPageLink (Cafe_proof_sentence, number badoption 3, "It's 38.")
              AddPageLink (Cafe_proof_sentence, number badoption 4, "It's -17.")
              if (GetBoolean(game, "burger")) {
                SetForegroundColour ("OrangeRed")
                msg ("This sounds interesting, alright, I've gotten my number!")
                AddPageLink (Cafe_proof_sentence, number badoption 1, "It's 5.")
                if (GetBoolean(game, "numberknowledge")) {
                  AddPageLink (Cafe_proof_sentence, correct number, "It's -72,8947, can we move on now?")
                }
                AddPageLink (Cafe_proof_sentence, number badoption 2, "It's 20.")
                AddPageLink (Cafe_proof_sentence, number badoption 3, "It's 38.")
                AddPageLink (Cafe_proof_sentence, number badoption 4, "It's -17.")
              }
              else {
                SetForegroundColour ("OrangeRed")
                msg ("This sounds interesting, alright, I've gotten my number!")
                AddPageLink (Cafe_proof_sentence, number badoption 1, "It's 5.")
                if (GetBoolean(game, "numberknowledge")) {
                  AddPageLink (Cafe_proof_sentence, correct number, "It's -72,8947, can we move on now?")
                }
                AddPageLink (Cafe_proof_sentence, number badoption 2, "It's 20.")
                AddPageLink (Cafe_proof_sentence, number badoption 3, "It's 38.")
                AddPageLink (Cafe_proof_sentence, number badoption 4, "It's -17.")
              }
            </script>
            <object name="number badoption 1">
              <inherit name="scripttext" />
              <script type="script">
                SetForegroundColour ("OrangeRed")
                msg ("That was the wrong number, I knew you wouldn't guess -72,8947!")
                SetFlagOn ("numberknowledge")
                SetFlagOn ("carknowledge")
                IncreaseCounter ("cardeaths")
                msg (" Listen, I'm really thankful for you maybe saving my life and all of that but you are giving a really implausible explanation and that whole guessing my number thing didn't even remotely work.")
                msg ("This is all way too much for me, I think I'm better of heading back to home.")
                SetForegroundColour ("Purple")
                msg ("Lilith and you both leave the restaurant, but just when you set one foot outside of the doorframe a red Sedan drives headfirst into the both of you.")
                msg ("Luckily you managed to get flung to the side somehow. Lilith however was not so lucky.")
                msg ("She died on impact when the speeding car hit her.")
                msg ("Atleast the drunkard who caused all of this will be locked up but you still lost Lilith.")
                SetFontSize (29)
                msg ("Game over")
                SetFontSize (13)
                msg ("Your date surely didn't go as planned.")
                SetFontSize (11)
                AddPageLink (number badoption 1, Gamestart, "Retry")
                SetForegroundColour ("OrangeRed")
              </script>
            </object>
            <object name="number badoption 2">
              <inherit name="scripttext" />
              <script type="script">
