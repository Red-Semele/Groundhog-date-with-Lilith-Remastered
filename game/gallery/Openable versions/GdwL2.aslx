  <object name="Page3">
    <description>This is page 3. Type a description here, and then create links to other pages below.</description>
  </object>
  <object name="Settings nd start">
    <inherit name="scripttext" />
    <options type="stringdictionary">
      <item>
        <key>Music</key>
        <value>Enable</value>
      </item>
    </options>
    <script type="script">
      SetForegroundColour ("DarkGreen")
      if (not GetBoolean(game, "music")) {
        AddPageLink (Settings nd start, Music, "Enable music.")
      }
      else {
        AddPageLink (Settings nd start, Music, "Disable music")
      }
    </script>
    <object name="Start">
      <object name="Namepicker">
        <inherit name="scripttext" />
        <description type="string"></description>
        <options type="stringdictionary" />
        <script type="script">
          TextFX_Typewriter ("Ah welcome to my game! Press a key to advance this screen.", 122)
          wait {
            TextFX_Typewriter ("In this game you will meet someone... special to say the least. I hope you'll like her!", 122)
            wait {
              TextFX_Typewriter ("Now, what do you want to name your character?", 122)
              GetInput() {
                if (result = "gallery") {
                  SetForegroundColour ("DarkGreen")
                  msg ("I hope you'll find something interesting there.")
                  wait {
                    MovePlayer (gallery)
                  }
                }
                else {
                  player.alias = CapFirst(result)
                  SetForegroundColour ("DarkGreen")
                  msg ("{player.alias}")
                  SetForegroundColour ("Purple")
                  TextFX_Typewriter ("That's a nice name, actually I can't check your name but I'll give you the benefit of the doubt.", 122)
                  wait {
                    TextFX_Typewriter ("So, now you are truly ready, good luck!", 122)
                    wait {
                      ClearScreen
                      MovePlayer (Gamestart)
                    }
                  }
                }
              }
            }
          }
        </script>
        <object name="player">
          <inherit name="defaultplayer" />
        </object>
      </object>
      <object name="Gamestart">
        <inherit name="scripttext" />
        <description type="string"></description>
        <options type="stringdictionary" />
        <sound type="string"></sound>
        <continuesound />
        <script type="script"><![CDATA[
          firsttime {
            SetForegroundColour ("Purple")
            msg ("It is a beautiful day unlike any other.<br/>And while it may have something to do with waking up with warm sunbeams caressing your face and absurd amounts of cheese stuffed inside your mouth it's something else that makes the day even better, or should I say someone else?")
            SetCounter ("Lildeaths", 0)
            wait {
              msg ("Suddenly your phone begins to blare \"Baby it's cold outside\" even though it's nowhere near winter.")
              wait {
                msg ("That has to be her, you better pick up the phone.")
                MovePlayer (phone choices)
              }
            }
            SetCounter ("sworddeaths", 0)
            SetCounter ("cardeaths", 0)
          }
          otherwise {
            // This just resets all the flags needed to make a more "dynamic" talking system.
            SetFontSize (12)
            SetFlagOff ("Cafe")
            SetFlagOn ("Lildeath")
            ClearScreen
            SetForegroundColour ("Purple")
            msg ("It is a beautiful day like the previous one, exactly like the previous one.<br/>Actually it's just the same day.<br/>Maybe you can make it just a tiny bit different.")
            wait {
              msg ("Suddenly your phone begins to blare \"Baby it's cold outside\" even though it's nowhere near winter.")
              wait {
                msg ("It's her. You should pick up the phone.")
                MovePlayer (phone choices)
              }
            }
          }
        ]]></script>
        <object name="phone choices">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>pick_phone</key>
              <value>Pick up the phone.</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
          <object name="pick_phone">
            <inherit name="scripttext" />
            <options type="stringdictionary">
              <item>
                <key>Burger restaurant</key>
                <value>Do burgers sound good?</value>
              </item>
              <item>
                <key>Chinese restaurant_riddles</key>
                <value>Test riddle</value>
              </item>
              <item>
                <key>Chinese restaurant</key>
                <value>Chinese restaurant start test</value>
              </item>
            </options>
            <script type="script"><![CDATA[
              SetForegroundColour ("OrangeRed")
              msg ("Hey {player.alias}! <br/>It's me, Lilith.<br/>I'm just calling you to see where you'd like to meet up for our date.")
              SetForegroundColour ("DarkGreen")
              if (not GetBoolean(game, "Cafe_taste")) {
                AddPageLink (pick_phone, Aquarium cafe, "I heard something about a cafe that has many exotic fish swim around in aquariums. ")
              }
              else {
                AddPageLink (pick_phone, Aquarium cafe, "I heard there's a cafe that has many exotic fish swim around in aquariums, you'll absolutely love it!")
              }
            ]]></script>
          </object>
        </object>
      </object>
      <object name="Chinese Abby memories">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          SetForegroundColour ("OrangeRed")
          msg ("You know, I thought it was kind of funny that you brought me here.")
          wait {
            SetForegroundColour ("OrangeRed")
            msg ("Don't get me wrong, I really enjoy like it here but my sister, Abigail, adores this places.")
            msg ("Since mom and me took her here for her twelfth birthday she insisted on coming again for five years in a row.")
            wait {
              SetForegroundColour ("OrangeRed")
              msg ("<br/>She would always pick the orange chicken, it really was her favourite.")
              wait {
                MovePlayer (Chinese Abby memories choices)
              }
            }
          }
        ]]></script>
        <object name="Chinese Abby memories choices">
          <inherit name="scripttext" />
          <options type="stringdictionary">
            <item>
              <key>Chinese Abby memories choice 2</key>
              <value>She sounds nice, can you tell me more about her?</value>
            </item>
          </options>
          <script type="script">
            SetForegroundColour ("DarkGreen")
          </script>
          <object name="Chinese Abby memories choice 2">
            <inherit name="scripttext" />
            <options type="stringdictionary">
              <item>
                <key>Chinese Abby more info</key>
                <value>What does she like to do?</value>
              </item>
              <item>
                <key>Chinese monster underneath bed story</key>
                <value>What's one the funniest memories you both share?</value>
              </item>
            </options>
            <script type="script">
              SetForegroundColour ("Purple")
              msg ("Lilith gives you a big smile.")
              SetForegroundColour ("OrangeRed")
              msg ("Sure, what would you like me to tell you?")
              SetForegroundColour ("DarkGreen")
            </script>
            <object name="Chinese Abby more info">
              <inherit name="scripttext" />
              <script type="script"><![CDATA[
                SetForegroundColour ("Purple")
                msg ("Lilith chuckles slightly.")
                SetForegroundColour ("OrangeRed")
                msg ("Alright, here I go, just stop me when I begin to ramble on too much.<br/>")
                wait {
                  SetForegroundColour ("OrangeRed")
                  msg ("She really likes to make stuff, right now it's mostly games.<br/>She can't really code much so she uses Quest, it's a program that makes it easier to make textbased games.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("<br/>She makes tons of those games but barely manages to finish them.<br/>Even is she finishes them eventually, she almost never does anything with them.")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("<br/>She asks me to play a select few of those that get finished every now and then, they are not really complex at the slightest but I always find them strangely intriguing nontheless.")
                      wait {
                        MovePlayer (Abby game choice)
                      }
                    }
                  }
                }
              ]]></script>
              <object name="Abby game choice">
                <inherit name="scripttext" />
                <options type="stringdictionary">
                  <item>
                    <key>Abby tell me more about the games</key>
                    <value>What do you find so interesting about those games?</value>
                  </item>
                </options>
                <script type="script">
                  SetForegroundColour ("DarkGreen")
                </script>
                <object name="Abby tell me more about the games">
                  <inherit name="scripttext" />
                  <script type="script"><![CDATA[
                    SetForegroundColour ("OrangeRed")
                    msg ("Well for one, games made by a small team or even one person are almost an imprint of what those people were thinking right when they made their project.")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("Two of Abby's games especially seem like they have something to say about her as a person.")
                      SetForegroundColour ("Purple")
                      msg ("Lilith pauses for a moment before continuing")
                      wait {
                        SetForegroundColour ("OrangeRed")
                        msg ("<br/>In the first game you play as someone who has to feed a prisoner.<br/>You are discouraged from talking to the prisoner by someone who speaks in red text.<br/><br/>A textbox appears and upon typing something the prisoner responds...")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("It's here where things begin getting a bit... special.")
                          wait {
                            SetForegroundColour ("OrangeRed")
                            msg ("<br/>The prisoner begins to speak absolute nonsense no matter what you decide on typing into the textbox.<br/>The text coming from them is dark blue.")
                            msg ("They seem oddly happy to see you and yet they pay no attention to you at all.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("It's only one voice in there but they always refer to them as if there are multiples.<br/>They keep going on and on about how you are speaking in a \"stolen voice\" and how no one wants to listen to you.<br/>And yet they keep begging you to speak, not because they listen to you or understand your words but because they like the color of your text, light green.<br/><br/>")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("The prisoner keeps talking, mostly insulting you and commanding you to bow before them.<br/>After what felt like probably ten minutes of pure nonsense reactions to my input another voice began to speak.<br/>")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("That voice was dark green, <br/>It also didn't really pay attention to what I was saying but the prisoner also didn't seem to notice the other voice.<br/>It kept calling out for help, repeatedly.")
                                  wait {
                                    SetForegroundColour ("OrangeRed")
                                    msg ("<br/>I tried typing just the word \"help\" in the textbox, suddenly the door opened.<br/>A link appeared, if you clicked it you would enter the room so I did, I wanted to know who was talking to me this entire time.")
                                    wait {
                                      SetForegroundColour ("OrangeRed")
                                      msg ("<br/>There was no one there...<br/>Suddenly the door shut and I was locked inside.<br/><br/>After a while you begin speaking the same nonsense as the prisoner, in dark blue aswell.<br/>That's when the game ends abruptly and turns to black.")
                                      wait {
                                        ClearScreen
                                        wait {
                                          SetForegroundColour ("OrangeRed")
                                          msg ("Oh, I've been talking longer than I thought I would, maybe it's better to not talk about the other game then. <br/>What do you think {player.alias}?")
                                          wait {
                                            MovePlayer (Abby tell more about games choices)
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  ]]></script>
                  <object name="Abby tell more about games choices">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>Abby Tell me about the second game</key>
                        <value>I don't mind at all, go ahead if you'd like to.</value>
                      </item>
                    </options>
                    <script type="script">
                      SetForegroundColour ("DarkGreen")
                    </script>
                    <object name="Abby Tell me about the second game">
                      <inherit name="scripttext" />
                      <script type="script"><![CDATA[
                        SetForegroundColour ("OrangeRed")
                        msg ("The second game is a lot bigger.<br/>It's about a ravenprince who needs to climb a mountain with his wings bound together.")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("On his way the raven constantly meets new characters.")
                          wait {
                            msg ("A cow called Io that believes she is a cow because some farmers told her so and eventually turns into a raven when she talks to the ravenprince.")
                            wait {
                              msg ("A snake that keeps accidentally eating her own tail because she is confused, after freeing her she just starts once again.")
                              wait {
                                msg ("A humanoid shadow with a rectangle for a head that dissappears every time you try to talk to it.")
                                wait {
                                  msg ("A three headed statue of a woman, each head speaks a different language. They speak Dutch, English and French respectively but neither of them seems to be able to make coherent sentences.")
                                  wait {
                                    msg ("An old man that keeps walking in circles and who has gold coins where his eyes should be.")
                                    wait {
                                      msg ("All of those characters discourage you from climbing the mountain, all of them except for the most important character of them all from what I could understand.<br/>They are a saphire being that hugs the raven and tells them they are forgiven.")
                                      msg ("Upon being told that they black out and awaken at the foot of the mountain as if their entire climb didn't really happen.")
                                      wait {
                                        msg ("<br/>I must have \"completed\" that game atleast ten times, every time was exactly the same no matter wheter I picked different choices or not.")
                                        wait {
                                          SetForegroundColour ("OrangeRed")
                                          msg ("You know, I'm not sure what those games actually mean. <br/>What do you think?")
                                          wait {
                                            MovePlayer (Abby game theme choices)
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      ]]></script>
                      <object name="Abby game theme choices">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>Abby loops</key>
                            <value>The theme seems to be about loops.</value>
                          </item>
                          <item>
                            <key>Abby pure nonsense</key>
                            <value>There seems to be no theme, it's pure nonsense.</value>
                          </item>
                        </options>
                        <script type="script">
                          SetForegroundColour ("DarkGreen")
                        </script>
                        <object name="Abby loops">
                          <inherit name="scripttext" />
                          <options type="stringdictionary">
                            <item>
                              <key>Abby Likes loops</key>
                              <value>Maybe she just likes making games about loops?</value>
                            </item>
                          </options>
                          <script type="script"><![CDATA[
                            SetForegroundColour ("OrangeRed")
                            msg ("You might be onto something! <br/>The feeder becoming the prisoner and the raven climbing the mountain again and again, those things are cleary loops.<br/>But what does that mean?<br/>Why would Abby put that premise in two of her games?")
                            SetForegroundColour ("DarkGreen")
                          ]]></script>
                          <object name="Abby Likes loops">
                            <inherit name="scripttext" />
                            <script type="script">
                              SetForegroundColour ("Purple")
                              msg ("Lilith lets out a small chuckle.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("Who knows? Maybe that's all there is to it.")
                                wait {
                                  SetForegroundColour ("Purple")
                                  msg ("Lilith grows more somber and begins to slightly frown.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("And yet I can't shake the feeling that there is something going on with her, something I'm not noticing.")
                                  wait {
                                    SetForegroundColour ("OrangeRed")
                                    msg ("There's this voice in my head that keeps telling me I'm not good enough, that I failed her and that I destroy everything I touch.")
                                    wait {
                                      SetForegroundColour ("OrangeRed")
                                      msg ("I would love to tell you that I didn't believe that voice in the slightest but that would be a lie.")
                                      wait {
                                        SetForegroundColour ("OrangeRed")
                                        msg ("I don't want to lose her {player.alias}, I can't go through all of that again.")
                                        SetForegroundColour ("Purple")
                                        msg ("Tears begin streaming down her face as she looks at you with a defeated look in her eyes.")
                                        wait {
                                          MovePlayer (Chinese Lilith comfort of no choices)
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            </script>
                            <object name="Chinese Lilith comfort of no choices">
                              <inherit name="scripttext" />
                              <options type="stringdictionary">
                                <item>
                                  <key>Chinese comfort her by telling her she is good enough</key>
                                  <value>That voice is just doubt, you are good enough Lilith.</value>
                                </item>
                                <item>
                                  <key>Chinese comfort her by telling her you like her</key>
                                  <value>I know it's very hard to fight that voice in your head, I just want to tell you that I really like you for whatever it is worth.</value>
                                </item>
                              </options>
                              <script type="script">
                                SetForegroundColour ("DarkGreen")
                              </script>
                              <object name="Chinese comfort her by telling her you like her">
                                <inherit name="scripttext" />
