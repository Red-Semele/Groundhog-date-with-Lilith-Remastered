            <object name="Chinese beach story">
              <inherit name="scripttext" />
            </object>
            <object name="Chinese monster underneath bed story">
              <inherit name="scripttext" />
              <script type="script"><![CDATA[
                SetForegroundColour ("OrangeRed")
                msg ("I think I have a story you'll find quite funny, just stop me when I'm talking too much alright?")
                wait {
                  SetForegroundColour ("OrangeRed")
                  msg ("Abigail was like five years old at the time of our story.<br/>One night she shook me until I was awake, we used to share a bedroom with a bunk bed.")
                  wait {
                    SetForegroundColour ("OrangeRed")
                    msg ("She told me she heared whispering and laughing coming from underneath our bed and begged me to go investigate it.")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("I told her it was probably nothing and tried to go back to sleep but she wouldn't stop begging so I eventually gave in since I didn't want to wake the others.")
                      wait {
                        SetForegroundColour ("OrangeRed")
                        msg ("As I stood before the dark opening underneath the bunk bed I felt as if something was watching me. But monsters didn't exist, right?")
                        wait {
                          SetForegroundColour ("OrangeRed")
                          msg ("Right when I was thinking that I heard something whisper.<br/>I was terrified but as Abby's big sister I couldn't let her know I was so I tried to compose myself as best as I could and looked underneath the bed.<br/>")
                          wait {
                            SetForegroundColour ("OrangeRed")
                            msg ("It was pitch-black so I decided to put my head fully underneath the bed, alongside with my right arm.<br/>My hand brushed against something soft and just as I grabbed it laughter came from underneath the bed.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("I jumped back out, utterly terrified, nearly bursting out in tears.<br/>In my hand I held a pink rabbit, Abby's favourite toy, Mr. bunfluff.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("Apparently he was causing all that ruckus, his voicebox was slightly malfunctioning .")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("I jumped back out, utterly terrified, nearly bursting out in tears.<br/>In my hand I held a pink rabbit, Abby's favourite toy, Mr. bunfluff.")
                                  wait {
                                    SetForegroundColour ("OrangeRed")
                                    msg ("It's extremely amusing to picture how a pink bunny scared the crap out of two little girls, it even was funny back then.<br/>I remember laughing with her about the whole ordeal for what must've been another hour or so before going to sleep.")
                                    SetFlagOn ("bedcheck")
                                    wait {
                                      MovePlayer (Chinese monster bed story choices)
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              ]]></script>
              <object name="Chinese monster bed story choices">
                <options type="stringdictionary">
                  <item>
                    <key>Big sis helper</key>
                    <value>Sounds like you really care for your sister.</value>
                  </item>
                </options>
                <object name="Big sis helper">
                  <inherit name="scripttext" />
                  <options type="stringdictionary">
                    <item>
                      <key>Lose people before</key>
                      <value>Did you lose people already?</value>
                    </item>
                  </options>
                  <script type="script"><![CDATA[
                    SetForegroundColour ("OrangeRed")
                    msg ("Of course! I love her with all of my heart!<br/>... I just don't want to lose her, you know?")
                    SetForegroundColour ("Purple")
                    msg ("Lilith gives you a saddened look.")
                    SetForegroundColour ("DarkGreen")
                  ]]></script>
                  <object name="Lose people before">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>Everybody has lost someone before</key>
                        <value>Well, everybody has lost someone before. I just kind of asumed...</value>
                      </item>
                    </options>
                    <script type="script"><![CDATA[
                      SetForegroundColour ("OrangeRed")
                      msg ("...<br/>Is it that obvious?")
                      SetForegroundColour ("DarkGreen")
                    ]]></script>
                    <object name="Everybody has lost someone before">
                      <inherit name="scripttext" />
                      <options type="stringdictionary">
                        <item>
                          <key>Talk about it</key>
                          <value>Do you want to talk about it?</value>
                        </item>
                      </options>
                      <script type="script">
                        SetForegroundColour ("Purple")
                        msg ("Lilith lets out a small laugh.")
                        SetForegroundColour ("OrangeRed")
                        msg ("I suppose you are right.")
                        SetForegroundColour ("Purple")
                        msg ("Lilith begins to slightly tear up.")
                        SetForegroundColour ("DarkGreen")
                      </script>
                      <object name="Talk about it">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>I am hear to listen</key>
                            <value>That's fine, if you ever want to talk about it you can always give me a call.</value>
                          </item>
                        </options>
                        <script type="script">
                          SetForegroundColour ("OrangeRed")
                          msg ("I'd rather not honestly...")
                          SetForegroundColour ("DarkGreen")
                        </script>
                        <object name="I am hear to listen">
                          <inherit name="scripttext" />
                          <options type="stringdictionary">
                            <item>
                              <key>confide stranger</key>
                              <value>It can feel good to confide in strangers, it's not like they are going to know who to tell your secrets to.</value>
                            </item>
                            <item>
                              <key>then make me no stranger</key>
                              <value>Then ask me a few questions to not make me a stranger anymore.</value>
                            </item>
                          </options>
                          <script type="script"><![CDATA[
                            SetForegroundColour ("Purple")
                            msg ("She gives you a slight smile.")
                            SetForegroundColour ("OrangeRed")
                            msg ("No offence {player.alias} but you got to admit that I barely know you.<br/>Isn't it pretty weird to tell you about it?")
                            SetForegroundColour ("DarkGreen")
                          ]]></script>
                          <object name="confide stranger">
                            <inherit name="scripttext" />
                            <script type="script">
                              SetForegroundColour ("Purple")
                              msg ("Lilith scratches her head and gives you a nice smile.")
                              SetForegroundColour ("OrangeRed")
                              msg ("I suppose you are right, I might take you up on that offer eventually.")
                              wait {
                                MovePlayer (Chinese death one)
                              }
                            </script>
                          </object>
                          <object name="then make me no stranger">
                            <inherit name="scripttext" />
                            <script type="script"><![CDATA[
                              SetForegroundColour ("Purple")
                              msg ("Lilith begins to laugh.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("I'm not sure it really works like that {player.alias}.<br/>I can't really think of any combination of questions that would make me feel like I've known you for years.<br/>You get to know someone over the span of all your time together, not by seeing them one time.")
                                wait {
                                  msg ("<br/>But thanks for the sugestion either way!")
                                  SetForegroundColour ("Purple")
                                  msg ("Lilith gives you a cute little smile.")
                                  wait {
                                    MovePlayer (Chinese death one)
                                  }
                                }
                              }
                            ]]></script>
                          </object>
                        </object>
                      </object>
                    </object>
                  </object>
                </object>
              </object>
            </object>
          </object>
        </object>
      </object>
      <object name="Chinese death one">
        <inherit name="scripttext" />
        <script type="script">
          SetForegroundColour ("Purple")
          msg ("When the waitress arives with your double plates of Peking duck you and Lilithl immediately dig in.")
          msg ("She takes a break from her food and looks at you for a moment.")
          SetForegroundColour ("OrangeRed")
          msg ("You know, I'm actually glad we could meet here, I wanted to tell you something.")
          SetForegroundColour ("Purple")
          msg ("Before Lilith can finish her sentence her face starts to swell,")
          SetForegroundColour ("OrangeRed")
          msg ("Call an ambulance, now!")
          SetForegroundColour ("Purple")
          msg ("You grab your phone as you frantically start calling an ambulance.")
          msg ("A woman with a warm voice listens to your incoherent ramblings and tries her best to get the details, she sends an ambulance your way.")
          msg ("The ambulance arrives quite fast but not fast enough. The doctors conclude that it must have been some sort of severe allergic reaction that made her face swell untill she couldn't breathe anymore.")
          SetFontSize (29)
          msg ("Game over")
          SetFontSize (13)
          msg ("Your date surely didn't go as planned.")
          SetFlagOn ("allergyknowledge")
          IncreaseCounter ("Lildeaths")
          IncreaseCounter ("allergydeaths")
          SetFontSize (11)
          AddPageLink (Chinese death one, Gamestart, "Retry")
        </script>
      </object>
      <object name="Chinese restaurant_riddles">
        <inherit name="scripttext" />
        <script type="script"><![CDATA[
          SetCounter ("R1W", 0)
          SetCounter ("R2W", 0)
          SetCounter ("R3W", 0)
          SetCounter ("RW", 0)
          SetForegroundColour ("OrangeRed")
          msg ("Do you want to try to answer a few riddles in the meantime?<br/>")
          SetForegroundColour ("DarkGreen")
          msg ("You give her a quick nod.<br/>")
          SetForegroundColour ("OrangeRed")
          msg ("<br/>Alright, here is the first riddle.<br/>They are all based around Greek and Roman myths.<br/>So here we go.")
          SetForegroundColour ("OrangeRed")
          SetForegroundColour ("OrangeRed")
          msg ("To taunt the gods with webs of lies<br/>is to hang but not to die.<br/>")
          SetForegroundColour ("Purple")
          msg ("Lilith pauses for a moment.")
          SetForegroundColour ("OrangeRed")
          msg ("So, do you have an idea who I could be talking about?")
          if (GetBoolean(game, "R1knowledge")) {
            SetForegroundColour ("DarkGreen")
            msg ("You remember Lilith telling you the answer was Arachne.")
          }
          GetInput() {
            if (IsRegexMatch  ("arachne", LCase (result))) {
              SetForegroundColour ("OrangeRed")
              msg ("That's right!")
              wait {
                SetForegroundColour ("OrangeRed")
                msg ("Lets try out the next riddle.")
                wait {
                  SetForegroundColour ("OrangeRed")
                  msg ("Carried by Lightning with a crown of moon.")
                  SetForegroundColour ("Purple")
                  msg ("Lilith pauses for a moment.")
                  SetForegroundColour ("OrangeRed")
                  msg ("So, do you have an idea who I could be talking about?")
                  if (GetBoolean(game, "R2knowledge")) {
                    SetForegroundColour ("DarkGreen")
                    msg ("You remember Lilith telling you the answer was Europa.")
                  }
                  GetInput() {
                    if (IsRegexMatch  ("europa", LCase (result))) {
                      SetForegroundColour ("OrangeRed")
                      msg ("That's right!<br/>")
                      SetForegroundColour ("OrangeRed")
                      msg ("Lets try out the next riddle.")
                      wait {
                        SetForegroundColour ("OrangeRed")
                        msg ("The musical barterer returned empty-handed from the underworld.")
                        SetForegroundColour ("Purple")
                        msg ("Lilith pauses for a moment.")
                        SetForegroundColour ("OrangeRed")
                        msg ("So, do you have an idea who I could be talking about?")
                        if (GetBoolean(game, "R3knowledge")) {
                          SetForegroundColour ("DarkGreen")
                          msg ("You remember Lilith telling you the answer was Orpheus.")
                        }
                        GetInput() {
                          if (IsRegexMatch  ("orpheus", LCase (result))) {
                            SetForegroundColour ("OrangeRed")
                            msg ("That's right!")
                            wait {
                              MovePlayer (Riddle evalution page)
                            }
                          }
                          else {
                            SetForegroundColour ("OrangeRed")
                            msg ("Hmm, not exactly who I was thinking about.<br/>would you like to try again or have me give the answer?")
                            wait {
                              IncreaseCounter ("R3W")
                              IncreaseCounter ("RW")
                              MovePlayer (Riddle three menu)
                            }
                          }
                        }
                      }
                    }
                    else {
                      SetForegroundColour ("OrangeRed")
                      msg ("Hmm, not exactly who I was thinking about.<br/>would you like to try again or have me give the answer?")
                      wait {
                        IncreaseCounter ("R2W")
                        IncreaseCounter ("RW")
                        MovePlayer (Riddle two menu)
                      }
                    }
                  }
                }
              }
            }
            else {
              SetForegroundColour ("OrangeRed")
              msg ("Hmm, not exactly who I was thinking about.<br/>would you like to try again or have me give the answer?")
              wait {
                IncreaseCounter ("R1W")
                IncreaseCounter ("RW")
                MovePlayer (Riddle one menu)
              }
            }
          }
        ]]></script>
