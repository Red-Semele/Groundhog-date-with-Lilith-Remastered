                              </script>
                              <object name="Chinese comfort her by telling her you feel like you know her pretty well">
                                <inherit name="scripttext" />
                                <script type="script"><![CDATA[
                                  SetForegroundColour ("LightGreen")
                                  msg ("You will tell her what you've learned from the looping, how she is as a person. <br/>(I made quite a few paths for the Chinese restaurant path so I need to still complete some.)")
                                  wait {
                                    MovePlayer (Chinese death one)
                                  }
                                ]]></script>
                              </object>
                              <object name="Chinese yes but you should aswell">
                                <inherit name="scripttext" />
                                <script type="script"><![CDATA[
                                  SetForegroundColour ("Purple")
                                  msg ("Lilith chuckles with a pained expression painted on her face.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("I suppose you are right.<br/>I need to believe that I'm a good person, otherwise it would just be empty praise coming from someone I barely met.")
                                  wait {
                                    SetForegroundColour ("Purple")
                                    msg ("Lilith tries her best to give you a smile, you can tell it's slightly forced.")
                                    SetForegroundColour ("OrangeRed")
                                    msg ("No offence {player.alias}! I like how our date is going so far, even though I am messing it up pretty badly right now, but this is our first date afterall.")
                                    wait {
                                      MovePlayer (Chinese death one)
                                    }
                                  }
