                        <object name="Abby pure nonsense">
                          <inherit name="scripttext" />
                          <script type="script"><![CDATA[
                            SetForegroundColour ("OrangeRed")
                            msg ("Hmm, do you really think so?")
                            SetForegroundColour ("Purple")
                            msg ("Lilith softly scratches her head.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              msg ("It's hard to believe that something could ever be just pure nonsense and nothing else.<br/>You have to pull the ideas you use to make a game or something else from somewhere, right?")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("I'd like to think that even if someone would try to make a game that is just pure nonsense that atleast some aspects of meaning would seep into it.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Afterall, the medium is the message.")
                                  wait {
                                    SetForegroundColour ("OrangeRed")
                                    msg ("So is it possible to create and form something without meaning even slightly implied?")
                                    wait {
                                      SetForegroundColour ("OrangeRed")
                                      msg ("Sorry if I'm boring you, it's just something I've been thinking about for a while now.")
                                      wait {
                                        MovePlayer (Abby pure nonsense choices)
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          ]]></script>
