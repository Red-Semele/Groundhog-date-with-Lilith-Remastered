                                  SetForegroundColour ("LightGreen")
                                  msg ("This dialog still needs to be made but it will move you to the first death.")
                                  wait {
                                    MovePlayer (Chinese death one)
                                  }
                                </script>
                              </object>
                            </object>
                            <object name="Chinese comfort her by telling her she is good enough">
                              <inherit name="scripttext" />
                              <description type="string"></description>
                              <options type="stringdictionary">
                                <item>
                                  <key>Chinese yes but you should aswell</key>
                                  <value>I do but I think you are the one who needs to believe that for it to work.</value>
                                </item>
                              </options>
                              <script type="script">
                                SetForegroundColour ("OrangeRed")
                                msg ("Do you really believe that, {player.alias}?")
                                if (GetBoolean(game, "shootknowledge")) {
                                  if (GetBoolean(game, "swordknowledge")) {
                                    AddPageLink (Chinese comfort her by telling her she is good enough, Chinese comfort her by telling her you feel like you know her pretty well, "Absolutely! I feel like I know you decently well and you really have no reason to doubt yourself.")
                                  }
