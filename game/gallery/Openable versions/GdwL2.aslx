            <object name="correct number">
              <inherit name="scripttext" />
              <script type="script"><![CDATA[
                SetForegroundColour ("Purple")
                msg ("Lilith looks absolutely flabergasted, her mouth is slightly opened and seems to be frozen for a moment or two.")
                SetForegroundColour ("OrangeRed")
                msg ("So you were actually speaking the truth? <br/>You really are living in some sort of groundhog-day like scenario?")
                msg ("Even with that proof it's pretty hard to get my brain to accept it.")
                msg ("I feel like when I'm going to admit I believe you there is going to come an entire camera crew out of nowhere and I'll be made fun of in some bad tv show. But let's say I am starting to believe you a little bit so we won't have the camera crew barge in on us.")
                msg ("So what is this all about?")
                SetForegroundColour ("DarkGreen")
                if (GetBoolean(game, "Cafe")) {
                  AddPageLink (correct number, Breaking loop, "I'm trying to break my loop by making sure you don't die on this date.")
                }
                else if (GetBoolean(game, "Burger")) {
                  AddPageLink (correct number, Burger_escape fate, "I'm trying to escape fate to save you from dying.")
                }
              ]]></script>
              <object name="Cafe_Groundhog_questions">
                <object name="Breaking loop">
                  <inherit name="scripttext" />
                  <script type="script">
                    SetForegroundColour ("OrangeRed")
                    msg ("So...")
                    SetForegroundColour ("Purple")
                    wait {
                      SetForegroundColour ("OrangeRed")
                      msg ("You mean that I have died multiple times in here and that every time I do so you get send back in time?")
                      msg ("So does you saving me just now mean that we are save? That your whole looping problem is able to stop?")
                      MovePlayer (Breaking loop questions)
                    }
                  </script>
                  <object name="Breaking loop questions">
                    <inherit name="scripttext" />
                    <options type="stringdictionary">
                      <item>
                        <key>I broke the loop</key>
                        <value>Yup, I broke the loop once and for all!</value>
                      </item>
                      <item>
                        <key>The loop still exists</key>
                        <value>The loop actually still exists.</value>
                      </item>
                      <item>
                        <key>Loop maybe gone</key>
                        <value>It could be gone but I'm not sure, I never made it this far in this cafe.</value>
                      </item>
                    </options>
                    <script type="script">
                      SetForegroundColour ("DarkGreen")
                    </script>
                    <object name="I broke the loop">
                      <inherit name="scripttext" />
                      <options type="stringdictionary" />
                      <script type="script"><![CDATA[
                        SetForegroundColour ("Purple")
                        msg ("A wide grin appears on Lilith's face.")
                        SetForegroundColour ("OrangeRed")
                        msg ("So, did we just cheat death?<br/>We actually did it, didn't we?<br/><br/>Thank you so much for saving me {player.alias}!")
                        wait {
                          msg ("Is it weird for me to feel absolutely ecstatic right now?")
                          MovePlayer (I broke the loop questions)
                        }
                      ]]></script>
                      <object name="I broke the loop questions">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>No weird to feel happy</key>
                            <value>Absolutely not! This also probably has never happened to anyone before so I doubt there is a standard way to react when it comes to this.</value>
                          </item>
                          <item>
                            <key>You do you Lilith</key>
                            <value>Absolutely not!  You have every right to feel happy.</value>
                          </item>
                          <item>
                            <key>I am also happy</key>
                            <value>Absolutely not! I am also happy for us.</value>
                          </item>
                        </options>
                        <script type="script">
                          SetForegroundColour ("DarkGreen")
                        </script>
                        <object name="No weird to feel happy">
                          <inherit name="scripttext" />
                          <script type="script">
                            SetForegroundColour ("OrangeRed")
                            msg ("I suppose you are right, this is quite an exceptional scenario. I thought that atleasst one person must've had this happen to them before, but those odds seem pretty low in retrospect.")
                            wait {
                              SetForegroundColour ("Purple")
                              msg ("Lilith gives you a thumbs-up and a cute laugh.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("And despite the odds you did everything you could and saved me! You are... sort of my hero now?")
                                SetForegroundColour ("Purple")
                                msg ("Lilith begins to turn a bright red, she begins to more closely resemble a cute tomato than a human.")
                                wait {
                                  msg ("Somehow she must've noticed her excessive blushing as she covers her face up with her hands and begins to giggle.")
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Sorry, once I get blushing I turn beet red really quickly.")
                                  wait {
                                    MovePlayer (Cafe_Death_two)
                                  }
                                }
                              }
                            }
                          </script>
                        </object>
                        <object name="You do you Lilith">
                          <inherit name="scripttext" />
                          <script type="script"><![CDATA[
                            SetForegroundColour ("OrangeRed")
                            msg ("Huh, you are right, aren't you?")
                            msg ("I shouldn't seek justification for my feelings.<br/>Especially now, we literally cheated death itself so I have every right to feel exstatic!<br/><br/>Well, it was mostly your work but still, that doesn't happen every day.<br/>")
                            wait {
                              SetForegroundColour ("Purple")
                              msg ("Lilith lets out a small chuckle.")
                              SetForegroundColour ("OrangeRed")
                              msg ("I suppose that it happened quite a few days for you but still, that's cheating!")
                              wait {
                                SetForegroundColour ("Purple")
                                msg ("Lilith pauses for a few seconds while looking you into the eyes. <br/>A soft smile has formed on her lips.")
                                wait {
                                  SetForegroundColour ("OrangeRed")
                                  msg ("Thank you {player.alias}, thank you for both saving me from my impending doom and for this date. <br/>I am really having a blast right now, although I must admit I had a slight headache trying to get my head around this whole thing.")
                                  wait {
                                    MovePlayer (Cafe_Death_two)
                                  }
                                }
                              }
                            }
                          ]]></script>
                        </object>
                        <object name="I am also happy">
                          <inherit name="scripttext" />
                          <script type="script"><![CDATA[
                            SetForegroundColour ("OrangeRed")
                            msg ("Then come dance with me! ")
                            SetForegroundColour ("Purple")
                            msg ("Lilith gets up and beckons you closer with a wide smile.")
                            if (not GetBoolean(game, "drownknowledge")) {
                              msg ("The two of you begin to move around with all kinds of limb-shaking that probably could be considered dancing by some.<br/>Knowing that you finally did it fills you with seemingly endless energy.")
                              wait {
                                MovePlayer (Cafe_Death_two)
                              }
                            }
                          ]]></script>
                        </object>
                      </object>
                    </object>
                    <object name="The loop still exists">
                      <inherit name="scripttext" />
                      <script type="script"><![CDATA[
                        SetForegroundColour ("OrangeRed")
                        msg ("Ah, so the loop still exists?<br/>I mean, me dying constantly doesn't seem like it's much fun but look at it from the bright side!")
                        wait {
                          msg ("We could form a team to be true heroes!  With your ability to relive the same moments and with my ability to... well die, I suppose, we could be practically unstoppable!")
                          msg ("Well, that is if we ever get out of here alive in the first place.")
                          wait {
                            SetForegroundColour ("Purple")
                            msg ("Lilith lets out a small chuckle but the concern in her eyes is clearly visible.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Sorry, this is still a bit much for me.<br/>I mean imagine that someone you were dating just told you that the two of you are stuck in a seemingly endless loop that always ends up with you dying.<br/>That would be pretty mind-boggling, wouldn't it?")
                            wait {
                              msg ("Yes, I suppose that's one way to put it.")
                              SetForegroundColour ("Purple")
                              msg ("Lilith lets out a small sigh and tries to give you a sincere smile.")
                              SetForegroundColour ("OrangeRed")
                              msg ("But it's not that useful to keep groaning about our situation, is it? <br/>Maybe it's a better idea to get some information that we can use.")
                              SetForegroundColour ("Purple")
                              msg ("Lilith pauses for a few seconds.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("For example, what do you think will happen once we make it past this date? Past this day even, do you think you would be stuck in a loop of reloading day after day for the years that we spend together or that all of this will go away when we make it through today?")
                                MovePlayer (The loop still exists questions)
                              }
                            }
                          }
                        }
                      ]]></script>
                      <object name="The loop still exists questions">
                        <inherit name="scripttext" />
                        <options type="stringdictionary">
                          <item>
                            <key>I hope it will end</key>
                            <value>It should only be this day that keeps repeating, I hope so atleast.</value>
                          </item>
                          <item>
                            <key>For the rest of our lives</key>
                            <value>We might be in this situation for the rest of our lives.</value>
                          </item>
                        </options>
                        <script type="script">
                          SetForegroundColour ("DarkGreen")
                        </script>
                        <object name="I hope it will end">
                          <inherit name="scripttext" />
                          <script type="script">
                            SetForegroundColour ("OrangeRed")
                            msg ("Hmm, then I wonder what made you experience a groundhog day scenario on this day and not any other one.")
                            msg ("Would it really have been caused by the dinner date? And if that's the case then what would you need to do to get out of it?")
                            SetForegroundColour ("OrangeRed")
                            msg ("Lilith looks at you and seems to be lost in her own thoughts for a moment.")
                            SetForegroundColour ("OrangeRed")
                            msg ("So when I died by that one bullet you had to relive this day again right?")
                            msg ("You nod.")
                            msg ("Hmm, in that case I would advise you to try to not get me killed.")
                            msg ("Lilith burst out to laughter.")
                            msg ("Abigail: Sorry, I'm not really accustomed to this whole thing yet. I have no clue how I could help you but if you have anything in mind just let me know.")
                            SetForegroundColour ("OrangeRed")
                          </script>
                        </object>
                        <object name="For the rest of our lives">
                          <inherit name="scripttext" />
                          <script type="script">
                            SetForegroundColour ("OrangeRed")
                            msg ("I really hope that will not  be the case, I don't want to die too early ofcourse, but when I have lived a long life and my time has come I'd be more than happy to go.")
                            SetForegroundColour ("Purple")
                            msg ("Lilith looks at you as to make sure you're processing all of this, you give her a silent nod and she continues.")
                            SetForegroundColour ("OrangeRed")
                            msg ("I mean, imagine what a nightmare it must be for the both of us.")
                            msg ("You would be cursed with always having to save an old lady that could literally die any moment, always just buying her a few extra hours.")
                            SetForegroundColour ("OrangeRed")
                            msg ("And I would be cursed with never getting to pass away, I would be the oldest person that was ever alive and just be a living heap of flesh and wrinkles after a year or 200. No matter how much I would pray for the sweet release of death it would never come, or atleast I would never be aware that it came as you would just rewind and try to fix it.")
                            SetForegroundColour ("Purple")
                            msg ("Lilith shudders.")
                            SetForegroundColour ("OrangeRed")
                            msg ("Let's just hope that this loop will end for the both of us before we get at that point.")
                            SetForegroundColour ("Purple")
                            msg ("Shaken by the images of a living heap of flesh and wrinkles you can only agree with her.")
                            wait {
                              MovePlayer (Cafe_Death_two)
                            }
                          </script>
                        </object>
                      </object>
                    </object>
                    <object name="Loop maybe gone">
                      <inherit name="scripttext" />
                      <script type="script"><![CDATA[
                        SetForegroundColour ("Purple")
                        msg ("Lilith lets out a small sigh and chuckles.")
                        SetForegroundColour ("OrangeRed")
                        msg ("Ah, then I guess we will just have to wait and see, I really hope that this loop ends, for the both of us.")
                        msg ("Also, you said you never have gotten this far here, does that mean that I am the first of... well, myself, you have met to this extent?")
                        SetForegroundColour ("Purple")
                        msg ("Her face seems to have lit up with glee as she expectantly awaits your answer.")
                        firsttime {
                          if (GetBoolean(game, "drownknowledge")) {
                            SetForegroundColour ("Purple")
                            msg ("You give Lilith a nod.")
                            msg ("You try to leave out the part where you already have seen her die in this cafe before and hope that she won't see through your slightly forced smile.")
                            wait {
                              MovePlayer (Loop maybe gone 2)
                            }
                          }
                          else {
                            SetForegroundColour ("Purple")
                            msg ("You give Lilith a nod and feel a wide smile forming on your face.")
                            msg ("You are excited about where the future will lead the two of you.")
                            wait {
                              MovePlayer (Loop maybe gone 2)
                            }
                          }
                        }
                        otherwise {
                          SetForegroundColour ("Purple")
                          msg ("For a moment you consider telling Lilith that this is in fact not the first time you've had this exact conversation.")
                          wait {
                            msg ("But in the end you can't push yourself to tell her the truth, not like this.<br/>Not with her desperatly clinging on to the last pieces of hope that are left.<br/>Maybe you are slightly projecting your feelings...<br/><br/>You try to do your best impression of your own nod and force out a smile to seem more sincere.")
                            wait {
                              MovePlayer (Loop maybe gone 2)
                            }
                          }
                        }
                      ]]></script>
                      <object name="Loop maybe gone 2">
                        <inherit name="scripttext" />
                        <script type="script"><![CDATA[
                          SetForegroundColour ("Purple")
                          msg ("She seems oddly happy with your answer as she lets out a genuine laugh.")
                          SetForegroundColour ("OrangeRed")
                          msg ("That's extremely cool!")
                          SetForegroundColour ("Purple")
                          wait {
                            msg ("A few people are looking at your table when Lilith shouted it, you can see her face become as red as a tomato in an instant.")
                            wait {
                              SetForegroundColour ("OrangeRed")
                              SetFontSize (9)
                              msg ("Ehrm, I mean, that's pretty neat.<br/>It's still much to wrap my head around but the idea that I am the first version of myself you talk to in this very moment... well, it's pretty flattering.")
                              SetForegroundColour ("Purple")
                              SetFontSize (12)
                              msg ("Lilith lets out a soft giggle, still partially aware of the eyes that were pointed on her back mere moments ago.")
                              SetForegroundColour ("OrangeRed")
                              SetFontSize (10)
                              msg ("But anyway, before we get completely of track there was something I wanted to ask you!")
                              SetForegroundColour ("Purple")
                              SetFontSize (12)
                              msg ("She blurted that line out as fast as she could, you've spent enough time with her to know she usually doesn't talk like that.")
                              msg ("Maybe she is embarrassed about what she wants to ask you, or maybe it's something else.<br/><br/>You try to make it easier for her to continue by giving her a nod and a supportive smile, whatever one of those may look like.")
                              SetForegroundColour ("OrangeRed")
                              msg ("What... would happen when we make it out of this loop?")
                              msg ("Would we see eachother again?")
                              msg ("Would we get to spend more time together?")
                              msg ("Because...")
                              wait {
                                msg ("This may seem a bit strange but...")
                                wait {
                                  msg ("I really like spending time with you and would not want to lose all of this.")
                                  SetForegroundColour ("Purple")
                                  msg ("She waves around with her arms as if to give the statement extra validity.")
                                  wait {
                                    MovePlayer (Loop maybe gone 2 answers)
                                  }
                                }
                              }
                            }
                          }
                        ]]></script>
                        <object name="Loop maybe gone 2 answers">
                          <inherit name="scripttext" />
                          <options type="stringdictionary">
                            <item>
                              <key>Lilith of course we will spend time together</key>
                              <value>Of course we will spend time together, I really like you.</value>
                            </item>
                            <item>
                              <key>I am doing all of this for you</key>
                              <value>I am doing all of this for you Lilith, I feel like I am starting to really know you and would love to learn more about you.</value>
                            </item>
                          </options>
                          <script type="script">
                            SetForegroundColour ("DarkGreen")
                          </script>
                          <object name="Lilith of course we will spend time together">
                            <inherit name="scripttext" />
                            <options type="stringdictionary" />
                            <script type="script"><![CDATA[
                              SetForegroundColour ("Purple")
                              msg ("Lilith seems to freeze for a few seconds after hearing those words.<br/>In an effort to thaw herself her face begins to glow red once more.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("I... I'd like that very much!<br/>One day I'd like to know you as well as you probably know me from reliving the same day constantly.<br/>I would love to be able to do that but for now we are stuck in this loop, I  believe in you {player.alias}, I know you can break this loop!")
                                MovePlayer (Spend time answers)
                              }
                            ]]></script>
                            <object name="Spend time answers">
                              <inherit name="scripttext" />
                              <options type="stringdictionary">
                                <item>
                                  <key>Cafe_Death_two</key>
                                  <value>I promise to do everything I can Lilith.</value>
                                </item>
                              </options>
                              <script type="script">
                                SetForegroundColour ("DarkGreen")
                              </script>
                            </object>
                          </object>
                          <object name="I am doing all of this for you">
                            <inherit name="scripttext" />
                            <script type="script"><![CDATA[
                              SetForegroundColour ("OrangeRed")
                              msg ("I... you... uhm")
                              SetForegroundColour ("Purple")
                              msg ("Lilith stumbles over her words for a few seconds.<br/>You can see a few tears in her eyes but from the look she is giving you you can deduce that those are tears of happiness.")
                              wait {
                                SetForegroundColour ("OrangeRed")
                                msg ("Thank you {player.alias}, I mean it from the bottom of my heart. Thank you for being here, with me, for me, it means more than I could probably express. ")
                                wait {
                                  MovePlayer (Cafe_Death_two)
                                }
                              }
                            ]]></script>
                          </object>
                        </object>
                      </object>
                    </object>
                  </object>
                </object>
              </object>
            </object>
          </object>
          <object name="Cafe_noproof">
            <inherit name="scripttext" />
            <script type="script">
              SetForegroundColour ("OrangeRed")
              msg ("Listen, I'm really thankful for you potentially saving my life and everything but I really think I need atleast some semblance of an explanation.")
              msg ("This is all a bit much for me, I think I'm better of heading back to home to calm down, I'm sorry.")
              SetForegroundColour ("Purple")
              msg ("You try to chase Lilith on her way out to explain what is going on  but just when you set one foot outside of the doorframe a red Sedan drives head first into the both of you.")
              msg ("Luckily you managed to get flung to the side somehow. Lilith however was not so lucky.")
              msg ("She died on impact when the speeding car hit her.")
              msg ("Atleast the drunkard who caused all of this will be locked up but you still lost Lilith.")
              SetFontSize (29)
              msg ("Game over")
              SetFontSize (13)
              msg ("Your date surely didn't go as planned.")
              SetFontSize (11)
              AddPageLink (Cafe_noproof, Gamestart, "Retry")
              SetForegroundColour ("OrangeRed")
            </script>
          </object>
        </object>
        <object name="Cafe_Death_one">
          <inherit name="scripttext" />
          <script type="script">
            SetForegroundColour ("Purple")
            msg ("Suddenly you hear someone scream, you can turn your head just quick enough to see someone fall with a plate in their hands.")
            msg ("The plate flies in the air, with it the ham sandwich that was put on top of it.")
            msg ("You are apparently not the only one who has noticed, as you can see a beautiful blue marlin jump from an opening in the aquarium.")
            msg ("The marlin has a long and pointy bill, it pierces the sandwich in a feat of pure dexterity. ")
            msg ("Sadly it's traject leads right to Lilith's chest as it's sword-like bill pierces her chest, somehow you know it has pierced her heart aswell.")
            msg ("She gives you on last look of utter shock before she falls dead on the floor.")
            SetFontSize (29)
            msg ("Game over")
            SetFontSize (13)
            msg ("Your date surely didn't go as planned.")
            SetFlagOn ("swordknowledge")
            SetFontSize (12)
            AddPageLink (Cafe_Death_one, Gamestart, "Retry")
            SetForegroundColour ("Purple")
            IncreaseCounter ("Lildeaths")
            IncreaseCounter ("sworddeaths")
          </script>
        </object>
      </object>
    </object>
    <object name="Settings">
      <object name="Music" />
    </object>
  </object>
</asl>